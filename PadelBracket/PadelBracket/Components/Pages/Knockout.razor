@page "/tournaments/{TournamentId:guid}/categories/{Category:int}/knockout"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject KnockoutService KnockoutService
@inject OrganizerAccountService OrganizerAccountService
@rendermode InteractiveServer

<PageTitle>Llave eliminatoria</PageTitle>

@if (tournament == null)
{
    <section class="access-state">
        <span class="access-state-icon">LL</span>
        <div>
            <div class="panel-kicker">Llave eliminatoria</div>
            <h1>No se encontró el torneo.</h1>
            <p>Puede haber sido eliminado o la dirección no corresponde a una llave válida.</p>

            <a class="btn btn-primary" href="/tournaments">
                Volver a torneos
            </a>
        </div>
    </section>
}
else if (CurrentOrganizer == null)
{
    <section class="access-state">
        <span class="access-state-icon">OR</span>
        <div>
            <div class="panel-kicker">Panel de organizador</div>
            <h1>Acceso de organizador</h1>
            <p>Iniciá sesión con tu cuenta de organizador para administrar esta llave eliminatoria.</p>

            <div class="access-state-actions">
                <a class="btn btn-primary" href="/organizer/login">
                    Ingresar como organizador
                </a>

                <a class="btn btn-outline-primary" href="/tournaments">
                    Volver a torneos
                </a>
            </div>
        </div>
    </section>
}
else if (!CanManageTournament)
{
    <section class="access-state">
        <span class="access-state-icon">!</span>
        <div>
            <div class="panel-kicker">Panel de organizador</div>
            <h1>Acceso denegado</h1>
            <p>Solo el organizador dueño del torneo puede generar llaves y cargar resultados.</p>

            <a class="btn btn-primary" href="/tournaments">
                Volver a mis torneos
            </a>
        </div>
    </section>
}
else
{
    <a class="panel-link tournament-back-link" href="@($"/tournaments/{tournament.Id}")">
        ← Volver al torneo
    </a>

    <section class="dashboard-hero knockout-hero">
        <div>
            <div class="page-eyebrow">Eliminatoria</div>
            <h1 class="page-title">Llave eliminatoria</h1>
            <p class="page-subtitle">
                @tournament.Name · @GetCategoryLabel(Category)
            </p>
        </div>

        <span class="status-pill">
            @GetCategoryGroupCount() grupos
        </span>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-warning">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <section class="metric-grid knockout-metric-grid">
        <div class="metric-card">
            <div class="metric-icon">LL</div>
            <div>
                <div class="metric-label">Estado de llave</div>
                <div class="metric-value metric-value-text">@(bracket == null ? "Sin generar" : "Generada")</div>
                <div class="metric-trend">Categoría @GetCategoryLabel(Category)</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">MT</div>
            <div>
                <div class="metric-label">Partidos</div>
                <div class="metric-value">@GetKnockoutMatchCount()</div>
                <div class="metric-trend">@GetCompletedKnockoutMatchCount() con resultado</div>
            </div>
            <div class="metric-sparkline"></div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">PD</div>
            <div>
                <div class="metric-label">Listos para jugar</div>
                <div class="metric-value">@GetReadyKnockoutMatchCount()</div>
                <div class="metric-trend">Pendientes de resultado</div>
            </div>
            <div class="metric-sparkline"></div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">CP</div>
            <div>
                <div class="metric-label">Campeones</div>
                <div class="metric-value metric-value-text">@GetPairName(GetChampion())</div>
                <div class="metric-trend">Se define al cargar la final</div>
            </div>
        </div>
    </section>

    @if (bracket == null)
    {
        <div class="card shadow-sm knockout-command-card">
            <div class="card-body">
                <div class="panel-header">
                    <div>
                        <div class="panel-kicker">Preparación</div>
                        <h2>Generar llave</h2>
                        <p>
                            La llave se genera con los clasificados de los grupos de esta categoría.
                            Por ahora clasifican 2 parejas por grupo.
                        </p>
                    </div>
                </div>

                <div class="knockout-rules-grid">
                    <div>
                        <strong>2 grupos</strong>
                        <span>Semifinales</span>
                    </div>
                    <div>
                        <strong>4 grupos</strong>
                        <span>Cuartos de final</span>
                    </div>
                    <div>
                        <strong>8 grupos</strong>
                        <span>Octavos de final</span>
                    </div>
                </div>

                <div class="panel-actions">
                    <button class="btn btn-success" @onclick="GenerateBracket">
                        Generar llave
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="knockout-status-bar">
            <div>
                <strong>Llave generada</strong>
                <span>@bracket.CreatedAt.ToString("dd/MM/yyyy HH:mm") · @GetCompletedKnockoutMatchCount()/@GetKnockoutMatchCount() resultados cargados</span>
            </div>

            <button class="btn btn-outline-danger"
                    @onclick="ToggleDeleteConfirmation">
                Eliminar llave
            </button>
        </div>

        @if (showDeleteConfirmation)
        {
            <div class="alert alert-danger knockout-delete-panel">
                <h5>¿Eliminar esta llave?</h5>

                @if (BracketHasResults())
                {
                    <p class="mb-2">
                        Esta llave ya tiene resultados cargados. Si la eliminás, también se pierden esos resultados y los avances de ronda.
                    </p>
                }
                else
                {
                    <p class="mb-2">
                        Esta llave no tiene resultados cargados todavía.
                    </p>
                }

                <p class="mb-3">
                    Después podrás generar una nueva llave con los clasificados actuales.
                </p>

                <button class="btn btn-danger me-2" @onclick="DeleteBracket">
                    Sí, eliminar llave
                </button>

                <button class="btn btn-outline-secondary" @onclick="CancelDeleteConfirmation">
                    Cancelar
                </button>
            </div>
        }

        var rounds = GetRounds();
        var bracketRows = GetBracketRows(rounds);

        <div class="knockout-board-wrapper">
            <div class="knockout-board" style="--round-count: @rounds.Count; --bracket-rows: @bracketRows">
                @for (int roundIndex = 0; roundIndex < rounds.Count; roundIndex++)
                {
                    var round = rounds[roundIndex];

                    <section class="knockout-round">
                        <div class="knockout-round-header">
                            <div>
                                <h3>@round.Name</h3>
                                <span>@round.Matches.Count partidos</span>
                            </div>
                        </div>

                        <div class="knockout-match-list">
                            @for (int matchIndex = 0; matchIndex < round.Matches.Count; matchIndex++)
                            {
                                var match = round.Matches[matchIndex];

                                <article class="@GetKnockoutMatchClass(match)" style="@GetMatchStyle(roundIndex, matchIndex)">
                                    @if (roundIndex > 0)
                                    {
                                        <span class="knockout-merge-line" aria-hidden="true"></span>
                                    }

                                    <div class="knockout-match-header">
                                        <span>@match.RoundName</span>

                                        @if (match.HasResult && match.Result != null)
                                        {
                                            <strong>@match.Result.DisplayScore</strong>
                                        }
                                        else if (match.IsReadyToPlay)
                                        {
                                            <strong>Pendiente</strong>
                                        }
                                        else
                                        {
                                            <strong>Esperando</strong>
                                        }
                                    </div>

                                    <div class="@GetKnockoutTeamClass(match, match.PairOne)">
                                        <span>@GetPairName(match.PairOne)</span>
                                        <small>1</small>
                                    </div>

                                    <div class="@GetKnockoutTeamClass(match, match.PairTwo)">
                                        <span>@GetPairName(match.PairTwo)</span>
                                        <small>2</small>
                                    </div>

                                    <div class="knockout-quick-actions">
                                        @if (match.HasResult && match.Result != null)
                                        {
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => StartEditResult(match)">
                                                Editar resultado
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => ClearResult(match.Id)">
                                                Limpiar
                                            </button>
                                        }
                                        else if (match.IsReadyToPlay)
                                        {
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => StartRegisterResult(match)">
                                                Cargar resultado
                                            </button>
                                        }
                                    </div>
                                </article>
                            }
                        </div>
                    </section>
                }

                <section class="knockout-round knockout-champion-round">
                    <div class="knockout-round-header">
                        <div>
                            <h3>Campeones</h3>
                            <span>@GetCategoryLabel(Category)</span>
                        </div>
                    </div>

                    <div class="knockout-champion-card">
                        <div class="knockout-trophy-mark">Copa</div>

                        @if (GetChampion() != null)
                        {
                            <div class="knockout-champion-label">Ganadores</div>
                            <strong>@GetPairName(GetChampion())</strong>
                        }
                        else
                        {
                            <div class="knockout-champion-label">Final pendiente</div>
                            <strong>Esperando campeones</strong>
                        }
                    </div>
                </section>
            </div>
        </div>

        @if (SelectedMatch != null)
        {
            var selectedMatch = SelectedMatch;
            var selectedInput = GetMatchInput(selectedMatch.Id);

            <div class="result-modal-backdrop" role="presentation" @onclick="CancelEditResult">
                <div class="result-modal" role="dialog" aria-modal="true" aria-labelledby="knockout-result-modal-title" @onclick:stopPropagation="true">
                    <div class="result-modal-header">
                        <div>
                            <div class="panel-kicker">Resultado de llave</div>
                            <h3 id="knockout-result-modal-title">
                                @(selectedMatch.HasResult ? "Editar resultado" : "Cargar resultado")
                            </h3>
                        </div>

                        <button class="result-modal-close"
                                type="button"
                                aria-label="Cerrar"
                                @onclick="CancelEditResult">
                            ×
                        </button>
                    </div>

                    <div class="result-match-summary">
                        <strong>@GetPairName(selectedMatch.PairOne)</strong>
                        <span>vs</span>
                        <strong>@GetPairName(selectedMatch.PairTwo)</strong>
                    </div>

                    <div class="result-round-note">
                        @selectedMatch.RoundName
                    </div>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="alert alert-danger mb-0">
                            @errorMessage
                        </div>
                    }

                    <div class="result-score-panel">
                        <div class="result-score-row">
                            <div>
                                <span>Set 1</span>
                                <small>Primer set del partido</small>
                            </div>

                            <div class="score-pair-inputs">
                                <input type="number"
                                       min="0"
                                       max="7"
                                       class="form-control score-input"
                                       @bind="selectedInput.SetOnePairOne" />
                                <span>-</span>
                                <input type="number"
                                       min="0"
                                       max="7"
                                       class="form-control score-input"
                                       @bind="selectedInput.SetOnePairTwo" />
                            </div>
                        </div>

                        <div class="result-score-row">
                            <div>
                                <span>Set 2</span>
                                <small>Segundo set del partido</small>
                            </div>

                            <div class="score-pair-inputs">
                                <input type="number"
                                       min="0"
                                       max="7"
                                       class="form-control score-input"
                                       @bind="selectedInput.SetTwoPairOne" />
                                <span>-</span>
                                <input type="number"
                                       min="0"
                                       max="7"
                                       class="form-control score-input"
                                       @bind="selectedInput.SetTwoPairTwo" />
                            </div>
                        </div>

                        <div class="result-score-row result-score-row-stb">
                            <div>
                                <span>Super tie-break</span>
                                <small>Se habilita cuando cada pareja gana un set.</small>
                            </div>

                            @if (FirstTwoSetsAreSplit(selectedInput))
                            {
                                <div class="result-stb-controls">
                                    <label class="result-toggle">
                                        <input type="checkbox"
                                               @bind="selectedInput.UseSuperTieBreak" />
                                        <span>Usar STB</span>
                                    </label>

                                    @if (selectedInput.UseSuperTieBreak)
                                    {
                                        <div class="score-pair-inputs">
                                            <input type="number"
                                                   min="0"
                                                   class="form-control score-input"
                                                   @bind="selectedInput.SuperTieBreakPairOne" />
                                            <span>-</span>
                                            <input type="number"
                                                   min="0"
                                                   class="form-control score-input"
                                                   @bind="selectedInput.SuperTieBreakPairTwo" />
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <span class="result-not-applicable">
                                    No aplica por ahora
                                </span>
                            }
                        </div>
                    </div>

                    <div class="result-modal-actions">
                        <button class="btn btn-outline-secondary"
                                type="button"
                                @onclick="CancelEditResult">
                            Cancelar
                        </button>

                        <button class="btn btn-primary"
                                type="button"
                                @onclick="() => RegisterResult(selectedMatch.Id)">
                            Guardar resultado
                        </button>
                    </div>
                </div>
            </div>
        }
    }
}

@code {
    [Parameter]
    public Guid TournamentId { get; set; }

    [Parameter]
    public int Category { get; set; }

    private Tournament? tournament;
    private KnockoutBracket? bracket;
    private string? errorMessage;
    private string? successMessage;
    private bool showDeleteConfirmation;
    private Guid? editingMatchId;

    private Dictionary<Guid, MatchInput> matchInputs = new();

    private Organizer? CurrentOrganizer => OrganizerAccountService.CurrentOrganizer;

    private bool CanManageTournament =>
        tournament != null &&
        CurrentOrganizer != null &&
        tournament.OrganizerId == CurrentOrganizer.Id;

    private KnockoutMatch? SelectedMatch =>
        bracket?.Matches.FirstOrDefault(match => match.Id == editingMatchId);

    protected override void OnInitialized()
    {
        tournament = TournamentService.GetTournamentById(TournamentId);

        if (tournament == null)
            return;

        bracket = KnockoutService.GetBracket(tournament.Id, Category);

        InitializeMatchInputs();
    }

    private bool EnsureCanManageTournament()
    {
        if (tournament == null)
            return false;

        if (CurrentOrganizer == null)
        {
            errorMessage = "Tenés que iniciar sesión como organizador.";
            return false;
        }

        if (tournament.OrganizerId != CurrentOrganizer.Id)
        {
            errorMessage = "Solo podés administrar torneos asociados a tu cuenta.";
            return false;
        }

        return true;
    }

    private void GenerateBracket()
    {
        if (!EnsureCanManageTournament() || tournament == null)
            return;

        errorMessage = null;
        successMessage = null;
        showDeleteConfirmation = false;
        editingMatchId = null;

        try
        {
            bracket = KnockoutService.GenerateBracket(tournament, Category);
            matchInputs = new Dictionary<Guid, MatchInput>();
            InitializeMatchInputs();

            successMessage = "Llave generada correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void DeleteBracket()
    {
        if (!EnsureCanManageTournament() || tournament == null)
            return;

        errorMessage = null;
        successMessage = null;
        editingMatchId = null;

        try
        {
            KnockoutService.DeleteBracket(tournament.Id, Category);

            bracket = null;
            matchInputs = new Dictionary<Guid, MatchInput>();
            showDeleteConfirmation = false;

            successMessage = "Llave eliminada correctamente. Ahora podés corregir los grupos y generar una nueva.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void ToggleDeleteConfirmation()
    {
        if (!EnsureCanManageTournament())
            return;

        showDeleteConfirmation = !showDeleteConfirmation;
        errorMessage = null;
        successMessage = null;
        editingMatchId = null;
    }

    private void CancelDeleteConfirmation()
    {
        showDeleteConfirmation = false;
    }

    private bool BracketHasResults()
    {
        if (tournament == null)
            return false;

        return KnockoutService.BracketHasResults(tournament.Id, Category);
    }

    private void RegisterResult(Guid matchId)
    {
        if (!EnsureCanManageTournament() || tournament == null || bracket == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            var input = GetMatchInput(matchId);

            var sets = new List<MatchSet>
            {
                new MatchSet(input.SetOnePairOne, input.SetOnePairTwo),
                new MatchSet(input.SetTwoPairOne, input.SetTwoPairTwo)
            };

            if (ShouldUseSuperTieBreak(input))
            {
                sets.Add(new MatchSet(
                    input.SuperTieBreakPairOne,
                    input.SuperTieBreakPairTwo,
                    true
                ));
            }

            KnockoutService.RegisterMatchResult(
                tournament.Id,
                Category,
                matchId,
                sets
            );

            bracket = KnockoutService.GetBracket(tournament.Id, Category);

            InitializeMatchInputs();
            ResetInputsForMatchesWithoutResults();

            editingMatchId = null;

            successMessage = "Resultado guardado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void StartEditResult(KnockoutMatch match)
    {
        if (!EnsureCanManageTournament())
            return;

        if (match.Result == null)
            return;

        var input = GetMatchInput(match.Id);

        input.SetOnePairOne = match.Result.Sets[0].PairOneScore;
        input.SetOnePairTwo = match.Result.Sets[0].PairTwoScore;

        input.SetTwoPairOne = match.Result.Sets[1].PairOneScore;
        input.SetTwoPairTwo = match.Result.Sets[1].PairTwoScore;

        if (match.Result.Sets.Count > 2)
        {
            input.UseSuperTieBreak = true;
            input.SuperTieBreakPairOne = match.Result.Sets[2].PairOneScore;
            input.SuperTieBreakPairTwo = match.Result.Sets[2].PairTwoScore;
        }
        else
        {
            input.UseSuperTieBreak = false;
            input.SuperTieBreakPairOne = 0;
            input.SuperTieBreakPairTwo = 0;
        }

        editingMatchId = match.Id;
        errorMessage = null;
        successMessage = null;
        showDeleteConfirmation = false;
    }

    private void StartRegisterResult(KnockoutMatch match)
    {
        if (!EnsureCanManageTournament())
            return;

        if (!match.IsReadyToPlay)
            return;

        if (!match.HasResult)
        {
            ResetInput(match.Id);
        }

        editingMatchId = match.Id;
        errorMessage = null;
        successMessage = null;
        showDeleteConfirmation = false;
    }

    private void CancelEditResult()
    {
        editingMatchId = null;
        errorMessage = null;
        successMessage = null;
    }

    private void ClearResult(Guid matchId)
    {
        if (!EnsureCanManageTournament() || tournament == null || bracket == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            KnockoutService.ClearMatchResult(
                tournament.Id,
                Category,
                matchId
            );

            bracket = KnockoutService.GetBracket(tournament.Id, Category);

            InitializeMatchInputs();

            ResetInput(matchId);
            ResetInputsForMatchesWithoutResults();

            editingMatchId = null;

            successMessage = "Resultado eliminado correctamente. Las rondas posteriores afectadas fueron limpiadas.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private bool ShouldUseSuperTieBreak(MatchInput input)
    {
        if (!input.UseSuperTieBreak)
            return false;

        return FirstTwoSetsAreSplit(input);
    }

    private bool FirstTwoSetsAreSplit(MatchInput input)
    {
        var pairOneWonSetOne = input.SetOnePairOne > input.SetOnePairTwo;
        var pairTwoWonSetOne = input.SetOnePairTwo > input.SetOnePairOne;

        var pairOneWonSetTwo = input.SetTwoPairOne > input.SetTwoPairTwo;
        var pairTwoWonSetTwo = input.SetTwoPairTwo > input.SetTwoPairOne;

        return (pairOneWonSetOne && pairTwoWonSetTwo) ||
               (pairTwoWonSetOne && pairOneWonSetTwo);
    }

    private void InitializeMatchInputs()
    {
        if (bracket == null)
            return;

        foreach (var match in bracket.Matches)
        {
            if (!matchInputs.ContainsKey(match.Id))
            {
                matchInputs[match.Id] = new MatchInput();
            }
        }
    }

    private void ResetInput(Guid matchId)
    {
        matchInputs[matchId] = new MatchInput();
    }

    private void ResetInputsForMatchesWithoutResults()
    {
        if (bracket == null)
            return;

        foreach (var match in bracket.Matches.Where(match => !match.HasResult))
        {
            matchInputs[match.Id] = new MatchInput();
        }
    }

    private MatchInput GetMatchInput(Guid matchId)
    {
        if (!matchInputs.ContainsKey(matchId))
        {
            matchInputs[matchId] = new MatchInput();
        }

        return matchInputs[matchId];
    }

    private int GetCategoryGroupCount()
    {
        if (tournament == null)
            return 0;

        return tournament.Groups.Count(group => group.Category == Category);
    }

    private int GetKnockoutMatchCount()
    {
        return bracket?.Matches.Count ?? 0;
    }

    private int GetCompletedKnockoutMatchCount()
    {
        return bracket?.Matches.Count(match => match.HasResult) ?? 0;
    }

    private int GetReadyKnockoutMatchCount()
    {
        return bracket?.Matches.Count(match => match.IsReadyToPlay && !match.HasResult) ?? 0;
    }

    private List<RoundViewModel> GetRounds()
    {
        if (bracket == null)
            return new List<RoundViewModel>();

        return bracket.Matches
            .GroupBy(match => GetRoundGroupName(match.RoundName))
            .OrderBy(group => GetRoundOrder(group.Key))
            .Select(group => new RoundViewModel(
                group.Key,
                group.ToList()
            ))
            .ToList();
    }

    private string GetRoundGroupName(string roundName)
    {
        if (roundName.StartsWith("Octavo de final"))
            return "Octavos de final";

        if (roundName.StartsWith("Cuarto de final"))
            return "Cuartos de final";

        if (roundName.StartsWith("Semifinal"))
            return "Semifinales";

        if (roundName.StartsWith("Final"))
            return "Final";

        return roundName;
    }

    private int GetRoundOrder(string roundName)
    {
        return roundName switch
        {
            "Octavos de final" => 1,
            "Cuartos de final" => 2,
            "Semifinales" => 3,
            "Final" => 4,
            _ => 99
        };
    }

    private static int GetBracketRows(List<RoundViewModel> rounds)
    {
        int firstRoundMatchCount = rounds.FirstOrDefault()?.Matches.Count ?? 1;

        return Math.Max(2, firstRoundMatchCount * 2);
    }

    private static string GetMatchStyle(int roundIndex, int matchIndex)
    {
        const int rowHeightPixels = 112;
        int rowSpan = 1 << (roundIndex + 1);
        int rowStart = (matchIndex * rowSpan) + 1;
        int connectorHeight = Math.Max(rowHeightPixels, (rowSpan / 2) * rowHeightPixels);

        return $"--match-row-start: {rowStart}; --match-row-span: {rowSpan}; --connector-height: {connectorHeight}px";
    }

    private string GetKnockoutMatchClass(KnockoutMatch match)
    {
        string statusClass = match.HasResult
            ? "is-complete"
            : match.IsReadyToPlay
                ? "is-ready"
                : "is-waiting";

        return $"knockout-match-card {statusClass}";
    }

    private string GetKnockoutTeamClass(KnockoutMatch match, Pair? pair)
    {
        string winnerClass = match.Winner != null &&
            pair != null &&
            match.Winner.Id == pair.Id
                ? " is-winner"
                : string.Empty;

        return $"knockout-team{winnerClass}";
    }

    private Pair? GetChampion()
    {
        if (bracket == null)
            return null;

        var final = bracket.Matches.FirstOrDefault(match =>
            match.RoundName.StartsWith("Final")
        );

        return final?.Winner;
    }

    private string GetPairName(Pair? pair)
    {
        return pair?.DisplayName ?? "Pendiente";
    }

    private string GetCategoryLabel(int category)
    {
        return category switch
        {
            1 => "1ra categoría",
            2 => "2da categoría",
            3 => "3ra categoría",
            4 => "4ta categoría",
            5 => "5ta categoría",
            6 => "6ta categoría",
            7 => "7ma categoría",
            8 => "8va categoría",
            _ => $"{category} categoría"
        };
    }

    private class RoundViewModel
    {
        public string Name { get; }
        public List<KnockoutMatch> Matches { get; }

        public RoundViewModel(string name, List<KnockoutMatch> matches)
        {
            Name = name;
            Matches = matches;
        }
    }

    private class MatchInput
    {
        public int SetOnePairOne { get; set; }
        public int SetOnePairTwo { get; set; }

        public int SetTwoPairOne { get; set; }
        public int SetTwoPairTwo { get; set; }

        public bool UseSuperTieBreak { get; set; }

        public int SuperTieBreakPairOne { get; set; }
        public int SuperTieBreakPairTwo { get; set; }
    }
}
