@page "/tournaments/{TournamentId:guid}/categories/{Category:int}/knockout"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject KnockoutService KnockoutService
@rendermode InteractiveServer

<PageTitle>Llave eliminatoria</PageTitle>

@if (tournament == null)
{
    <div class="alert alert-danger">
        No se encontró el torneo.
    </div>

    <a class="btn btn-secondary" href="/tournaments">
        Volver a torneos
    </a>
}
else
{
    <div class="mb-3">
        <a class="btn btn-link px-0" href="@($"/tournaments/{tournament.Id}")">
            ← Volver al torneo
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">Llave eliminatoria</h1>

            <p class="text-muted mb-0">
                Torneo: <strong>@tournament.Name</strong>
            </p>

            <p class="text-muted mb-0">
                Categoría: <strong>@GetCategoryLabel(Category)</strong>
            </p>
        </div>

        <div class="text-end">
            <span class="badge bg-dark fs-6">
                @GetCategoryGroupCount() grupos
            </span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-warning">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    @if (bracket == null)
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="card-title">Generar llave</h4>

                <p class="text-muted">
                    La llave se genera con los clasificados de los grupos de esta categoría.
                    Por ahora clasifican 2 parejas por grupo.
                </p>

                <ul class="text-muted">
                    <li>2 grupos generan semifinales.</li>
                    <li>4 grupos generan cuartos de final.</li>
                    <li>8 grupos generan octavos de final.</li>
                </ul>

                <button class="btn btn-success" @onclick="GenerateBracket">
                    Generar llave
                </button>
            </div>
        </div>
    }
    else
    {
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div class="alert alert-success mb-0 flex-grow-1 me-3">
                Llave generada el @bracket.CreatedAt.ToString("dd/MM/yyyy HH:mm").
            </div>

            <button class="btn btn-outline-danger"
                    @onclick="ToggleDeleteConfirmation">
                Eliminar llave
            </button>
        </div>

        @if (showDeleteConfirmation)
        {
            <div class="alert alert-danger">
                <h5>¿Eliminar esta llave?</h5>

                @if (BracketHasResults())
                {
                    <p class="mb-2">
                        Esta llave ya tiene resultados cargados. Si la eliminás, también se pierden esos resultados y los avances de ronda.
                    </p>
                }
                else
                {
                    <p class="mb-2">
                        Esta llave no tiene resultados cargados todavía.
                    </p>
                }

                <p class="mb-3">
                    Después podrás generar una nueva llave con los clasificados actuales.
                </p>

                <button class="btn btn-danger me-2" @onclick="DeleteBracket">
                    Sí, eliminar llave
                </button>

                <button class="btn btn-secondary" @onclick="CancelDeleteConfirmation">
                    Cancelar
                </button>
            </div>
        }

        @foreach (var round in GetRounds())
        {
            <section class="mb-5">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h3 class="mb-0">@round.Name</h3>

                    <span class="badge bg-secondary">
                        @round.Matches.Count partidos
                    </span>
                </div>

                <div class="row">
                    @foreach (var match in round.Matches)
                    {
                        var input = GetMatchInput(match.Id);

                        <div class="col-md-6 col-lg-4 mb-4">
                            <div class="card h-100 shadow-sm">
                                <div class="card-header bg-dark text-white">
                                    <strong>@match.RoundName</strong>
                                </div>

                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span>
                                            <strong>@GetPairName(match.PairOne)</strong>
                                        </span>
                                        <span class="badge bg-secondary">Pareja 1</span>
                                    </div>

                                    <div class="text-center text-muted mb-3">
                                        vs
                                    </div>

                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <span>
                                            <strong>@GetPairName(match.PairTwo)</strong>
                                        </span>
                                        <span class="badge bg-secondary">Pareja 2</span>
                                    </div>

                                    @if (match.IsReadyToPlay && (!match.HasResult || editingMatchId == match.Id))
                                    {
                                        <hr />

                                        <h6 class="mb-3">
                                            @(match.HasResult ? "Editar resultado" : "Cargar resultado")
                                        </h6>

                                        <div class="mb-3">
                                            <label class="form-label">Set 1</label>
                                            <div class="d-flex gap-2 align-items-center">
                                                <input type="number"
                                                       min="0"
                                                       max="7"
                                                       class="form-control"
                                                       @bind="input.SetOnePairOne" />
                                                <span>-</span>
                                                <input type="number"
                                                       min="0"
                                                       max="7"
                                                       class="form-control"
                                                       @bind="input.SetOnePairTwo" />
                                            </div>
                                        </div>

                                        <div class="mb-3">
                                            <label class="form-label">Set 2</label>
                                            <div class="d-flex gap-2 align-items-center">
                                                <input type="number"
                                                       min="0"
                                                       max="7"
                                                       class="form-control"
                                                       @bind="input.SetTwoPairOne" />
                                                <span>-</span>
                                                <input type="number"
                                                       min="0"
                                                       max="7"
                                                       class="form-control"
                                                       @bind="input.SetTwoPairTwo" />
                                            </div>
                                        </div>

                                        @if (FirstTwoSetsAreSplit(input))
                                        {
                                            <div class="form-check mb-3">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       @bind="input.UseSuperTieBreak" />
                                                <label class="form-check-label">
                                                    Usar super tie-break
                                                </label>
                                            </div>

                                            @if (input.UseSuperTieBreak)
                                            {
                                                <div class="mb-3">
                                                    <label class="form-label">Super tie-break</label>
                                                    <div class="d-flex gap-2 align-items-center">
                                                        <input type="number"
                                                               min="0"
                                                               class="form-control"
                                                               @bind="input.SuperTieBreakPairOne" />
                                                        <span>-</span>
                                                        <input type="number"
                                                               min="0"
                                                               class="form-control"
                                                               @bind="input.SuperTieBreakPairTwo" />
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="mb-3">
                                                <span class="text-muted">
                                                    Super tie-break no necesario.
                                                </span>
                                            </div>
                                        }

                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => RegisterResult(match.Id)">
                                                Guardar resultado
                                            </button>

                                            @if (editingMatchId == match.Id)
                                            {
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        @onclick="CancelEditResult">
                                                    Cancelar
                                                </button>
                                            }
                                        </div>
                                    }
                                </div>

                                <div class="card-footer text-muted">
                                    @if (match.HasResult && match.Result != null)
                                    {
                                        <div>
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <span class="badge bg-success">
                                                    @match.Result.DisplayScore
                                                </span>

                                                <span>
                                                    Ganó: <strong>@GetPairName(match.Winner)</strong>
                                                </span>
                                            </div>

                                            @if (editingMatchId != match.Id)
                                            {
                                                <div class="d-flex gap-2">
                                                    <button class="btn btn-sm btn-outline-warning"
                                                            @onclick="() => StartEditResult(match)">
                                                        Editar
                                                    </button>

                                                    <button class="btn btn-sm btn-outline-danger"
                                                            @onclick="() => ClearResult(match.Id)">
                                                        Borrar
                                                    </button>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else if (match.IsReadyToPlay)
                                    {
                                        <span>Resultado pendiente</span>
                                    }
                                    else
                                    {
                                        <span>Esperando ganadores</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }

        @if (GetChampion() != null)
        {
            <div class="alert alert-primary">
                Campeones de @GetCategoryLabel(Category):
                <strong>@GetPairName(GetChampion())</strong>
            </div>
        }
    }
}

@code {
    [Parameter]
    public Guid TournamentId { get; set; }

    [Parameter]
    public int Category { get; set; }

    private Tournament? tournament;
    private KnockoutBracket? bracket;
    private string? errorMessage;
    private string? successMessage;
    private bool showDeleteConfirmation;
    private Guid? editingMatchId;

    private Dictionary<Guid, MatchInput> matchInputs = new();

    protected override void OnInitialized()
    {
        tournament = TournamentService.GetTournamentById(TournamentId);

        if (tournament == null)
            return;

        bracket = KnockoutService.GetBracket(tournament.Id, Category);

        InitializeMatchInputs();
    }

    private void GenerateBracket()
    {
        if (tournament == null)
            return;

        errorMessage = null;
        successMessage = null;
        showDeleteConfirmation = false;
        editingMatchId = null;

        try
        {
            bracket = KnockoutService.GenerateBracket(tournament, Category);
            matchInputs = new Dictionary<Guid, MatchInput>();
            InitializeMatchInputs();

            successMessage = "Llave generada correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void DeleteBracket()
    {
        if (tournament == null)
            return;

        errorMessage = null;
        successMessage = null;
        editingMatchId = null;

        try
        {
            KnockoutService.DeleteBracket(tournament.Id, Category);

            bracket = null;
            matchInputs = new Dictionary<Guid, MatchInput>();
            showDeleteConfirmation = false;

            successMessage = "Llave eliminada correctamente. Ahora podés corregir los grupos y generar una nueva.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void ToggleDeleteConfirmation()
    {
        showDeleteConfirmation = !showDeleteConfirmation;
        errorMessage = null;
        successMessage = null;
        editingMatchId = null;
    }

    private void CancelDeleteConfirmation()
    {
        showDeleteConfirmation = false;
    }

    private bool BracketHasResults()
    {
        if (tournament == null)
            return false;

        return KnockoutService.BracketHasResults(tournament.Id, Category);
    }

    private void RegisterResult(Guid matchId)
    {
        if (tournament == null || bracket == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            var input = GetMatchInput(matchId);

            var sets = new List<MatchSet>
            {
                new MatchSet(input.SetOnePairOne, input.SetOnePairTwo),
                new MatchSet(input.SetTwoPairOne, input.SetTwoPairTwo)
            };

            if (ShouldUseSuperTieBreak(input))
            {
                sets.Add(new MatchSet(
                    input.SuperTieBreakPairOne,
                    input.SuperTieBreakPairTwo,
                    true
                ));
            }

            KnockoutService.RegisterMatchResult(
                tournament.Id,
                Category,
                matchId,
                sets
            );

            bracket = KnockoutService.GetBracket(tournament.Id, Category);

            InitializeMatchInputs();
            ResetInputsForMatchesWithoutResults();

            editingMatchId = null;

            successMessage = "Resultado guardado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void StartEditResult(KnockoutMatch match)
    {
        if (match.Result == null)
            return;

        var input = GetMatchInput(match.Id);

        input.SetOnePairOne = match.Result.Sets[0].PairOneScore;
        input.SetOnePairTwo = match.Result.Sets[0].PairTwoScore;

        input.SetTwoPairOne = match.Result.Sets[1].PairOneScore;
        input.SetTwoPairTwo = match.Result.Sets[1].PairTwoScore;

        if (match.Result.Sets.Count > 2)
        {
            input.UseSuperTieBreak = true;
            input.SuperTieBreakPairOne = match.Result.Sets[2].PairOneScore;
            input.SuperTieBreakPairTwo = match.Result.Sets[2].PairTwoScore;
        }
        else
        {
            input.UseSuperTieBreak = false;
            input.SuperTieBreakPairOne = 0;
            input.SuperTieBreakPairTwo = 0;
        }

        editingMatchId = match.Id;
        errorMessage = null;
        successMessage = null;
        showDeleteConfirmation = false;
    }

    private void CancelEditResult()
    {
        editingMatchId = null;
        errorMessage = null;
        successMessage = null;
    }

    private void ClearResult(Guid matchId)
    {
        if (tournament == null || bracket == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            KnockoutService.ClearMatchResult(
                tournament.Id,
                Category,
                matchId
            );

            bracket = KnockoutService.GetBracket(tournament.Id, Category);

            InitializeMatchInputs();

            ResetInput(matchId);
            ResetInputsForMatchesWithoutResults();

            editingMatchId = null;

            successMessage = "Resultado eliminado correctamente. Las rondas posteriores afectadas fueron limpiadas.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private bool ShouldUseSuperTieBreak(MatchInput input)
    {
        if (!input.UseSuperTieBreak)
            return false;

        return FirstTwoSetsAreSplit(input);
    }

    private bool FirstTwoSetsAreSplit(MatchInput input)
    {
        var pairOneWonSetOne = input.SetOnePairOne > input.SetOnePairTwo;
        var pairTwoWonSetOne = input.SetOnePairTwo > input.SetOnePairOne;

        var pairOneWonSetTwo = input.SetTwoPairOne > input.SetTwoPairTwo;
        var pairTwoWonSetTwo = input.SetTwoPairTwo > input.SetTwoPairOne;

        return (pairOneWonSetOne && pairTwoWonSetTwo) ||
               (pairTwoWonSetOne && pairOneWonSetTwo);
    }

    private void InitializeMatchInputs()
    {
        if (bracket == null)
            return;

        foreach (var match in bracket.Matches)
        {
            if (!matchInputs.ContainsKey(match.Id))
            {
                matchInputs[match.Id] = new MatchInput();
            }
        }
    }

    private void ResetInput(Guid matchId)
    {
        matchInputs[matchId] = new MatchInput();
    }

    private void ResetInputsForMatchesWithoutResults()
    {
        if (bracket == null)
            return;

        foreach (var match in bracket.Matches.Where(match => !match.HasResult))
        {
            matchInputs[match.Id] = new MatchInput();
        }
    }

    private MatchInput GetMatchInput(Guid matchId)
    {
        if (!matchInputs.ContainsKey(matchId))
        {
            matchInputs[matchId] = new MatchInput();
        }

        return matchInputs[matchId];
    }

    private int GetCategoryGroupCount()
    {
        if (tournament == null)
            return 0;

        return tournament.Groups.Count(group => group.Category == Category);
    }

    private List<RoundViewModel> GetRounds()
    {
        if (bracket == null)
            return new List<RoundViewModel>();

        return bracket.Matches
            .GroupBy(match => GetRoundGroupName(match.RoundName))
            .OrderBy(group => GetRoundOrder(group.Key))
            .Select(group => new RoundViewModel(
                group.Key,
                group.ToList()
            ))
            .ToList();
    }

    private string GetRoundGroupName(string roundName)
    {
        if (roundName.StartsWith("Octavo de final"))
            return "Octavos de final";

        if (roundName.StartsWith("Cuarto de final"))
            return "Cuartos de final";

        if (roundName.StartsWith("Semifinal"))
            return "Semifinales";

        if (roundName.StartsWith("Final"))
            return "Final";

        return roundName;
    }

    private int GetRoundOrder(string roundName)
    {
        return roundName switch
        {
            "Octavos de final" => 1,
            "Cuartos de final" => 2,
            "Semifinales" => 3,
            "Final" => 4,
            _ => 99
        };
    }

    private Pair? GetChampion()
    {
        if (bracket == null)
            return null;

        var final = bracket.Matches.FirstOrDefault(match =>
            match.RoundName.StartsWith("Final")
        );

        return final?.Winner;
    }

    private string GetPairName(Pair? pair)
    {
        return pair?.DisplayName ?? "Pendiente";
    }

    private string GetCategoryLabel(int category)
    {
        return category switch
        {
            1 => "1ra categoría",
            2 => "2da categoría",
            3 => "3ra categoría",
            4 => "4ta categoría",
            5 => "5ta categoría",
            6 => "6ta categoría",
            7 => "7ma categoría",
            8 => "8va categoría",
            _ => $"{category} categoría"
        };
    }

    private class RoundViewModel
    {
        public string Name { get; }
        public List<KnockoutMatch> Matches { get; }

        public RoundViewModel(string name, List<KnockoutMatch> matches)
        {
            Name = name;
            Matches = matches;
        }
    }

    private class MatchInput
    {
        public int SetOnePairOne { get; set; }
        public int SetOnePairTwo { get; set; }

        public int SetTwoPairOne { get; set; }
        public int SetTwoPairTwo { get; set; }

        public bool UseSuperTieBreak { get; set; }

        public int SuperTieBreakPairOne { get; set; }
        public int SuperTieBreakPairTwo { get; set; }
    }
}