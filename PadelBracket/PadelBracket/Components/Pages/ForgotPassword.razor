@page "/forgot-password"
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService

<PageTitle>Recuperar contraseña</PageTitle>

<div class="page-header">
    <div class="page-eyebrow">Cuenta de jugador</div>
    <h1 class="page-title">Recuperar contraseña</h1>
    <p class="page-subtitle">
        Generá un código de recuperación y usalo para definir una nueva contraseña.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">
        @successMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(generatedResetCode))
{
    <div class="alert alert-warning">
        Código de recuperación: <strong>@generatedResetCode</strong>
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title mb-2">Solicitar código</h4>

        <p class="text-muted mb-4">
            Por ahora el código se muestra en pantalla. Más adelante se puede enviar por email.
        </p>

        <div class="mb-4">
            <label class="form-label">Email</label>
            <input class="form-control"
                   type="email"
                   placeholder="Ejemplo: juan@mail.com"
                   @bind="email"
                   @bind:event="oninput" />
        </div>

        <button class="btn btn-primary" @onclick="RequestResetCode">
            Generar código
        </button>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title mb-2">Cambiar contraseña</h4>

        <div class="mb-3">
            <label class="form-label">Código de recuperación</label>
            <input class="form-control"
                   placeholder="Código de 6 dígitos"
                   @bind="resetCode"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Nueva contraseña</label>
            <input class="form-control"
                   type="password"
                   placeholder="Mínimo 8 caracteres"
                   @bind="newPassword"
                   @bind:event="oninput" />
        </div>

        <div class="mb-4">
            <label class="form-label">Confirmar nueva contraseña</label>
            <input class="form-control"
                   type="password"
                   placeholder="Repetí tu nueva contraseña"
                   @bind="confirmNewPassword"
                   @bind:event="oninput" />
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary" @onclick="ResetPassword">
                Cambiar contraseña
            </button>

            <a class="btn btn-outline-primary" href="/login">
                Volver a ingresar
            </a>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string resetCode = string.Empty;
    private string generatedResetCode = string.Empty;
    private string newPassword = string.Empty;
    private string confirmNewPassword = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private void RequestResetCode()
    {
        ClearMessages();

        try
        {
            generatedResetCode = PlayerAccountService.RequestPasswordReset(email);
            resetCode = generatedResetCode;
            successMessage = "Código generado correctamente.";
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private void ResetPassword()
    {
        ClearMessages();

        try
        {
            PlayerAccountService.ResetPassword(
                email,
                resetCode,
                newPassword,
                confirmNewPassword);

            resetCode = string.Empty;
            generatedResetCode = string.Empty;
            newPassword = string.Empty;
            confirmNewPassword = string.Empty;
            successMessage = "Contraseña actualizada correctamente. Ya podés iniciar sesión.";
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}