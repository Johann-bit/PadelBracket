@page "/forgot-password"
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService

<PageTitle>Recuperar contraseña</PageTitle>

<div class="auth-shell forgot-auth-shell">
    <section class="auth-panel">
        <div class="auth-card forgot-auth-card">
            <div class="auth-card-header">
                <span class="auth-badge">Cuenta de jugador</span>
                <h1>Recuperar contraseña</h1>
                <p>
                    Generá un código de recuperación y usalo para definir una nueva contraseña.
                </p>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">
                    @errorMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="alert alert-success">
                    @successMessage
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(generatedResetCode))
            {
                <div class="forgot-code-card">
                    <span>Código de recuperación</span>
                    <strong>@generatedResetCode</strong>
                    <small>Copialo en el campo de abajo para cambiar tu contraseña.</small>
                </div>
            }

            <div class="forgot-step-card">
                <div class="forgot-step-header">
                    <span>01</span>
                    <div>
                        <h2>Solicitar código</h2>
                        <p>Usá el email de tu cuenta de jugador.</p>
                    </div>
                </div>

                <div class="auth-form">
                    <div class="form-field">
                        <span>Email</span>
                        <input class="form-control"
                               type="email"
                               placeholder="Ejemplo: juan@mail.com"
                               autocomplete="email"
                               @bind="email"
                               @bind:event="oninput" />
                    </div>

                    <button class="btn btn-primary auth-submit"
                            @onclick="RequestResetCode">
                        Generar código
                    </button>
                </div>
            </div>

            <div class="forgot-step-card">
                <div class="forgot-step-header">
                    <span>02</span>
                    <div>
                        <h2>Cambiar contraseña</h2>
                        <p>Ingresá el código y una contraseña nueva.</p>
                    </div>
                </div>

                <div class="auth-form forgot-reset-grid">
                    <div class="form-field span-2">
                        <span>Código de recuperación</span>
                        <input class="form-control"
                               placeholder="Código de 6 dígitos"
                               @bind="resetCode"
                               @bind:event="oninput" />
                    </div>

                    <div class="form-field">
                        <span>Nueva contraseña</span>
                        <input class="form-control"
                               type="password"
                               placeholder="Mínimo 8 caracteres"
                               autocomplete="new-password"
                               @bind="newPassword"
                               @bind:event="oninput" />
                    </div>

                    <div class="form-field">
                        <span>Confirmar nueva contraseña</span>
                        <input class="form-control"
                               type="password"
                               placeholder="Repetí tu nueva contraseña"
                               autocomplete="new-password"
                               @bind="confirmNewPassword"
                               @bind:event="oninput" />
                    </div>

                    <button class="btn btn-primary auth-submit span-2"
                            @onclick="ResetPassword">
                        Cambiar contraseña
                    </button>
                </div>
            </div>

            <div class="auth-footer">
                <span>¿Ya recuperaste el acceso?</span>
                <a href="/login">Volver a ingresar</a>
            </div>
        </div>
    </section>

    <aside class="auth-side-panel">
        <div class="auth-side-card forgot-side-card">
            <div class="auth-side-icon">PW</div>
            <h2>Recuperá tu acceso sin perder tu perfil.</h2>
            <p>
                Tu cuenta mantiene pareja, inscripciones e historial. Solo actualizamos la contraseña.
            </p>

            <div class="auth-feature-list">
                <div>
                    <span>01</span>
                    <strong>Código temporal</strong>
                    <small>En esta demo el código se muestra en pantalla para probar el flujo.</small>
                </div>

                <div>
                    <span>02</span>
                    <strong>Nueva clave</strong>
                    <small>Usá una contraseña fuerte y distinta a tus datos personales.</small>
                </div>

                <div>
                    <span>03</span>
                    <strong>Acceso normal</strong>
                    <small>Después volvés al login e ingresás con la contraseña nueva.</small>
                </div>
            </div>
        </div>
    </aside>
</div>

@code {
    private string email = string.Empty;
    private string resetCode = string.Empty;
    private string generatedResetCode = string.Empty;
    private string newPassword = string.Empty;
    private string confirmNewPassword = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private void RequestResetCode()
    {
        ClearMessages();

        try
        {
            generatedResetCode = PlayerAccountService.RequestPasswordReset(email);
            resetCode = generatedResetCode;
            successMessage = "Código generado correctamente.";
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private void ResetPassword()
    {
        ClearMessages();

        try
        {
            PlayerAccountService.ResetPassword(
                email,
                resetCode,
                newPassword,
                confirmNewPassword);

            resetCode = string.Empty;
            generatedResetCode = string.Empty;
            newPassword = string.Empty;
            confirmNewPassword = string.Empty;
            successMessage = "Contraseña actualizada correctamente. Ya podés iniciar sesión.";
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
