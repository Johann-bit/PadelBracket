@page "/tournaments/{TournamentId:guid}"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@rendermode InteractiveServer

<PageTitle>Detalle del torneo</PageTitle>

@if (tournament == null)
{
    <div class="alert alert-danger">
        No se encontró el torneo.
    </div>

    <a class="btn btn-secondary" href="/tournaments">
        Volver a torneos
    </a>
}
else
{
    <div class="mb-3">
        <a class="btn btn-link px-0" href="/tournaments">
            ← Volver a torneos
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">@tournament.Name</h1>

            <p class="text-muted mb-0">
                Creado el @tournament.CreatedAt.ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>

        <div class="text-end">
            <span class="badge bg-dark fs-6">
                @tournament.Groups.Count grupos
            </span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4 class="card-title">Crear grupo</h4>

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label class="form-label">Nombre del grupo</label>
                    <input class="form-control"
                           placeholder="Ejemplo: Grupo A"
                           @bind="newGroupName" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Categoría</label>
                    <select class="form-select" @bind="selectedCategory">
                        <option value="8">8va categoría</option>
                        <option value="7">7ma categoría</option>
                        <option value="6">6ta categoría</option>
                        <option value="5">5ta categoría</option>
                        <option value="4">4ta categoría</option>
                        <option value="3">3ra categoría</option>
                        <option value="2">2da categoría</option>
                        <option value="1">1ra categoría</option>
                    </select>
                </div>
            </div>

            <button class="btn btn-primary" @onclick="CreateGroup">
                Crear grupo
            </button>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Grupos por categoría</h3>

        <span class="badge bg-secondary">
            @tournament.Groups.Count total
        </span>
    </div>

    @if (!tournament.Groups.Any())
    {
        <div class="alert alert-info">
            Este torneo todavía no tiene grupos.
        </div>
    }
    else
    {
        @foreach (var categoryGroup in tournament.Groups
                            .GroupBy(g => g.Category)
                            .OrderByDescending(g => g.Key))
        {
            <section class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h4 class="mb-0">
                            @GetCategoryLabel(categoryGroup.Key)
                        </h4>

                        <small class="text-muted">
                            Grupos y participantes de esta categoría
                        </small>
                    </div>

                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-dark">
                            @categoryGroup.Count() grupos
                        </span>

                        <a class="btn btn-sm btn-outline-success"
                           href="@($"/tournaments/{tournament.Id}/categories/{categoryGroup.Key}/knockout")">
                            Ver llave
                        </a>
                    </div>
                </div>

                <div class="row">
                    @foreach (var group in categoryGroup.OrderBy(g => g.Name))
                    {
                        var isEditingGroup = editingGroupId == group.Id;
                        var isDeletingGroup = groupIdToDelete == group.Id;

                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                        @if (isEditingGroup)
                                        {
                                            <input class="form-control"
                                                   @bind="editGroupName" />
                                        }
                                        else
                                        {
                                            <h5 class="card-title mb-0">@group.Name</h5>
                                        }

                                        <span class="badge bg-primary">
                                            @group.CategoryLabel
                                        </span>
                                    </div>

                                    <p class="card-text mb-1">
                                        Parejas: <strong>@group.Pairs.Count</strong>
                                    </p>

                                    <p class="card-text mb-3">
                                        Partidos: <strong>@group.Matches.Count</strong>
                                    </p>

                                    @if (group.Pairs.Any())
                                    {
                                        <div class="mb-3">
                                            <small class="text-muted d-block mb-1">
                                                Participantes:
                                            </small>

                                            <ul class="list-unstyled mb-0">
                                                @foreach (var pair in group.Pairs.Take(4))
                                                {
                                                    <li>
                                                        <small>• @pair.DisplayName</small>
                                                    </li>
                                                }

                                                @if (group.Pairs.Count > 4)
                                                {
                                                    <li>
                                                        <small class="text-muted">
                                                            + @(group.Pairs.Count - 4) más
                                                        </small>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    @if (isEditingGroup)
                                    {
                                        <div class="d-flex gap-2 flex-wrap">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => SaveGroupEdit(group.Id)">
                                                Guardar
                                            </button>

                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="CancelGroupEdit">
                                                Cancelar
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a class="btn btn-sm btn-outline-primary"
                                               href="@($"/tournaments/{tournament.Id}/groups/{group.Id}")">
                                                Abrir grupo
                                            </a>

                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => StartGroupEdit(group)">
                                                Renombrar
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger"
                                                    disabled="@group.Matches.Any()"
                                                    @onclick="() => AskDeleteGroup(group.Id)">
                                                Eliminar
                                            </button>
                                        </div>

                                        @if (group.Matches.Any())
                                        {
                                            <small class="text-muted d-block mt-2">
                                                No se puede eliminar un grupo con partidos generados.
                                            </small>
                                        }
                                    }

                                    @if (isDeletingGroup)
                                    {
                                        <div class="alert alert-danger mt-3 mb-0">
                                            <strong>¿Eliminar este grupo?</strong>
                                            <div class="mt-2 d-flex gap-2">
                                                <button class="btn btn-sm btn-danger"
                                                        @onclick="() => DeleteGroup(group.Id)">
                                                    Confirmar
                                                </button>

                                                <button class="btn btn-sm btn-secondary"
                                                        @onclick="CancelDeleteGroup">
                                                    Cancelar
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    }
}

@code {
    [Parameter]
    public Guid TournamentId { get; set; }

    private Tournament? tournament;
    private string newGroupName = string.Empty;
    private int selectedCategory = 5;
    private string? errorMessage;
    private string? successMessage;

    private Guid? editingGroupId;
    private string editGroupName = string.Empty;

    private Guid? groupIdToDelete;

    protected override void OnInitialized()
    {
        LoadTournament();
    }

    private void LoadTournament()
    {
        tournament = TournamentService.GetTournamentById(TournamentId);
    }

    private void CreateGroup()
    {
        if (tournament == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.AddGroupToTournament(
                tournament.Id,
                newGroupName,
                selectedCategory
            );

            newGroupName = string.Empty;
            LoadTournament();

            successMessage = "Grupo creado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void StartGroupEdit(Group group)
    {
        editingGroupId = group.Id;
        editGroupName = group.Name;
        groupIdToDelete = null;

        errorMessage = null;
        successMessage = null;
    }

    private void CancelGroupEdit()
    {
        editingGroupId = null;
        editGroupName = string.Empty;

        errorMessage = null;
        successMessage = null;
    }

    private void SaveGroupEdit(Guid groupId)
    {
        if (tournament == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.RenameGroupInTournament(
                tournament.Id,
                groupId,
                editGroupName
            );

            editingGroupId = null;
            editGroupName = string.Empty;

            LoadTournament();

            successMessage = "Grupo renombrado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void AskDeleteGroup(Guid groupId)
    {
        editingGroupId = null;
        editGroupName = string.Empty;
        groupIdToDelete = groupId;

        errorMessage = null;
        successMessage = null;
    }

    private void CancelDeleteGroup()
    {
        groupIdToDelete = null;
    }

    private void DeleteGroup(Guid groupId)
    {
        if (tournament == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.DeleteGroupFromTournament(
                tournament.Id,
                groupId
            );

            groupIdToDelete = null;

            LoadTournament();

            successMessage = "Grupo eliminado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private string GetCategoryLabel(int category)
    {
        return category switch
        {
            1 => "1ra categoría",
            2 => "2da categoría",
            3 => "3ra categoría",
            4 => "4ta categoría",
            5 => "5ta categoría",
            6 => "6ta categoría",
            7 => "7ma categoría",
            8 => "8va categoría",
            _ => $"{category} categoría"
        };
    }
}