@page "/tournaments/{TournamentId:guid}"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@rendermode InteractiveServer

<PageTitle>Detalle del torneo</PageTitle>

@if (tournament == null)
{
    <div class="alert alert-danger">
        No se encontró el torneo.
    </div>

    <a class="btn btn-secondary" href="/tournaments">
        Volver a torneos
    </a>
}
else
{
    <div class="mb-3">
        <a class="btn btn-link px-0" href="/tournaments">
            ← Volver a torneos
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">@tournament.Name</h1>

            <p class="text-muted mb-0">
                Creado el @tournament.CreatedAt.ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>

        <div class="text-end">
            <span class="badge bg-dark fs-6">
                @tournament.Groups.Count grupos
            </span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4 class="card-title">Crear grupo</h4>

            <div class="mb-3">
                <label class="form-label">Nombre del grupo</label>
                <input class="form-control"
                       placeholder="Ejemplo: Grupo A"
                       @bind="newGroupName" />
            </div>

            <button class="btn btn-primary" @onclick="CreateGroup">
                Crear grupo
            </button>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Grupos</h3>

        <span class="badge bg-secondary">
            @tournament.Groups.Count total
        </span>
    </div>

    @if (!tournament.Groups.Any())
    {
        <div class="alert alert-info">
            Este torneo todavía no tiene grupos.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var group in tournament.Groups)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">@group.Name</h5>

                            <p class="card-text mb-1">
                                Parejas: <strong>@group.Pairs.Count</strong>
                            </p>

                            <p class="card-text">
                                Partidos: <strong>@group.Matches.Count</strong>
                            </p>

                            <a class="btn btn-sm btn-outline-primary"
                               href="@($"/tournaments/{tournament.Id}/groups/{group.Id}")">
                                Abrir grupo
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    [Parameter]
    public Guid TournamentId { get; set; }

    private Tournament? tournament;
    private string newGroupName = string.Empty;
    private string? errorMessage;

    protected override void OnInitialized()
    {
        tournament = TournamentService.GetTournamentById(TournamentId);
    }

    private void CreateGroup()
    {
        if (tournament == null)
            return;

        errorMessage = null;

        try
        {
            TournamentService.AddGroupToTournament(tournament.Id, newGroupName);
            newGroupName = string.Empty;
            tournament = TournamentService.GetTournamentById(TournamentId);
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}