            return;

        isEditingDetails = true;
        editClubName = tournament.ClubName;
        editCity = tournament.City;
        editAddress = tournament.Address;
        editStartDate = tournament.StartDate;

        errorMessage = null;
        successMessage = null;
    }

    private void CancelDetailsEdit()
    {
