@page "/tournaments/{TournamentId:guid}"
@using PadelBracket.Domain.Entities
@using PadelBracket.Domain.Enums
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject OrganizerAccountService OrganizerAccountService
@rendermode InteractiveServer

<PageTitle>Detalle del torneo</PageTitle>

@if (tournament == null)
{
    <div class="alert alert-danger">
        No se encontró el torneo.
    </div>

    <a class="btn btn-secondary" href="/tournaments">
        Volver a torneos
    </a>
}
else if (CurrentOrganizer == null)
{
    <div class="page-header">
        <div class="page-eyebrow">Panel de organizador</div>
        <h1 class="page-title">Acceso de organizador</h1>
        <p class="page-subtitle">
            Iniciá sesión como organizador para administrar este torneo.
        </p>
    </div>

    <div class="empty-state">
        <div class="empty-state-title">No hay una sesión de organizador activa.</div>
        <div class="mb-3">
            Entrá con tu cuenta de organizador para ver y editar torneos.
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" href="/organizer/login">
                Ingresar como organizador
            </a>

            <a class="btn btn-outline-primary" href="/tournaments">
                Volver a torneos
            </a>
        </div>
    </div>
}
else if (!CanManageTournament)
{
    <div class="page-header">
        <div class="page-eyebrow">Panel de organizador</div>
        <h1 class="page-title">Acceso denegado</h1>
        <p class="page-subtitle">
            Este torneo pertenece a otra cuenta de organizador.
        </p>
    </div>

    <div class="empty-state">
        <div class="empty-state-title">No podés administrar este torneo.</div>
        <div class="mb-3">
            Solo el organizador dueño puede editar datos, categorías, grupos y resultados.
        </div>

        <a class="btn btn-primary" href="/tournaments">
            Volver a mis torneos
        </a>
    </div>
}
else
{
    <div class="mb-3">
        <a class="btn btn-link px-0" href="/tournaments">
            ← Volver a torneos
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">@tournament.Name</h1>

            <p class="text-muted mb-0">
                @tournament.ClubName · @tournament.City · Inicio @tournament.StartDate.ToString("dd/MM/yyyy")
            </p>

            <p class="text-muted mb-0">
                @tournament.Address
            </p>

            <p class="text-muted mb-0">
                Creado el @tournament.CreatedAt.ToString("dd/MM/yyyy HH:mm")
            </p>
        </div>

        <div class="text-end">
            <span class="badge bg-dark fs-6">
                @tournament.Groups.Count grupos
            </span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h4 class="card-title mb-1">Datos del torneo</h4>
                    <p class="text-muted mb-0">
                        Club, ubicación y fecha de inicio del torneo.
                    </p>
                </div>

                @if (!isEditingDetails)
                {
                    <button class="btn btn-sm btn-outline-primary"
                            @onclick="StartDetailsEdit">
                        Editar datos
                    </button>
                }
            </div>

            @if (isEditingDetails)
            {
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Club</label>
                        <input class="form-control"
                               @bind="editClubName"
                               @bind:event="oninput" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Ciudad</label>
                        <input class="form-control"
                               @bind="editCity"
                               @bind:event="oninput" />
                    </div>

                    <div class="col-md-8">
                        <label class="form-label">Dirección</label>
                        <input class="form-control"
                               @bind="editAddress"
                               @bind:event="oninput" />
                    </div>

                    <div class="col-md-4">
                        <label class="form-label">Fecha de inicio</label>
                        <input class="form-control"
                               type="date"
                               @bind="editStartDate" />
                    </div>
                </div>

                <div class="d-flex gap-2 flex-wrap">
                    <button class="btn btn-primary"
                            @onclick="SaveDetailsEdit">
                        Guardar datos
                    </button>

                    <button class="btn btn-outline-secondary"
                            @onclick="CancelDetailsEdit">
                        Cancelar
                    </button>
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Club</div>
                            <div class="stat-value">@tournament.ClubName</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Ciudad</div>
                            <div class="stat-value">@tournament.City</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Fecha</div>
                            <div class="stat-value">@tournament.StartDate.ToString("dd/MM")</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Estado</div>
                            <div class="stat-value">@tournament.StatusLabel</div>
                        </div>
                    </div>

                    <div class="col-12">
                        <div class="empty-state">
                            <div class="empty-state-title">Dirección</div>
                            <div>@tournament.Address</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4 class="card-title mb-2">Categorías del torneo</h4>

            <p class="text-muted mb-4">
                Definí qué categorías pueden inscribirse, cupos disponibles y costo de inscripción.
            </p>

            <div class="row g-3 mb-4">
                <div class="col-md-3">
                    <label class="form-label">Categoría</label>
                    <select class="form-select" @bind="newCategory">
                        <option value="8">8va categoría</option>
                        <option value="7">7ma categoría</option>
                        <option value="6">6ta categoría</option>
                        <option value="5">5ta categoría</option>
                        <option value="4">4ta categoría</option>
                        <option value="3">3ra categoría</option>
                        <option value="2">2da categoría</option>
                        <option value="1">1ra categoría</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Cupos</label>
                    <input class="form-control"
                           type="number"
                           min="1"
                           @bind="newCategoryMaxPairs" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Inscripción</label>
                    <input class="form-control"
                           type="number"
                           min="0"
                           step="100"
                           @bind="newCategoryRegistrationFee" />
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary w-100"
                            @onclick="CreateCategory">
                        Agregar categoría
                    </button>
                </div>
            </div>

            @if (!tournament.TournamentCategories.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-title">Todavía no hay categorías.</div>
                    <div>
                        Agregá al menos una categoría para que el torneo aparezca en disponibles.
                    </div>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped align-middle">
                        <thead>
                            <tr>
                                <th>Categoría</th>
                                <th>Cupos</th>
                                <th>Inscripción</th>
                                <th>Inscriptos activos</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var category in tournament.TournamentCategories.OrderByDescending(category => category.Category))
                            {
                                var activeRegistrations = tournament.GetActiveRegistrationsByCategory(category.Category).Count;

                                <tr>
                                    <td>
                                        <span class="badge bg-primary">
                                            @GetCategoryLabel(category.Category)
                                        </span>
                                    </td>

                                    <td>@activeRegistrations / @category.MaxPairs</td>

                                    <td>$@category.RegistrationFee</td>

                                    <td>@activeRegistrations</td>

                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-danger"
                                                disabled="@HasActiveRegistrations(category.Category)"
                                                @onclick="() => AskDeleteCategory(category.Category)">
                                            Eliminar
                                        </button>
                                    </td>
                                </tr>

                                @if (categoryToDelete == category.Category)
                                {
                                    <tr>
                                        <td colspan="5">
                                            <div class="alert alert-danger mb-0">
                                                <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                                                    <div>
                                                        <strong>¿Eliminar esta categoría?</strong>
                                                        <div>
                                                            Solo se puede eliminar si no tiene inscripciones activas.
                                                        </div>
                                                    </div>

                                                    <div class="d-flex gap-2 flex-wrap">
                                                        <button class="btn btn-sm btn-danger"
                                                                @onclick="() => DeleteCategory(category.Category)">
                                                            Confirmar
                                                        </button>

                                                        <button class="btn btn-sm btn-secondary"
                                                                @onclick="CancelDeleteCategory">
                                                            Cancelar
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                <div>
                    <h4 class="card-title mb-1">Inscripciones</h4>
                    <p class="text-muted mb-0">
                        Revisá parejas anotadas, confirmá lugares, gestioná pagos y controlá qué falta asignar a grupos.
                    </p>
                </div>

                <span class="badge bg-dark">
                    @tournament.Registrations.Count total
                </span>
            </div>

            @if (tournament.Registrations.Any())
            {
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Pendientes</div>
                            <div class="stat-value">@PendingRegistrationsCount</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Confirmadas sin grupo</div>
                            <div class="stat-value">@ConfirmedUnassignedRegistrationsCount</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Asignadas a grupo</div>
                            <div class="stat-value">@AssignedRegistrationsCount</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Pagas</div>
                            <div class="stat-value">@PaidRegistrationsCount</div>
                        </div>
                    </div>
                </div>
            }

            @if (!tournament.Registrations.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-title">Todavía no hay inscripciones.</div>
                    <div>
                        Cuando una pareja se anote al torneo, va a aparecer en esta sección.
                    </div>
                </div>
            }
            else
            {
                var filteredRegistrations = FilteredRegistrations;

                <div class="border rounded p-3 mb-4">
                    <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-3">
                        <div>
                            <h5 class="mb-1">Filtros</h5>
                            <div class="text-muted">
                                Mostrando @filteredRegistrations.Count de @tournament.Registrations.Count inscripciones.
                            </div>
                        </div>

                        @if (HasRegistrationFilters)
                        {
                            <button class="btn btn-outline-secondary"
                                    @onclick="ClearRegistrationFilters">
                                Limpiar filtros
                            </button>
                        }
                    </div>

                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Buscar pareja</label>
                            <input class="form-control"
                                   placeholder="Nombre de jugador o pareja"
                                   @bind="registrationSearchTerm"
                                   @bind:event="oninput" />
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Categoría</label>
                            <select class="form-select" @bind="registrationCategoryFilter">
                                <option value="all">Todas</option>
                                @foreach (var category in tournament.TournamentCategories.OrderByDescending(category => category.Category))
                                {
                                    <option value="@category.Category">@GetCategoryLabel(category.Category)</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Estado</label>
                            <select class="form-select" @bind="registrationStatusFilter">
                                <option value="all">Todos</option>
                                @foreach (RegistrationStatus status in Enum.GetValues<RegistrationStatus>())
                                {
                                    <option value="@status">@GetRegistrationStatusLabel(status)</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Pago</label>
                            <select class="form-select" @bind="registrationPaymentFilter">
                                <option value="all">Todos</option>
                                @foreach (PaymentStatus status in Enum.GetValues<PaymentStatus>())
                                {
                                    <option value="@status">@GetPaymentStatusLabel(status)</option>
                                }
                            </select>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Grupo</label>
                            <select class="form-select" @bind="registrationGroupFilter">
                                <option value="all">Todos</option>
                                <option value="assigned">Con grupo</option>
                                <option value="unassigned">Sin grupo</option>
                                @foreach (var group in tournament.Groups
                                                               .OrderByDescending(group => group.Category)
                                                               .ThenBy(group => group.Name))
                                {
                                    <option value="@group.Id">@group.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>

                @if (!filteredRegistrations.Any())
                {
                    <div class="empty-state">
                        <div class="empty-state-title">No hay inscripciones con esos filtros.</div>
                        <div class="mb-3">
                            Probá cambiar la búsqueda, categoría, estado, pago o grupo.
                        </div>

                        <button class="btn btn-outline-primary"
                                @onclick="ClearRegistrationFilters">
                            Limpiar filtros
                        </button>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-striped align-middle">
                            <thead>
                                <tr>
                                    <th>Pareja</th>
                                    <th>Categoría</th>
                                    <th>Estado</th>
                                    <th>Pago</th>
                                    <th>Grupo</th>
                                    <th>Fecha</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var registration in filteredRegistrations)
                                {
                                    var assignedGroup = GetAssignedGroup(registration);

                                    <tr>
                                        <td>
                                            <strong>@registration.Pair.DisplayName</strong>
                                        </td>

                                        <td>
                                            <span class="badge bg-primary">
                                                @GetCategoryLabel(registration.Category)
                                            </span>
                                        </td>

                                        <td>
                                            <span class="@GetRegistrationStatusBadgeClass(registration.Status)">
                                                @GetRegistrationStatusLabel(registration.Status)
                                            </span>
                                        </td>

                                        <td>
                                            <span class="@GetPaymentStatusBadgeClass(registration.PaymentStatus)">
                                                @GetPaymentStatusLabel(registration.PaymentStatus)
                                            </span>
                                        </td>

                                        <td>
                                            @if (assignedGroup != null)
                                            {
                                                <a class="badge bg-success text-decoration-none"
                                                   href="@($"/tournaments/{tournament.Id}/groups/{assignedGroup.Id}")">
                                                    @assignedGroup.Name
                                                </a>
                                            }
                                            else if (registration.Status == RegistrationStatus.Confirmed)
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    Sin grupo
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-light text-dark">
                                                    No aplica
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            @registration.RegisteredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                        </td>

                                        <td class="text-end">
                                            <div class="d-flex gap-2 justify-content-end flex-wrap">
                                                @if (CanConfirmOrReject(registration))
                                                {
                                                    <button class="btn btn-sm btn-outline-success"
                                                            @onclick="() => ConfirmRegistration(registration.Id)">
                                                        Confirmar
                                                    </button>

                                                    <button class="btn btn-sm btn-outline-danger"
                                                            @onclick="() => RejectRegistration(registration.Id)">
                                                        Rechazar
                                                    </button>
                                                }

                                                @if (CanMarkAsPaid(registration))
                                                {
                                                    <button class="btn btn-sm btn-outline-primary"
                                                            @onclick="() => MarkRegistrationAsPaid(registration.Id)">
                                                        Marcar pago
                                                    </button>
                                                }

                                                @if (CanRefund(registration))
                                                {
                                                    <button class="btn btn-sm btn-outline-warning"
                                                            @onclick="() => RefundRegistration(registration.Id)">
                                                        Reembolsar
                                                    </button>
                                                }

                                                @if (CanCancelRegistration(registration))
                                                {
                                                    <button class="btn btn-sm btn-outline-secondary"
                                                            @onclick="() => CancelRegistration(registration.Id)">
                                                        Cancelar
                                                    </button>
                                                }

                                                @if (!CanConfirmOrReject(registration) &&
                                                     !CanMarkAsPaid(registration) &&
                                                     !CanRefund(registration) &&
                                                     !CanCancelRegistration(registration))
                                                {
                                                    <span class="text-muted small">
                                                        Sin acciones
                                                    </span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4 class="card-title">Crear grupo</h4>

            <div class="row">
                <div class="col-md-8 mb-3">
                    <label class="form-label">Nombre del grupo</label>
                    <input class="form-control"
                           placeholder="Ejemplo: Grupo A"
                           @bind="newGroupName" />
                </div>

                <div class="col-md-4 mb-3">
                    <label class="form-label">Categoría</label>
                    <select class="form-select" @bind="selectedCategory">
                        <option value="8">8va categoría</option>
                        <option value="7">7ma categoría</option>
                        <option value="6">6ta categoría</option>
                        <option value="5">5ta categoría</option>
                        <option value="4">4ta categoría</option>
                        <option value="3">3ra categoría</option>
                        <option value="2">2da categoría</option>
                        <option value="1">1ra categoría</option>
                    </select>
                </div>
            </div>

            <button class="btn btn-primary" @onclick="CreateGroup">
                Crear grupo
            </button>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="mb-0">Grupos por categoría</h3>

        <span class="badge bg-secondary">
            @tournament.Groups.Count total
        </span>
    </div>

    @if (!tournament.Groups.Any())
    {
        <div class="alert alert-info">
            Este torneo todavía no tiene grupos.
        </div>
    }
    else
    {
        @foreach (var categoryGroup in tournament.Groups
                                            .GroupBy(g => g.Category)
                                            .OrderByDescending(g => g.Key))
        {
            <section class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h4 class="mb-0">
                            @GetCategoryLabel(categoryGroup.Key)
                        </h4>

                        <small class="text-muted">
                            Grupos y participantes de esta categoría
                        </small>
                    </div>

                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-dark">
                            @categoryGroup.Count() grupos
                        </span>

                        <a class="btn btn-sm btn-outline-success"
                           href="@($"/tournaments/{tournament.Id}/categories/{categoryGroup.Key}/knockout")">
                            Ver llave
                        </a>
                    </div>
                </div>

                <div class="row">
                    @foreach (var group in categoryGroup.OrderBy(g => g.Name))
                    {
                        var isEditingGroup = editingGroupId == group.Id;
                        var isDeletingGroup = groupIdToDelete == group.Id;

                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100 shadow-sm">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                                        @if (isEditingGroup)
                                        {
                                            <input class="form-control"
                                                   @bind="editGroupName" />
                                        }
                                        else
                                        {
                                            <h5 class="card-title mb-0">@group.Name</h5>
                                        }

                                        <span class="badge bg-primary">
                                            @group.CategoryLabel
                                        </span>
                                    </div>

                                    <p class="card-text mb-1">
                                        Parejas: <strong>@group.Pairs.Count</strong>
                                    </p>

                                    <p class="card-text mb-3">
                                        Partidos: <strong>@group.Matches.Count</strong>
                                    </p>

                                    @if (group.Pairs.Any())
                                    {
                                        <div class="mb-3">
                                            <small class="text-muted d-block mb-1">
                                                Participantes:
                                            </small>

                                            <ul class="list-unstyled mb-0">
                                                @foreach (var pair in group.Pairs.Take(4))
                                                {
                                                    <li>
                                                        <small>• @pair.DisplayName</small>
                                                    </li>
                                                }

                                                @if (group.Pairs.Count > 4)
                                                {
                                                    <li>
                                                        <small class="text-muted">
                                                            + @(group.Pairs.Count - 4) más
                                                        </small>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    }

                                    @if (isEditingGroup)
                                    {
                                        <div class="d-flex gap-2 flex-wrap">
                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => SaveGroupEdit(group.Id)">
                                                Guardar
                                            </button>

                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="CancelGroupEdit">
                                                Cancelar
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a class="btn btn-sm btn-outline-primary"
                                               href="@($"/tournaments/{tournament.Id}/groups/{group.Id}")">
                                                Abrir grupo
                                            </a>

                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => StartGroupEdit(group)">
                                                Renombrar
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger"
                                                    disabled="@group.Matches.Any()"
                                                    @onclick="() => AskDeleteGroup(group.Id)">
                                                Eliminar
                                            </button>
                                        </div>

                                        @if (group.Matches.Any())
                                        {
                                            <small class="text-muted d-block mt-2">
                                                No se puede eliminar un grupo con partidos generados.
                                            </small>
                                        }
                                    }

                                    @if (isDeletingGroup)
                                    {
                                        <div class="alert alert-danger mt-3 mb-0">
                                            <strong>¿Eliminar este grupo?</strong>
                                            <div class="mt-2 d-flex gap-2">
                                                <button class="btn btn-sm btn-danger"
                                                        @onclick="() => DeleteGroup(group.Id)">
                                                    Confirmar
                                                </button>

                                                <button class="btn btn-sm btn-secondary"
                                                        @onclick="CancelDeleteGroup">
                                                    Cancelar
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </section>
        }
    }
}

