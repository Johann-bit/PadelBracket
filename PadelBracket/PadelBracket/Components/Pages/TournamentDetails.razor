    private string editClubName = string.Empty;
    private string editCity = string.Empty;
    private string editAddress = string.Empty;
    private DateTime editStartDate = DateTime.Today;

    private int newCategory = 6;
    private int newCategoryMaxPairs = 16;
    private decimal newCategoryRegistrationFee = 800;
    private int? categoryToDelete;

    private Guid? editingGroupId;
    private string editGroupName = string.Empty;

    private Guid? groupIdToDelete;
    private string registrationSearchTerm = string.Empty;
    private string registrationCategoryFilter = "all";
    private string registrationStatusFilter = "all";
    private string registrationPaymentFilter = "all";
    private string registrationGroupFilter = "all";

    private Organizer? CurrentOrganizer => OrganizerAccountService.CurrentOrganizer;

    private bool CanManageTournament =>
        tournament != null &&
        CurrentOrganizer != null &&
        tournament.OrganizerId == CurrentOrganizer.Id;

    private int PendingRegistrationsCount =>
        tournament?.Registrations.Count(registration =>
            registration.Status == RegistrationStatus.Pending) ?? 0;

    private int ConfirmedUnassignedRegistrationsCount =>
        tournament?.Registrations.Count(registration =>
            registration.Status == RegistrationStatus.Confirmed &&
            GetAssignedGroup(registration) == null) ?? 0;

    private int AssignedRegistrationsCount =>
        tournament?.Registrations.Count(registration =>
            GetAssignedGroup(registration) != null) ?? 0;

    private int PaidRegistrationsCount =>
        tournament?.Registrations.Count(registration =>
            registration.PaymentStatus == PaymentStatus.Paid) ?? 0;

    private List<TournamentRegistration> FilteredRegistrations =>
        tournament?.Registrations
            .Where(MatchesRegistrationFilters)
            .OrderByDescending(registration => registration.RegisteredAt)
            .ToList() ?? new List<TournamentRegistration>();

    private bool HasRegistrationFilters =>
        !string.IsNullOrWhiteSpace(registrationSearchTerm) ||
        registrationCategoryFilter != "all" ||
        registrationStatusFilter != "all" ||
        registrationPaymentFilter != "all" ||
        registrationGroupFilter != "all";

    protected override void OnInitialized()
    {
        LoadTournament();
    }

    private void LoadTournament()
    {
        tournament = TournamentService.GetTournamentById(TournamentId);
    }

    private bool MatchesRegistrationFilters(TournamentRegistration registration)
    {
        if (!string.IsNullOrWhiteSpace(registrationSearchTerm) &&
            !registration.Pair.DisplayName.Contains(
                registrationSearchTerm.Trim(),
                StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (registrationCategoryFilter != "all" &&
            int.TryParse(registrationCategoryFilter, out int selectedRegistrationCategory) &&
            registration.Category != selectedRegistrationCategory)
        {
            return false;
        }

        if (registrationStatusFilter != "all" &&
            Enum.TryParse(registrationStatusFilter, out RegistrationStatus selectedRegistrationStatus) &&
            registration.Status != selectedRegistrationStatus)
        {
            return false;
        }

        if (registrationPaymentFilter != "all" &&
            Enum.TryParse(registrationPaymentFilter, out PaymentStatus selectedPaymentStatus) &&
            registration.PaymentStatus != selectedPaymentStatus)
        {
            return false;
        }

        if (registrationGroupFilter != "all")
        {
            Group? assignedGroup = GetAssignedGroup(registration);

            if (registrationGroupFilter == "assigned")
                return assignedGroup != null;

            if (registrationGroupFilter == "unassigned")
                return assignedGroup == null;

            if (Guid.TryParse(registrationGroupFilter, out Guid selectedGroupId))
                return assignedGroup?.Id == selectedGroupId;
        }

        return true;
    }

    private void ClearRegistrationFilters()
    {
        registrationSearchTerm = string.Empty;
        registrationCategoryFilter = "all";
        registrationStatusFilter = "all";
        registrationPaymentFilter = "all";
        registrationGroupFilter = "all";
    }

    private bool EnsureCanManageTournament()
    {
        if (tournament == null)
            return false;

        if (CurrentOrganizer == null)
        {
            errorMessage = "Tenés que iniciar sesión como organizador.";
            return false;
        }

        if (tournament.OrganizerId != CurrentOrganizer.Id)
        {
            errorMessage = "Solo podés administrar torneos asociados a tu cuenta.";
            return false;
        }

        return true;
    }

