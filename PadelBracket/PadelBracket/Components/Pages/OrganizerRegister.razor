@page "/organizer/register"
@using PadelBracket.Services
@inject OrganizerAccountService OrganizerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Registro organizador</PageTitle>

<div class="auth-shell register-auth-shell">
    <section class="auth-panel">
        <div class="auth-card register-auth-card">
            <div class="auth-card-header">
                <span class="auth-badge">Cuenta de organizador</span>
                <h1>Organizar torneos</h1>
                <p>
                    Creá tu cuenta para cargar torneos, administrar categorías, controlar inscripciones y generar llaves.
                </p>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">
                    @errorMessage
                </div>
            }

            <div class="auth-form register-form">
                <div class="form-field">
                    <span>Nombre real</span>
                    <input class="form-control"
                           placeholder="Ejemplo: Juan Pérez"
                           autocomplete="name"
                           @bind="realName"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Email</span>
                    <input class="form-control"
                           type="email"
                           placeholder="Ejemplo: organizador@mail.com"
                           autocomplete="email"
                           @bind="email"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Club</span>
                    <input class="form-control"
                           placeholder="Ejemplo: Club Carrasco"
                           @bind="clubName"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Ciudad</span>
                    <input class="form-control"
                           placeholder="Ejemplo: Montevideo"
                           @bind="city"
                           @bind:event="oninput" />
                </div>

                <div class="form-field span-2">
                    <span>Teléfono</span>
                    <input class="form-control"
                           placeholder="Ejemplo: 099123456"
                           autocomplete="tel"
                           @bind="phone"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Contraseña</span>
                    <input class="form-control"
                           type="password"
                           placeholder="Mínimo 8 caracteres"
                           autocomplete="new-password"
                           @bind="password"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Confirmar contraseña</span>
                    <input class="form-control"
                           type="password"
                           placeholder="Repetí tu contraseña"
                           autocomplete="new-password"
                           @bind="confirmPassword"
                           @bind:event="oninput" />
                </div>

                <button class="btn btn-primary auth-submit span-2"
                        @onclick="RegisterOrganizer">
                    Crear cuenta de organizador
                </button>
            </div>

            <div class="auth-footer">
                <span>¿Ya tenés cuenta?</span>
                <a href="/organizer/login">Ingresar como organizador</a>
            </div>
        </div>
    </section>

    <aside class="auth-side-panel">
        <div class="auth-side-card register-side-card organizer-side-card">
            <div class="auth-side-icon">PB</div>
            <h2>Un panel pensado para correr torneos de verdad.</h2>
            <p>
                Tus datos identifican al responsable y al club detrás de cada torneo publicado.
            </p>

            <div class="register-requirement-list">
                <div>
                    <span>@GetRequirementStatus(HasRealName)</span>
                    <strong>Responsable real</strong>
                    <small>Nombre y apellido del organizador, sin números.</small>
                </div>

                <div>
                    <span>@GetRequirementStatus(HasValidEmail)</span>
                    <strong>Email válido</strong>
                    <small>Será la cuenta principal del panel de torneos.</small>
                </div>

                <div>
                    <span>@GetRequirementStatus(HasClubData)</span>
                    <strong>Club y ciudad</strong>
                    <small>Base para publicar ubicación y contexto del torneo.</small>
                </div>

                <div>
                    <span>@GetRequirementStatus(HasStrongPassword)</span>
                    <strong>Contraseña fuerte</strong>
                    <small>8 caracteres, mayúscula, minúscula, número y especial.</small>
                </div>

                <div>
                    <span>@GetRequirementStatus(PasswordsMatch)</span>
                    <strong>Confirmación</strong>
                    <small>Las dos contraseñas tienen que coincidir.</small>
                </div>
            </div>
        </div>
    </aside>
</div>

@code {
    private string realName = string.Empty;
    private string email = string.Empty;
    private string clubName = string.Empty;
    private string city = "Montevideo";
    private string phone = string.Empty;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMessage = string.Empty;

    private bool HasRealName => realName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Length >= 2;

    private bool HasValidEmail => email.Contains('@') && email.Contains('.');

    private bool HasClubData =>
        !string.IsNullOrWhiteSpace(clubName) &&
        !string.IsNullOrWhiteSpace(city);

    private bool HasStrongPassword =>
        password.Length >= 8 &&
        password.Any(char.IsUpper) &&
        password.Any(char.IsLower) &&
        password.Any(char.IsDigit) &&
        password.Any(character => !char.IsLetterOrDigit(character));

    private bool PasswordsMatch =>
        !string.IsNullOrWhiteSpace(password) &&
        password == confirmPassword;

    private void RegisterOrganizer()
    {
        errorMessage = string.Empty;

        try
        {
            OrganizerAccountService.Register(
                realName,
                email,
                password,
                confirmPassword,
                clubName,
                city,
                phone);

            NavigationManager.NavigateTo("/tournaments");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private static string GetRequirementStatus(bool isComplete)
    {
        return isComplete ? "OK" : "--";
    }
}
