@page "/organizer/register"
@using PadelBracket.Services
@inject OrganizerAccountService OrganizerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Registro organizador</PageTitle>

<div class="page-header">
    <div class="page-eyebrow">Cuenta de organizador</div>
    <h1 class="page-title">Registrarme como organizador</h1>
    <p class="page-subtitle">
        Creá tu cuenta para cargar torneos, administrar categorías e inscripciones.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title mb-2">Datos del organizador</h4>

        <p class="text-muted mb-4">
            Usá datos reales del responsable y del club donde se organizan los torneos.
        </p>

        <div class="mb-3">
            <label class="form-label">Nombre real</label>
            <input class="form-control"
                   placeholder="Ejemplo: Juan Pérez"
                   @bind="realName"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control"
                   type="email"
                   placeholder="Ejemplo: organizador@mail.com"
                   @bind="email"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Club</label>
            <input class="form-control"
                   placeholder="Ejemplo: Club Carrasco"
                   @bind="clubName"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Ciudad</label>
            <input class="form-control"
                   placeholder="Ejemplo: Montevideo"
                   @bind="city"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Teléfono</label>
            <input class="form-control"
                   placeholder="Ejemplo: 099123456"
                   @bind="phone"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input class="form-control"
                   type="password"
                   placeholder="Mínimo 8 caracteres"
                   @bind="password"
                   @bind:event="oninput" />
        </div>

        <div class="mb-4">
            <label class="form-label">Confirmar contraseña</label>
            <input class="form-control"
                   type="password"
                   placeholder="Repetí tu contraseña"
                   @bind="confirmPassword"
                   @bind:event="oninput" />
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary" @onclick="RegisterOrganizer">
                Crear cuenta
            </button>

            <a class="btn btn-outline-primary" href="/organizer/login">
                Ya tengo cuenta
            </a>
        </div>
    </div>
</div>

@code {
    private string realName = string.Empty;
    private string email = string.Empty;
    private string clubName = string.Empty;
    private string city = "Montevideo";
    private string phone = string.Empty;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private string errorMessage = string.Empty;

    private void RegisterOrganizer()
    {
        errorMessage = string.Empty;

        try
        {
            OrganizerAccountService.Register(
                realName,
                email,
                password,
                confirmPassword,
                clubName,
                city,
                phone);

            NavigationManager.NavigateTo("/tournaments");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }
}