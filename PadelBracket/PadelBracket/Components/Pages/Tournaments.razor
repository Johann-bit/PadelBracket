@page "/tournaments"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@rendermode InteractiveServer

<PageTitle>Torneos</PageTitle>

<div class="page-header">
    <div class="page-eyebrow">Panel de torneos</div>
    <h1 class="page-title">PadelBracket</h1>
    <p class="page-subtitle">
        Gestioná torneos de pádel, grupos, tablas de posiciones y llaves eliminatorias
        desde un panel simple y ordenado.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<div class="stat-grid">
    <div class="stat-card">
        <div class="stat-label">Torneos creados</div>
        <div class="stat-value">@tournaments.Count</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Estado</div>
        <div class="stat-value">Activo</div>
    </div>

    <div class="stat-card">
        <div class="stat-label">Modo</div>
        <div class="stat-value">Local</div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title mb-2">Crear torneo</h4>

        <p class="text-muted mb-4">
            Elegí un nombre claro para identificar el torneo dentro del panel.
        </p>

        <div class="mb-3">
            <label class="form-label">Nombre del torneo</label>
            <input class="form-control"
                   placeholder="Ejemplo: Torneo Apertura 2026"
                   @bind="newTournamentName" />
        </div>

        <button class="btn btn-primary" @onclick="CreateTournament">
            Crear torneo
        </button>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-1">Torneos creados</h3>
        <p class="text-muted mb-0">
            Abrí un torneo para cargar grupos, parejas y resultados.
        </p>
    </div>

    <span class="badge bg-secondary">
        @tournaments.Count total
    </span>
</div>

@if (!tournaments.Any())
{
    <div class="empty-state">
        <div class="empty-state-title">Todavía no hay torneos creados.</div>
        <div>
            Creá el primero y arrancá a cargar grupos por categoría.
        </div>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Nombre</th>
                    <th>Creado</th>
                    <th>Grupos</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tournament in tournaments)
                {
                    <tr>
                        <td>
                            <strong>@tournament.Name</strong>
                        </td>
                        <td>@tournament.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>
                            <span class="badge bg-secondary">
                                @tournament.Groups.Count grupos
                            </span>
                        </td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary"
                               href="@($"/tournaments/{tournament.Id}")">
                                Abrir
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private string newTournamentName = string.Empty;
    private string? errorMessage;
    private List<Tournament> tournaments = new();

    protected override void OnInitialized()
    {
        tournaments = TournamentService.GetAllTournaments();
    }

    private void CreateTournament()
    {
        errorMessage = null;

        try
        {
            TournamentService.CreateTournament(newTournamentName);
            newTournamentName = string.Empty;
            tournaments = TournamentService.GetAllTournaments();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}