@page "/tournaments"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@rendermode InteractiveServer

<PageTitle>Torneos</PageTitle>

<h1 class="mb-4">PadelBracket</h1>

<p class="text-muted">
    Gestioná torneos de pádel, grupos, tablas de posiciones y llaves eliminatorias.
</p>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <h4 class="card-title">Crear torneo</h4>

        <div class="mb-3">
            <label class="form-label">Nombre del torneo</label>
            <input class="form-control"
                   placeholder="Ejemplo: Torneo Apertura 2026"
                   @bind="newTournamentName" />
        </div>

        <button class="btn btn-primary" @onclick="CreateTournament">
            Crear torneo
        </button>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Torneos creados</h3>

    <span class="badge bg-secondary">
        @tournaments.Count total
    </span>
</div>

@if (!tournaments.Any())
{
    <div class="alert alert-info">
        Todavía no hay torneos creados.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Creado</th>
                    <th>Grupos</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tournament in tournaments)
                {
                    <tr>
                        <td>
                            <strong>@tournament.Name</strong>
                        </td>
                        <td>@tournament.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@tournament.Groups.Count</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary"
                               href="@($"/tournaments/{tournament.Id}")">
                                Abrir
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private string newTournamentName = string.Empty;
    private string? errorMessage;
    private List<Tournament> tournaments = new();

    protected override void OnInitialized()
    {
        tournaments = TournamentService.GetAllTournaments();
    }

    private void CreateTournament()
    {
        errorMessage = null;

        try
        {
            TournamentService.CreateTournament(newTournamentName);
            newTournamentName = string.Empty;
            tournaments = TournamentService.GetAllTournaments();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }
}