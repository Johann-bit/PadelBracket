@page "/tournaments"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject KnockoutService KnockoutService
@inject OrganizerAccountService OrganizerAccountService
@rendermode InteractiveServer

<PageTitle>Torneos</PageTitle>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">
        @successMessage
    </div>
}

@if (CurrentOrganizer == null)
{
    <section class="dashboard-hero">
        <div>
            <div class="page-eyebrow">Panel de organizador</div>
            <h1 class="page-title">Mis torneos</h1>
            <p class="page-subtitle">
                Gestioná tus torneos de pádel, categorías, grupos, inscripciones y resultados.
            </p>
        </div>
    </section>

    <div class="empty-state organizer-empty-state">
        <div class="empty-state-title">Iniciá sesión como organizador.</div>
        <p>Necesitás una cuenta de organizador para crear y administrar torneos.</p>

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" href="/organizer/login">
                Ingresar como organizador
            </a>

            <a class="btn btn-outline-primary" href="/organizer/register">
                Registrarme como organizador
            </a>
        </div>
    </div>
}
else
{
    <section class="dashboard-hero">
        <div>
            <div class="page-eyebrow">Panel de organizador</div>
            <h1 class="page-title">Mis torneos</h1>
            <p class="page-subtitle">
                Creá torneos, abrí categorías, armá grupos y seguí la llave desde un solo lugar.
            </p>
        </div>

        <a class="btn btn-primary dashboard-hero-action" href="#crear-torneo">
            <span>+</span>
            Crear torneo
        </a>
    </section>

    <section class="metric-grid tournament-metric-grid">
        <div class="metric-card">
            <div class="metric-icon">TR</div>
            <div>
                <div class="metric-label">Mis torneos</div>
                <div class="metric-value">@tournaments.Count</div>
                <div class="metric-trend">Organizados por tu cuenta</div>
            </div>
            <div class="metric-sparkline"></div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">GR</div>
            <div>
                <div class="metric-label">Grupos creados</div>
                <div class="metric-value">@tournaments.Sum(tournament => tournament.Groups.Count)</div>
                <div class="metric-trend">En tus torneos activos</div>
            </div>
            <div class="metric-sparkline"></div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">CL</div>
            <div>
                <div class="metric-label">Club base</div>
                <div class="metric-value metric-value-text">@CurrentOrganizer.ClubName</div>
                <div class="metric-trend">@CurrentOrganizer.City</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">FE</div>
            <div>
                <div class="metric-label">Próximo inicio</div>
                <div class="metric-value metric-value-text">
                    @(tournaments.Any()
                        ? tournaments.OrderBy(tournament => tournament.StartDate).First().StartDate.ToString("dd/MM")
                        : "Sin fecha")
                </div>
                <div class="metric-trend">Según tus torneos cargados</div>
            </div>
        </div>
    </section>

    <section class="tournament-workspace">
        <div id="crear-torneo" class="dashboard-panel tournament-create-panel">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Nuevo torneo</div>
                    <h2>Crear torneo</h2>
                    <p>El torneo queda asociado a tu cuenta de organizador.</p>
                </div>
            </div>

            <div class="tournament-form-grid">
                <label class="form-field span-2">
                    <span>Nombre del torneo</span>
                    <input class="form-control"
                           placeholder="Ejemplo: Torneo Apertura 2026"
                           @bind="newTournamentName"
                           @bind:event="oninput" />
                </label>

                <label class="form-field">
                    <span>Club</span>
                    <input class="form-control"
                           placeholder="Ejemplo: Club Carrasco"
                           @bind="newClubName"
                           @bind:event="oninput" />
                </label>

                <label class="form-field">
                    <span>Ciudad</span>
                    <input class="form-control"
                           placeholder="Ejemplo: Montevideo"
                           @bind="newCity"
                           @bind:event="oninput" />
                </label>

                <label class="form-field span-2">
                    <span>Dirección</span>
                    <input class="form-control"
                           placeholder="Ejemplo: Av. Italia 1234"
                           @bind="newAddress"
                           @bind:event="oninput" />
                </label>

                <label class="form-field">
                    <span>Fecha de inicio</span>
                    <input class="form-control"
                           type="date"
                           @bind="newStartDate" />
                </label>
            </div>

            <div class="panel-actions">
                <button class="btn btn-primary" @onclick="CreateTournament">
                    Crear torneo
                </button>
            </div>
        </div>

        <div class="dashboard-panel tournament-list-panel">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Gestión</div>
                    <h2>Torneos creados</h2>
                    <p>Abrí un torneo para cargar categorías, grupos, parejas y resultados.</p>
                </div>

                <span class="status-pill">@tournaments.Count total</span>
            </div>

            @if (!tournaments.Any())
            {
                <div class="empty-state">
                    <div class="empty-state-title">Todavía no tenés torneos creados.</div>
                    <div>Creá el primero y arrancá a cargar categorías.</div>
                </div>
            }
            else
            {
                <div class="table-responsive tournament-table-wrap">
                    <table class="table tournament-table align-middle">
                        <thead>
                            <tr>
                                <th>Torneo</th>
                                <th>Club</th>
                                <th>Ciudad</th>
                                <th>Inicio</th>
                                <th>Estado</th>
                                <th>Grupos</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tournament in tournaments)
                            {
                                var isEditing = editingTournamentId == tournament.Id;
                                var isDeleting = tournamentIdToDelete == tournament.Id;

                                <tr>
                                    <td>
                                        @if (isEditing)
                                        {
                                            <input class="form-control"
                                                   @bind="editTournamentName" />
                                        }
                                        else
                                        {
                                            <div class="tournament-name">@tournament.Name</div>
                                            <div class="tournament-meta">
                                                Creado @tournament.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                            </div>
                                            <div class="tournament-meta">@tournament.Address</div>
                                        }
                                    </td>

                                    <td>@tournament.ClubName</td>

                                    <td>@tournament.City</td>

                                    <td>
                                        <span class="date-chip">@tournament.StartDate.ToString("dd/MM")</span>
                                    </td>

                                    <td>
                                        <span class="badge bg-primary">
                                            @tournament.StatusLabel
                                        </span>
                                    </td>

                                    <td>
                                        <span class="badge bg-secondary">
                                            @tournament.Groups.Count grupos
                                        </span>
                                    </td>

                                    <td class="text-end tournament-actions">
                                        @if (isEditing)
                                        {
                                            <button class="btn btn-sm btn-primary"
                                                    @onclick="() => SaveTournamentEdit(tournament.Id)">
                                                Guardar
                                            </button>

                                            <button class="btn btn-sm btn-outline-secondary"
                                                    @onclick="CancelTournamentEdit">
                                                Cancelar
                                            </button>
                                        }
                                        else
                                        {
                                            <a class="btn btn-sm btn-primary"
                                               href="@($"/tournaments/{tournament.Id}")">
                                                Abrir
                                            </a>

                                            <button class="btn btn-sm btn-outline-primary"
                                                    @onclick="() => StartTournamentEdit(tournament)">
                                                Renombrar
                                            </button>

                                            <button class="btn btn-sm btn-outline-danger"
                                                    @onclick="() => AskDeleteTournament(tournament.Id)">
                                                Eliminar
                                            </button>
                                        }
                                    </td>
                                </tr>

                                @if (isDeleting)
                                {
                                    <tr>
                                        <td colspan="7">
                                            <div class="alert alert-danger mb-0">
                                                <div class="delete-confirmation">
                                                    <div>
                                                        <strong>¿Eliminar este torneo?</strong>
                                                        <div>Se eliminarán sus grupos, partidos y llaves eliminatorias asociadas.</div>
                                                    </div>

                                                    <div class="d-flex gap-2">
                                                        <button class="btn btn-sm btn-danger"
                                                                @onclick="() => DeleteTournament(tournament.Id)">
                                                            Confirmar
                                                        </button>

                                                        <button class="btn btn-sm btn-secondary"
                                                                @onclick="CancelDeleteTournament">
                                                            Cancelar
                                                        </button>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>
}

@code {
    private string newTournamentName = string.Empty;
    private string newClubName = string.Empty;
    private string newCity = "Montevideo";
    private string newAddress = string.Empty;
    private DateTime newStartDate = DateTime.Today;

    private string? errorMessage;
    private string? successMessage;
    private List<Tournament> tournaments = new();

    private Guid? editingTournamentId;
    private string editTournamentName = string.Empty;

    private Guid? tournamentIdToDelete;

    private Organizer? CurrentOrganizer => OrganizerAccountService.CurrentOrganizer;

    protected override void OnInitialized()
    {
        LoadTournaments();
        LoadOrganizerDefaults();
    }

    private void LoadTournaments()
    {
        if (CurrentOrganizer == null)
        {
            tournaments = new List<Tournament>();
            return;
        }

        tournaments = TournamentService.GetAllTournaments()
            .Where(tournament => tournament.OrganizerId == CurrentOrganizer.Id)
            .OrderByDescending(tournament => tournament.CreatedAt)
            .ToList();
    }

    private void LoadOrganizerDefaults()
    {
        if (CurrentOrganizer == null)
            return;

        if (string.IsNullOrWhiteSpace(newClubName))
            newClubName = CurrentOrganizer.ClubName;

        if (string.IsNullOrWhiteSpace(newCity))
            newCity = CurrentOrganizer.City;
    }

    private void CreateTournament()
    {
        errorMessage = null;
        successMessage = null;

        if (CurrentOrganizer == null)
        {
            errorMessage = "Tenés que iniciar sesión como organizador para crear torneos.";
            return;
        }

        try
        {
            TournamentService.CreateTournament(
                newTournamentName,
                newClubName,
                newCity,
                newAddress,
                newStartDate,
                CurrentOrganizer.Id);

            newTournamentName = string.Empty;
            newClubName = CurrentOrganizer.ClubName;
            newCity = CurrentOrganizer.City;
            newAddress = string.Empty;
            newStartDate = DateTime.Today;

            LoadTournaments();

            successMessage = "Torneo creado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void StartTournamentEdit(Tournament tournament)
    {
        if (!CanManageTournament(tournament))
        {
            errorMessage = "Solo podés editar torneos asociados a tu cuenta de organizador.";
            return;
        }

        editingTournamentId = tournament.Id;
        editTournamentName = tournament.Name;
        tournamentIdToDelete = null;

        errorMessage = null;
        successMessage = null;
    }

    private void CancelTournamentEdit()
    {
        editingTournamentId = null;
        editTournamentName = string.Empty;

        errorMessage = null;
        successMessage = null;
    }

    private void SaveTournamentEdit(Guid tournamentId)
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            Tournament tournament = GetManagedTournamentOrThrow(tournamentId);

            TournamentService.RenameTournament(tournament.Id, editTournamentName);

            editingTournamentId = null;
            editTournamentName = string.Empty;

            LoadTournaments();

            successMessage = "Torneo renombrado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void AskDeleteTournament(Guid tournamentId)
    {
        try
        {
            GetManagedTournamentOrThrow(tournamentId);

            tournamentIdToDelete = tournamentId;
            editingTournamentId = null;
            editTournamentName = string.Empty;

            errorMessage = null;
            successMessage = null;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void CancelDeleteTournament()
    {
        tournamentIdToDelete = null;
    }

    private void DeleteTournament(Guid tournamentId)
    {
        errorMessage = null;
        successMessage = null;

        try
        {
            Tournament tournament = GetManagedTournamentOrThrow(tournamentId);

            KnockoutService.DeleteBracketsByTournament(tournament.Id);
            TournamentService.DeleteTournament(tournament.Id);

            tournamentIdToDelete = null;

            LoadTournaments();

            successMessage = "Torneo eliminado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private Tournament GetManagedTournamentOrThrow(Guid tournamentId)
    {
        if (CurrentOrganizer == null)
            throw new InvalidOperationException("Tenés que iniciar sesión como organizador.");

        Tournament tournament = TournamentService.GetTournamentById(tournamentId)
            ?? throw new ArgumentException("Tournament not found.");

        if (tournament.OrganizerId != CurrentOrganizer.Id)
            throw new InvalidOperationException("Solo podés administrar torneos asociados a tu cuenta.");

        return tournament;
    }

    private bool CanManageTournament(Tournament tournament)
    {
        return CurrentOrganizer != null &&
            tournament.OrganizerId == CurrentOrganizer.Id;
    }
}
