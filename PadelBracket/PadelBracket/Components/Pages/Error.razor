@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<section class="error-page">
    <div class="error-card">
        <span class="error-icon">!</span>

        <div class="error-content">
            <div class="home-eyebrow">
                <span>PB</span>
                Algo no salió como esperábamos
            </div>

            <h1>No pudimos completar la acción.</h1>

            <p>
                Probá volver a la página anterior o entrar de nuevo al panel. Si vuelve a pasar,
                este código ayuda a encontrar el problema.
            </p>

            @if (ShowRequestId)
            {
                <div class="error-request">
                    <span>Código técnico</span>
                    <code>@RequestId</code>
                </div>
            }

            <div class="error-actions">
                <a class="btn btn-primary" href="/">
                    Volver al inicio
                </a>

                <a class="btn btn-outline-primary" href="/tournaments/available">
                    Ver torneos
                </a>
            </div>
        </div>
    </div>
</section>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
