@page "/profile"
@using PadelBracket.Domain.Entities
@using PadelBracket.Domain.Enums
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService
@inject PlayerService PlayerService
@inject RankingService RankingService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Mi perfil</PageTitle>

@if (CurrentPlayer == null)
{
    <section class="dashboard-hero player-page-hero">
        <div>
            <div class="page-eyebrow">Cuenta de jugador</div>
            <h1 class="page-title">Mi perfil</h1>
            <p class="page-subtitle">
                Iniciá sesión para ver y editar tu perfil de jugador.
            </p>
        </div>
    </section>

    <div class="empty-state">
        <div class="empty-state-title">No hay una sesión activa.</div>
        <div class="mb-3">
            Entrá con tu cuenta para acceder a tu perfil.
        </div>

        <a class="btn btn-primary" href="/login">
            Ingresar
        </a>
    </div>
}
else
{
    <section class="dashboard-hero player-page-hero">
        <div>
            <div class="page-eyebrow">Cuenta de jugador</div>
            <h1 class="page-title">Mi perfil</h1>
            <p class="page-subtitle">
                Revisá tus datos personales, deportivos y tu posición competitiva.
            </p>
        </div>

        <a class="btn btn-primary dashboard-hero-action" href="/ranking">
            Ver ranking
        </a>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <section class="metric-grid player-metric-grid">
        <div class="metric-card">
            <div class="metric-icon">JG</div>
            <div>
                <div class="metric-label">Jugador</div>
                <div class="metric-value metric-value-text">@CurrentPlayer.Name</div>
                <div class="metric-trend">@CurrentPlayer.Email</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">CT</div>
            <div>
                <div class="metric-label">Categoría</div>
                <div class="metric-value">@GetCategoryLabel(CurrentPlayer.Category)</div>
                <div class="metric-trend">Nivel declarado</div>
            </div>
            <div class="metric-sparkline"></div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">RK</div>
            <div>
                <div class="metric-label">Puntos base</div>
                <div class="metric-value">@CurrentPlayer.RankingPoints</div>
                <div class="metric-trend">Perfil competitivo</div>
            </div>
            <div class="metric-sparkline"></div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">PF</div>
            <div>
                <div class="metric-label">Estado</div>
                <div class="metric-value metric-value-text">@(CurrentPlayer.HasCompleteProfile ? "Completo" : "Incompleto")</div>
                <div class="metric-trend">@GetVerificationLabel(CurrentPlayer.VerificationStatus)</div>
            </div>
        </div>
    </section>

    <div class="card mb-4 profile-ranking-card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3 flex-wrap mb-3">
                <div>
                    <h4 class="card-title mb-2">Ranking actual</h4>

                    <p class="text-muted mb-0">
                        Tu posición se calcula con los resultados cargados en torneos de tu categoría.
                    </p>
                </div>

                <a class="btn btn-outline-primary" href="/ranking">
                    Ver ranking
                </a>
            </div>

            @if (rankingSummary == null || !CurrentPlayer.Category.HasValue)
            {
                <div class="empty-state">
                    <div class="empty-state-title">Ranking no disponible.</div>
                    <div>
                        Completá tus datos deportivos para aparecer en el ranking de tu categoría.
                    </div>
                </div>
            }
            else if (!rankingSummary.IsRanked || rankingSummary.Ranking == null)
            {
                <div class="empty-state">
                    <div class="empty-state-title">Todavía no tenés resultados rankeados.</div>
                    <div>
                        Cuando juegues partidos con resultados cargados, tu posición aparecerá acá.
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3">
                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Posición</div>
                            <div class="stat-value">#@rankingSummary.Position</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Puntos competitivos</div>
                            <div class="stat-value">@rankingSummary.Ranking.Points</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Partidos</div>
                            <div class="stat-value">@rankingSummary.Ranking.MatchesPlayed</div>
                        </div>
                    </div>

                    <div class="col-md-3">
                        <div class="stat-card">
                            <div class="stat-label">Win rate</div>
                            <div class="stat-value">@rankingSummary.Ranking.WinRate.ToString("0.0")%</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-label">Victorias</div>
                            <div class="stat-value">@rankingSummary.Ranking.Wins</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-label">Derrotas</div>
                            <div class="stat-value">@rankingSummary.Ranking.Losses</div>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <div class="stat-card">
                            <div class="stat-label">Diferencia de games</div>
                            <div class="stat-value">@FormatDifference(rankingSummary.Ranking.GameDifference)</div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <section class="profile-form-grid">
    <div class="card mb-4 profile-form-card">
        <div class="card-body">
            <h4 class="card-title mb-2">Datos personales</h4>

            <p class="text-muted mb-4">
                Usá tu nombre real para competir y figurar correctamente en rankings y torneos.
            </p>

            <div class="mb-3">
                <label class="form-label">Nombre real</label>
                <input class="form-control"
                       @bind="name"
                       @bind:event="oninput" />
            </div>

            <div class="mb-4">
                <label class="form-label">Email</label>
                <input class="form-control"
                       type="email"
                       @bind="email"
                       @bind:event="oninput" />
            </div>

            <button class="btn btn-primary" @onclick="SavePersonalData">
                Guardar datos personales
            </button>
        </div>
    </div>

    <div class="card mb-4 profile-form-card">
        <div class="card-body">
            <h4 class="card-title mb-2">Datos deportivos</h4>

            <p class="text-muted mb-4">
                Tu mano hábil, lado de juego y categoría ayudan a formar parejas y validar inscripciones.
            </p>

            <div class="mb-3">
                <label class="form-label">Mano hábil</label>
                <select class="form-select" @bind="dominantHand">
                    <option value="@DominantHand.Right">Derecha</option>
                    <option value="@DominantHand.Left">Zurda</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Lado de juego</label>
                <select class="form-select" @bind="preferredSide">
                    <option value="@PreferredSide.Drive">Drive</option>
                    <option value="@PreferredSide.Backhand">Revés</option>
                    <option value="@PreferredSide.Both">Ambos</option>
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label">Categoría</label>
                <select class="form-select" @bind="category">
                    @for (int categoryOption = 1; categoryOption <= 8; categoryOption++)
                    {
                        <option value="@categoryOption">@categoryOption</option>
                    }
                </select>
            </div>

            <button class="btn btn-primary" @onclick="SaveSportData">
                Guardar datos deportivos
            </button>
        </div>
    </div>

    <div class="card mb-4 profile-form-card">
        <div class="card-body">
            <h4 class="card-title mb-2">Seguridad</h4>

            <p class="text-muted mb-4">
                Cambiá tu contraseña usando tu contraseña actual.
            </p>

            <div class="mb-3">
                <label class="form-label">Contraseña actual</label>
                <input class="form-control"
                       type="password"
                       @bind="currentPassword"
                       @bind:event="oninput" />
            </div>

            <div class="mb-3">
                <label class="form-label">Nueva contraseña</label>
                <input class="form-control"
                       type="password"
                       @bind="newPassword"
                       @bind:event="oninput" />
            </div>

            <div class="mb-4">
                <label class="form-label">Confirmar nueva contraseña</label>
                <input class="form-control"
                       type="password"
                       @bind="confirmNewPassword"
                       @bind:event="oninput" />
            </div>

            <button class="btn btn-primary" @onclick="ChangePassword">
                Cambiar contraseña
            </button>
        </div>
    </div>

    <div class="card profile-status-card">
        <div class="card-body">
            <h4 class="card-title mb-2">Estado del perfil</h4>

            <div class="d-flex gap-2 flex-wrap">
                <span class="badge @GetVerificationBadgeClass(CurrentPlayer.VerificationStatus)">
                    @GetVerificationLabel(CurrentPlayer.VerificationStatus)
                </span>

                @if (CurrentPlayer.HasCompleteProfile)
                {
                    <span class="badge bg-success">Perfil completo</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Perfil incompleto</span>
                }
            </div>
        </div>
    </div>
    </section>
}

@code {
    private string name = string.Empty;
    private string email = string.Empty;
    private DominantHand dominantHand = DominantHand.Right;
    private PreferredSide preferredSide = PreferredSide.Drive;
    private int category = 6;
    private string currentPassword = string.Empty;
    private string newPassword = string.Empty;
    private string confirmNewPassword = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private PlayerRankingSummary? rankingSummary;

    private Player? CurrentPlayer => PlayerAccountService.CurrentPlayer;

    protected override void OnInitialized()
    {
        LoadProfile();
    }

    private void LoadProfile()
    {
        if (CurrentPlayer == null)
            return;

        name = CurrentPlayer.Name;
        email = CurrentPlayer.Email;
        dominantHand = CurrentPlayer.DominantHand ?? DominantHand.Right;
        preferredSide = CurrentPlayer.PreferredSide ?? PreferredSide.Drive;
        category = CurrentPlayer.Category ?? 6;

        LoadRankingSummary();
    }

    private void LoadRankingSummary()
    {
        if (CurrentPlayer == null || !CurrentPlayer.Category.HasValue)
        {
            rankingSummary = null;
            return;
        }

        rankingSummary = RankingService.GetPlayerRankingSummary(
            CurrentPlayer.Id,
            CurrentPlayer.Category.Value);
    }

    private void SavePersonalData()
    {
        ClearMessages();

        if (CurrentPlayer == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        try
        {
            PlayerAccountService.UpdateCurrentPlayerPersonalData(name, email);
            successMessage = "Datos personales actualizados correctamente.";
            LoadProfile();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private void SaveSportData()
    {
        ClearMessages();

        if (CurrentPlayer == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        try
        {
            PlayerService.UpdateSportData(
                CurrentPlayer.Id,
                dominantHand,
                preferredSide,
                category);

            successMessage = "Datos deportivos actualizados correctamente.";
            LoadProfile();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private void ChangePassword()
    {
        ClearMessages();

        if (CurrentPlayer == null)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        try
        {
            PlayerAccountService.ChangeCurrentPlayerPassword(
                currentPassword,
                newPassword,
                confirmNewPassword);

            currentPassword = string.Empty;
            newPassword = string.Empty;
            confirmNewPassword = string.Empty;
            successMessage = "Contraseña actualizada correctamente.";
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private static string GetCategoryLabel(int? playerCategory)
    {
        if (!playerCategory.HasValue)
            return "-";

        return playerCategory.Value.ToString();
    }

    private static string GetVerificationLabel(PlayerVerificationStatus status)
    {
        return status switch
        {
            PlayerVerificationStatus.Pending => "Verificación pendiente",
            PlayerVerificationStatus.Verified => "Verificado",
            PlayerVerificationStatus.Rejected => "Verificación rechazada",
            _ => status.ToString()
        };
    }

    private static string GetVerificationBadgeClass(PlayerVerificationStatus status)
    {
        return status switch
        {
            PlayerVerificationStatus.Verified => "bg-success",
            PlayerVerificationStatus.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }

    private static string FormatDifference(int difference)
    {
        return difference > 0 ? $"+{difference}" : difference.ToString();
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
