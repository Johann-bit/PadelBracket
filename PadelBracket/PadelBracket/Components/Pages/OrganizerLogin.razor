@page "/organizer/login"
@using PadelBracket.Services
@inject OrganizerAccountService OrganizerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Ingresar organizador</PageTitle>

<div class="auth-shell">
    <section class="auth-panel">
        <div class="auth-card">
            <div class="auth-card-header">
                <span class="auth-badge">Organizador</span>
                <h1>Ingresar</h1>
                <p>
                    Entrá a tu panel para crear torneos, revisar inscripciones, armar grupos y cargar resultados.
                </p>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">
                    @errorMessage
                </div>
            }

            <div class="auth-form">
                <div class="form-field">
                    <span>Email</span>
                    <input class="form-control"
                           type="email"
                           placeholder="Ejemplo: organizador@mail.com"
                           autocomplete="email"
                           @bind="email"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Contraseña</span>
                    <input class="form-control"
                           type="password"
                           placeholder="Tu contraseña"
                           autocomplete="current-password"
                           @bind="password"
                           @bind:event="oninput" />
                </div>

                <button class="btn btn-primary auth-submit"
                        @onclick="LoginOrganizer">
                    Ingresar al panel
                </button>
            </div>

            <div class="auth-footer">
                <span>¿Vas a organizar tu primer torneo?</span>
                <a href="/organizer/register">Crear cuenta de organizador</a>
            </div>
        </div>
    </section>

    <aside class="auth-side-panel">
        <div class="auth-side-card organizer-side-card">
            <div class="auth-side-icon">TR</div>
            <h2>Gestioná el torneo sin perder el control.</h2>
            <p>
                El modo organizador concentra categorías, pagos, grupos, partidos y llaves eliminatorias.
            </p>

            <div class="auth-feature-list">
                <div>
                    <span>01</span>
                    <strong>Categorías y cupos</strong>
                    <small>Definí niveles, fees y disponibilidad antes de abrir inscripciones.</small>
                </div>

                <div>
                    <span>02</span>
                    <strong>Grupos y partidos</strong>
                    <small>Asigná parejas, generá cruces y cargá resultados desde el panel.</small>
                </div>

                <div>
                    <span>03</span>
                    <strong>Llave final</strong>
                    <small>Pasá de fase de grupos a eliminación con una vista clara.</small>
                </div>
            </div>
        </div>
    </aside>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private void LoginOrganizer()
    {
        errorMessage = string.Empty;

        try
        {
            OrganizerAccountService.Login(email, password);

            NavigationManager.NavigateTo("/tournaments");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }
}
