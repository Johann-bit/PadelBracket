@page "/organizer/login"
@using PadelBracket.Services
@inject OrganizerAccountService OrganizerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Ingresar organizador</PageTitle>

<div class="page-header">
    <div class="page-eyebrow">Cuenta de organizador</div>
    <h1 class="page-title">Ingresar como organizador</h1>
    <p class="page-subtitle">
        Entrá con tu email para administrar tus torneos y categorías.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title mb-2">Iniciar sesión</h4>

        <p class="text-muted mb-4">
            Usá el email con el que registraste tu cuenta de organizador.
        </p>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control"
                   type="email"
                   placeholder="Ejemplo: organizador@mail.com"
                   @bind="email"
                   @bind:event="oninput" />
        </div>

        <div class="mb-4">
            <label class="form-label">Contraseña</label>
            <input class="form-control"
                   type="password"
                   placeholder="Tu contraseña"
                   @bind="password"
                   @bind:event="oninput" />
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary" @onclick="LoginOrganizer">
                Ingresar
            </button>

            <a class="btn btn-outline-primary" href="/organizer/register">
                Crear cuenta
            </a>
        </div>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private void LoginOrganizer()
    {
        errorMessage = string.Empty;

        try
        {
            OrganizerAccountService.Login(email, password);

            NavigationManager.NavigateTo("/tournaments");
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }
}