@page "/register"
@using PadelBracket.Domain.Enums
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Registrarme</PageTitle>

<div class="auth-shell register-auth-shell">
    <section class="auth-panel">
        <div class="auth-card register-auth-card">
            <div class="auth-card-header">
                <span class="auth-badge">Cuenta de jugador</span>
                <h1>Registrarme</h1>
                <p>
                    Creá tu perfil con nombre real, categoría, mano hábil y lado de juego para poder anotarte a torneos.
                </p>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">
                    @errorMessage
                </div>
            }

            <div class="auth-form register-form">
                <div class="form-field span-2">
                    <span>Nombre real</span>
                    <input class="form-control"
                           placeholder="Ejemplo: Juan Pérez"
                           autocomplete="name"
                           @bind="realName"
                           @bind:event="oninput" />
                </div>

                <div class="form-field span-2">
                    <span>Email</span>
                    <input class="form-control"
                           type="email"
                           placeholder="Ejemplo: juan@mail.com"
                           autocomplete="email"
                           @bind="email"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Contraseña</span>
                    <input class="form-control"
                           type="password"
                           placeholder="Mínimo 8 caracteres"
                           autocomplete="new-password"
                           @bind="password"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Confirmar contraseña</span>
                    <input class="form-control"
                           type="password"
                           placeholder="Repetí tu contraseña"
                           autocomplete="new-password"
                           @bind="confirmPassword"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Mano hábil</span>
                    <select class="form-select" @bind="dominantHand">
                        <option value="@DominantHand.Right">Derecha</option>
                        <option value="@DominantHand.Left">Zurda</option>
                    </select>
                </div>

                <div class="form-field">
                    <span>Lado de juego</span>
                    <select class="form-select" @bind="preferredSide">
                        <option value="@PreferredSide.Drive">Drive</option>
                        <option value="@PreferredSide.Backhand">Revés</option>
                        <option value="@PreferredSide.Both">Ambos</option>
                    </select>
                </div>

                <div class="form-field span-2">
                    <span>Categoría</span>
                    <select class="form-select" @bind="category">
                        @for (int categoryOption = 1; categoryOption <= 8; categoryOption++)
                        {
                            <option value="@categoryOption">@GetCategoryLabel(categoryOption)</option>
                        }
                    </select>
                </div>

                <button class="btn btn-primary auth-submit span-2"
                        @onclick="RegisterPlayer">
                    Crear cuenta
                </button>
            </div>

            <div class="auth-footer">
                <span>¿Ya tenés cuenta?</span>
                <a href="/login">Ingresar como jugador</a>
            </div>
        </div>
    </section>

    <aside class="auth-side-panel">
        <div class="auth-side-card register-side-card">
            <div class="auth-side-icon">PB</div>
            <h2>Tu perfil competitivo empieza bien armado.</h2>
            <p>
                Estos datos son obligatorios porque después validan pareja, categoría e inscripción.
            </p>

            <div class="register-requirement-list">
                <div>
                    <span>@GetRequirementStatus(HasRealName)</span>
                    <strong>Nombre real</strong>
                    <small>Usá nombre y apellido, sin números.</small>
                </div>

                <div>
                    <span>@GetRequirementStatus(HasValidEmail)</span>
                    <strong>Email válido</strong>
                    <small>Va a identificar tu cuenta de jugador.</small>
                </div>

                <div>
                    <span>@GetRequirementStatus(HasStrongPassword)</span>
                    <strong>Contraseña fuerte</strong>
                    <small>8 caracteres, mayúscula, minúscula, número y especial.</small>
                </div>

                <div>
                    <span>@GetRequirementStatus(PasswordsMatch)</span>
                    <strong>Confirmación</strong>
                    <small>Las dos contraseñas tienen que coincidir.</small>
                </div>

                <div>
                    <span>OK</span>
                    <strong>Datos deportivos</strong>
                    <small>Mano, lado y categoría quedan cargados desde el registro.</small>
                </div>
            </div>
        </div>
    </aside>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string realName = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private DominantHand dominantHand = DominantHand.Right;
    private PreferredSide preferredSide = PreferredSide.Drive;
    private int category = 6;
    private string errorMessage = string.Empty;

    private bool HasRealName => realName
        .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
        .Length >= 2;

    private bool HasValidEmail => email.Contains('@') && email.Contains('.');

    private bool HasStrongPassword =>
        password.Length >= 8 &&
        password.Any(char.IsUpper) &&
        password.Any(char.IsLower) &&
        password.Any(char.IsDigit) &&
        password.Any(character => !char.IsLetterOrDigit(character));

    private bool PasswordsMatch =>
        !string.IsNullOrWhiteSpace(password) &&
        password == confirmPassword;

    private async Task RegisterPlayer()
    {
        errorMessage = string.Empty;

        try
        {
            await PlayerAccountService.RegisterAsync(
                realName,
                email,
                password,
                confirmPassword,
                dominantHand,
                preferredSide,
                category);

            NavigationManager.NavigateTo(GetSafeReturnUrl());
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
            return "/";

        if (!ReturnUrl.StartsWith("/") || ReturnUrl.StartsWith("//"))
            return "/";

        return ReturnUrl;
    }

    private static string GetCategoryLabel(int category)
    {
        return category switch
        {
            1 => "1ra categoría",
            2 => "2da categoría",
            3 => "3ra categoría",
            4 => "4ta categoría",
            5 => "5ta categoría",
            6 => "6ta categoría",
            7 => "7ma categoría",
            8 => "8va categoría",
            _ => "Sin categoría"
        };
    }

    private static string GetRequirementStatus(bool isComplete)
    {
        return isComplete ? "OK" : "--";
    }
}
