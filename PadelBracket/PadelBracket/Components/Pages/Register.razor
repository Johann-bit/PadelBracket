@page "/register"
@using PadelBracket.Domain.Enums
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Registrarme</PageTitle>

<div class="page-header">
    <div class="page-eyebrow">Cuenta de jugador</div>
    <h1 class="page-title">Registrarme</h1>
    <p class="page-subtitle">
        Creá tu perfil con nombre real, categoría, mano hábil y lado de juego para poder anotarte a torneos.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title mb-2">Datos del jugador</h4>

        <p class="text-muted mb-4">
            Usá tu nombre real. Estos datos son necesarios para competir y formar pareja.
        </p>

        <div class="mb-3">
            <label class="form-label">Nombre real</label>
            <input class="form-control"
                   placeholder="Ejemplo: Juan Pérez"
                   @bind="realName"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control"
                   type="email"
                   placeholder="Ejemplo: juan@mail.com"
                   @bind="email"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Contraseña</label>
            <input class="form-control"
                   type="password"
                   placeholder="Mínimo 8 caracteres"
                   @bind="password"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Confirmar contraseña</label>
            <input class="form-control"
                   type="password"
                   placeholder="Repetí tu contraseña"
                   @bind="confirmPassword"
                   @bind:event="oninput" />
        </div>

        <div class="mb-3">
            <label class="form-label">Mano hábil</label>
            <select class="form-select" @bind="dominantHand">
                <option value="@DominantHand.Right">Derecha</option>
                <option value="@DominantHand.Left">Zurda</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Lado de juego</label>
            <select class="form-select" @bind="preferredSide">
                <option value="@PreferredSide.Drive">Drive</option>
                <option value="@PreferredSide.Backhand">Revés</option>
                <option value="@PreferredSide.Both">Ambos</option>
            </select>
        </div>

        <div class="mb-4">
            <label class="form-label">Categoría</label>
            <select class="form-select" @bind="category">
                @for (int categoryOption = 1; categoryOption <= 8; categoryOption++)
                {
                    <option value="@categoryOption">@categoryOption</option>
                }
            </select>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary" @onclick="RegisterPlayer">
                Crear cuenta
            </button>

            <a class="btn btn-outline-primary" href="/login">
                Ya tengo cuenta
            </a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string realName = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private string confirmPassword = string.Empty;
    private DominantHand dominantHand = DominantHand.Right;
    private PreferredSide preferredSide = PreferredSide.Drive;
    private int category = 6;
    private string errorMessage = string.Empty;

    private async Task RegisterPlayer()
    {
        errorMessage = string.Empty;

        try
        {
            await PlayerAccountService.RegisterAsync(
                realName,
                email,
                password,
                confirmPassword,
                dominantHand,
                preferredSide,
                category);

            NavigationManager.NavigateTo(GetSafeReturnUrl());
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
            return "/";

        if (!ReturnUrl.StartsWith("/") || ReturnUrl.StartsWith("//"))
            return "/";

        return ReturnUrl;
    }
}