@page "/my-registrations"
@using PadelBracket.Domain.DTOs
@using PadelBracket.Domain.Enums
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject PlayerAccountService PlayerAccountService
@rendermode InteractiveServer

<PageTitle>Mis inscripciones</PageTitle>

<div class="page-header">
    <div class="page-eyebrow">Competencia</div>
    <h1 class="page-title">Mis inscripciones</h1>
    <p class="page-subtitle">
        Revisá tus torneos, el estado de la inscripción y la confirmación manual de pago.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">
        @successMessage
    </div>
}

@if (CurrentPlayerId == null)
{
    <div class="empty-state">
        <div class="empty-state-title">Iniciá sesión para ver tus inscripciones.</div>
        <div class="mb-3">
            Tus inscripciones se muestran según el jugador que tenga la sesión activa.
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" href="/login?returnUrl=/my-registrations">
                Ingresar
            </a>

            <a class="btn btn-outline-primary" href="/register?returnUrl=/my-registrations">
                Registrarme
            </a>
        </div>
    </div>
}
else
{
    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-label">Inscripciones</div>
            <div class="stat-value">@myRegistrations.Count</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Pendientes</div>
            <div class="stat-value">@myRegistrations.Count(item => item.Registration.Status == RegistrationStatus.Pending)</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Confirmadas</div>
            <div class="stat-value">@myRegistrations.Count(item => item.Registration.Status == RegistrationStatus.Confirmed)</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Pagas</div>
            <div class="stat-value">@myRegistrations.Count(item => item.Registration.PaymentStatus == PaymentStatus.Paid)</div>
        </div>
    </div>

    @if (!myRegistrations.Any())
    {
        <div class="empty-state">
            <div class="empty-state-title">Todavía no tenés inscripciones.</div>
            <div class="mb-3">
                Cuando inscribas una pareja a un torneo, vas a verla acá.
            </div>

            <a class="btn btn-primary" href="/tournaments/available">
                Ver torneos disponibles
            </a>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <strong>Pago manual por ahora.</strong>
            <div>
                Coordiná el pago con el organizador. Cuando lo valide, esta inscripción va a aparecer como paga.
            </div>
        </div>

        <div class="row g-3">
            @foreach (MyRegistrationItem item in myRegistrations)
            {
                <div class="col-xl-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <div>
                                    <h4 class="card-title mb-1">@item.Tournament.Name</h4>
                                    <div class="text-muted">
                                        @item.Tournament.ClubName · @item.Tournament.City · @item.Tournament.StartDateLabel
                                    </div>
                                </div>

                                <span class="badge bg-primary">
                                    @item.Registration.CategoryLabel
                                </span>
                            </div>

                            <div class="table-responsive mb-3">
                                <table class="table table-sm align-middle mb-0">
                                    <tbody>
                                        <tr>
                                            <th>Pareja</th>
                                            <td>@item.Registration.PairDisplayName</td>
                                        </tr>

                                        <tr>
                                            <th>Inscripción</th>
                                            <td>
                                                <span class="badge @GetRegistrationStatusBadgeClass(item.Registration.Status)">
                                                    @item.Registration.StatusLabel
                                                </span>
                                            </td>
                                        </tr>

                                        <tr>
                                            <th>Pago</th>
                                            <td>
                                                <span class="badge @GetPaymentStatusBadgeClass(item.Registration.PaymentStatus)">
                                                    @item.Registration.PaymentStatusLabel
                                                </span>
                                                <div class="text-muted mt-1">
                                                    @item.Registration.PaymentHelpText
                                                </div>
                                            </td>
                                        </tr>

                                        <tr>
                                            <th>Fecha</th>
                                            <td>@item.Registration.RegisteredAt.ToString("dd/MM/yyyy HH:mm")</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap">
                                <a class="btn btn-sm btn-outline-primary"
                                   href="@($"/tournaments/{item.Tournament.Id}")">
                                    Ver torneo
                                </a>

                                @if (CanCancelRegistration(item.Registration))
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => AskCancelRegistration(item.Registration.Id)">
                                        Cancelar inscripción
                                    </button>
                                }
                            </div>

                            @if (registrationIdToCancel == item.Registration.Id)
                            {
                                <div class="alert alert-danger mt-3 mb-0">
                                    <strong>¿Cancelar esta inscripción?</strong>
                                    <div class="mb-3">
                                        La inscripción quedará cancelada y el cupo volverá a estar disponible.
                                    </div>

                                    <div class="d-flex gap-2 flex-wrap">
                                        <button class="btn btn-sm btn-danger"
                                                @onclick="() => CancelRegistration(item.Tournament.Id, item.Registration.Id)">
                                            Confirmar
                                        </button>

                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="CancelCancelRegistration">
                                            Volver
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private List<MyRegistrationItem> myRegistrations = new();
    private Guid? registrationIdToCancel;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private Guid? CurrentPlayerId => PlayerAccountService.CurrentPlayer?.Id;

    protected override void OnInitialized()
    {
        LoadRegistrations();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await PlayerAccountService.RestoreSessionAsync();
        LoadRegistrations();
        StateHasChanged();
    }

    private void LoadRegistrations()
    {
        myRegistrations = new();

        if (CurrentPlayerId == null)
            return;

        myRegistrations = TournamentService.GetAllTournamentDtos()
            .SelectMany(tournament => tournament.Registrations
                .Where(RegistrationBelongsToCurrentPlayer)
                .Select(registration => new MyRegistrationItem(tournament, registration)))
            .OrderByDescending(item => item.Registration.RegisteredAt)
            .ToList();
    }

    private bool RegistrationBelongsToCurrentPlayer(TournamentRegistrationDto registration)
    {
        return CurrentPlayerId.HasValue && registration.BelongsToPlayer(CurrentPlayerId.Value);
    }

    private void AskCancelRegistration(Guid registrationId)
    {
        ClearMessages();
        registrationIdToCancel = registrationId;
    }

    private void CancelCancelRegistration()
    {
        registrationIdToCancel = null;
    }

    private void CancelRegistration(Guid tournamentId, Guid registrationId)
    {
        ClearMessages();

        try
        {
            TournamentService.CancelRegistration(tournamentId, registrationId);

            registrationIdToCancel = null;
            successMessage = "Inscripción cancelada correctamente.";

            LoadRegistrations();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private static bool CanCancelRegistration(TournamentRegistrationDto registration)
    {
        return registration.Status == RegistrationStatus.Pending ||
               registration.Status == RegistrationStatus.Confirmed;
    }

    private static string GetRegistrationStatusBadgeClass(RegistrationStatus status)
    {
        return status switch
        {
            RegistrationStatus.Confirmed => "bg-success",
            RegistrationStatus.Rejected => "bg-danger",
            RegistrationStatus.Cancelled => "bg-secondary",
            _ => "bg-warning text-dark"
        };
    }

    private static string GetPaymentStatusBadgeClass(PaymentStatus status)
    {
        return status switch
        {
            PaymentStatus.Paid => "bg-success",
            PaymentStatus.Refunded => "bg-primary",
            PaymentStatus.Cancelled => "bg-secondary",
            _ => "bg-warning text-dark"
        };
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }

    private record MyRegistrationItem(
        TournamentDto Tournament,
        TournamentRegistrationDto Registration);
}
