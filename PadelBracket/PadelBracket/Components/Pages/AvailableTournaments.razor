@page "/tournaments/available"
@using PadelBracket.Domain.DTOs
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject PairService PairService
@inject PlayerAccountService PlayerAccountService
@rendermode InteractiveServer

<PageTitle>Torneos disponibles</PageTitle>

<section class="dashboard-hero player-page-hero">
    <div>
        <div class="page-eyebrow">Competencia</div>
        <h1 class="page-title">Torneos disponibles</h1>
        <p class="page-subtitle">
            Encontrá torneos abiertos, revisá categorías, cupos e inscripciones antes de anotarte con tu pareja.
        </p>
    </div>

    @if (CurrentPlayer != null)
    {
        <a class="btn btn-primary dashboard-hero-action" href="/pairs">
            <span>+</span>
            Mi pareja
        </a>
    }
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">
        @successMessage
    </div>
}

<section class="metric-grid player-metric-grid">
    <div class="metric-card">
        <div class="metric-icon">TR</div>
        <div>
            <div class="metric-label">Torneos</div>
            <div class="metric-value">@availableTournaments.Count</div>
            <div class="metric-trend">Disponibles para anotarte</div>
        </div>
        <div class="metric-sparkline"></div>
    </div>

    <div class="metric-card">
        <div class="metric-icon">CT</div>
        <div>
            <div class="metric-label">Categorías</div>
            <div class="metric-value">@availableTournaments.Sum(tournament => tournament.CategoryCount)</div>
            <div class="metric-trend">Con cupos configurados</div>
        </div>
        <div class="metric-sparkline"></div>
    </div>

    <div class="metric-card">
        <div class="metric-icon">IN</div>
        <div>
            <div class="metric-label">Inscripciones activas</div>
            <div class="metric-value">@availableTournaments.Sum(tournament => tournament.ActiveRegistrationCount)</div>
            <div class="metric-trend">Entre todos los torneos</div>
        </div>
        <div class="metric-sparkline"></div>
    </div>

    <div class="metric-card">
        <div class="metric-icon">PR</div>
        <div>
            <div class="metric-label">Mis parejas</div>
            <div class="metric-value">@myPairs.Count</div>
            <div class="metric-trend">Disponibles para competir</div>
        </div>
    </div>
</section>

@if (!availableTournaments.Any())
{
    <div class="empty-state">
        <div class="empty-state-title">No hay torneos disponibles por ahora.</div>
        <div>
            Cuando un organizador cree torneos con categorías, van a aparecer acá.
        </div>
    </div>
}
else
{
    <div class="available-tournament-grid">
        @foreach (TournamentDto tournament in availableTournaments)
        {
            <div class="card h-100 available-tournament-card">
                    <div class="card-body">
                        <div class="available-tournament-header">
                            <div>
                                <h4 class="card-title mb-1">@tournament.Name</h4>
                                <div class="text-muted">
                                    Creado @tournament.CreatedAtLabel
                                </div>
                            </div>

                            <span class="badge bg-primary">
                                @tournament.StatusLabel
                            </span>
                        </div>

                        <div class="available-category-strip">
                            @foreach (TournamentCategoryDto category in tournament.Categories)
                            {
                                <span class="badge @GetCategoryBadgeClass(category)">
                                    @category.CategoryLabel · @category.SlotsLabel
                                </span>
                            }
                        </div>

                        <div class="available-category-grid">
                            @foreach (TournamentCategoryDto category in tournament.Categories)
                            {
                                <div class="available-category-card">
                                    <strong>@category.CategoryLabel</strong>
                                    <span>@category.SlotsLabel</span>
                                    <small>@category.RegistrationFeeLabel</small>
                                </div>
                            }
                        </div>

                        <div class="player-signup-panel">
                            <div class="panel-kicker">Inscripción</div>
                            <h5>Inscribir mi pareja</h5>

                            @if (CurrentPlayer == null)
                            {
                                <div class="empty-state mb-3">
                                    <div class="empty-state-title">Iniciá sesión para inscribirte.</div>
                                    <div>
                                        Necesitás una cuenta de jugador y una pareja creada.
                                    </div>
                                </div>

                                <div class="d-flex gap-2 flex-wrap">
                                    <a class="btn btn-sm btn-primary" href="/login?returnUrl=/tournaments/available">
                                        Ingresar
                                    </a>

                                    <a class="btn btn-sm btn-outline-primary" href="/register?returnUrl=/tournaments/available">
                                        Registrarme
                                    </a>
                                </div>
                            }
                            else if (!myPairs.Any())
                            {
                                <div class="empty-state mb-3">
                                    <div class="empty-state-title">Todavía no tenés pareja.</div>
                                    <div>
                                        Creá una pareja antes de anotarte a un torneo.
                                    </div>
                                </div>

                                <a class="btn btn-sm btn-primary" href="/pairs">
                                    Crear pareja
                                </a>
                            }
                            else
                            {
                                <div class="player-signup-grid">
                                    <label class="form-field">
                                        <span>Pareja</span>
                                        <select class="form-select"
                                                value="@GetSelectedPairId(tournament.Id)"
                                                @onchange="eventArgs => SetSelectedPairId(tournament.Id, eventArgs.Value?.ToString() ?? string.Empty)">
                                            <option value="">Seleccionar pareja</option>

                                            @foreach (PairDto pair in GetEligiblePairs(tournament))
                                            {
                                                <option value="@pair.Id">
                                                    @pair.DisplayName · Categoría @GetCategoryLabel(pair.Category)
                                                </option>
                                            }
                                        </select>
                                    </label>

                                    <label class="form-field">
                                        <span>Categoría</span>
                                        <select class="form-select"
                                                value="@GetSelectedCategory(tournament.Id)"
                                                @onchange="eventArgs => SetSelectedCategory(tournament.Id, eventArgs.Value?.ToString() ?? string.Empty)">
                                            <option value="">Seleccionar categoría</option>

                                            @foreach (TournamentCategoryDto category in tournament.Categories.Where(category => category.HasAvailableSlots))
                                            {
                                                <option value="@category.Category">
                                                    @category.CategoryLabel
                                                </option>
                                            }
                                        </select>
                                    </label>
                                </div>

                                @if (!GetEligiblePairs(tournament).Any())
                                {
                                    <div class="alert alert-warning">
                                        No tenés parejas compatibles con las categorías disponibles de este torneo.
                                    </div>
                                }

                                <div class="available-card-footer">
                                    <div class="text-muted">
                                        @tournament.ActiveRegistrationCount inscripciones activas
                                    </div>

                                    <div class="d-flex gap-2 flex-wrap">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="@($"/tournaments/{tournament.Id}")">
                                            Ver torneo
                                        </a>

                                        <button class="btn btn-sm btn-primary"
                                                @onclick="() => RegisterMyPair(tournament.Id)">
                                            Inscribir
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
        }
    </div>
}

@code {
    private List<TournamentDto> availableTournaments = new();
    private List<PairDto> myPairs = new();

    private readonly Dictionary<Guid, string> selectedPairIdsByTournament = new();
    private readonly Dictionary<Guid, string> selectedCategoriesByTournament = new();

    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private Player? CurrentPlayer => PlayerAccountService.CurrentPlayer;

    protected override void OnInitialized()
    {
        LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await PlayerAccountService.RestoreSessionAsync();
        LoadData();
        StateHasChanged();
    }

    private void LoadData()
    {
        availableTournaments = TournamentService.GetAllTournamentDtos()
            .Where(tournament => tournament.HasCategories)
            .OrderByDescending(tournament => tournament.CreatedAt)
            .ToList();

        myPairs = PairService.GetAllDtos()
            .Where(pair =>
                CurrentPlayer != null &&
                (pair.PlayerOneId == CurrentPlayer.Id || pair.PlayerTwoId == CurrentPlayer.Id))
            .OrderBy(pair => pair.DisplayName)
            .ToList();
    }

    private void RegisterMyPair(Guid tournamentId)
    {
        ClearMessages();

        try
        {
            string selectedPairId = GetSelectedPairId(tournamentId);
            string selectedCategory = GetSelectedCategory(tournamentId);

            if (CurrentPlayer == null)
                throw new InvalidOperationException("Tenés que iniciar sesión para inscribirte.");

            if (string.IsNullOrWhiteSpace(selectedPairId))
                throw new ArgumentException("Seleccioná una pareja.");

            if (string.IsNullOrWhiteSpace(selectedCategory))
                throw new ArgumentException("Seleccioná una categoría.");

            PairDto selectedPair = myPairs.FirstOrDefault(pair => pair.Id == Guid.Parse(selectedPairId))
                ?? throw new ArgumentException("No se encontró la pareja seleccionada.");

            if (!selectedPair.PlayerOneId.Equals(CurrentPlayer.Id) &&
                !selectedPair.PlayerTwoId.Equals(CurrentPlayer.Id))
            {
                throw new InvalidOperationException("Solo podés inscribir una pareja en la que participás.");
            }

            TournamentService.RegisterPairToTournament(
                tournamentId,
                selectedPair.Id,
                int.Parse(selectedCategory));

            selectedPairIdsByTournament[tournamentId] = string.Empty;
            selectedCategoriesByTournament[tournamentId] = string.Empty;

            successMessage = "Inscripción creada correctamente.";

            LoadData();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private List<PairDto> GetEligiblePairs(TournamentDto tournament)
    {
        return myPairs
            .Where(pair => tournament.Categories.Any(category =>
                category.HasAvailableSlots &&
                pair.Category.HasValue &&
                pair.Category.Value <= category.Category))
            .ToList();
    }

    private string GetSelectedPairId(Guid tournamentId)
    {
        return selectedPairIdsByTournament.TryGetValue(tournamentId, out string? pairId)
            ? pairId
            : string.Empty;
    }

    private void SetSelectedPairId(Guid tournamentId, string pairId)
    {
        selectedPairIdsByTournament[tournamentId] = pairId;
    }

    private string GetSelectedCategory(Guid tournamentId)
    {
        return selectedCategoriesByTournament.TryGetValue(tournamentId, out string? category)
            ? category
            : string.Empty;
    }

    private void SetSelectedCategory(Guid tournamentId, string category)
    {
        selectedCategoriesByTournament[tournamentId] = category;
    }

    private static string GetCategoryBadgeClass(TournamentCategoryDto category)
    {
        if (category.AvailableSlots <= 0)
            return "bg-secondary";

        return "bg-success";
    }

    private static string GetCategoryLabel(int? category)
    {
        if (!category.HasValue)
            return "-";

        return category.Value.ToString();
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
