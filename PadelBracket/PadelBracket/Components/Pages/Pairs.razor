@page "/pairs"
@using PadelBracket.Domain.DTOs
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject PlayerService PlayerService
@inject PairService PairService
@inject PlayerAccountService PlayerAccountService
@rendermode InteractiveServer

<PageTitle>Parejas</PageTitle>

<section class="dashboard-hero player-page-hero">
    <div>
        <div class="page-eyebrow">Mi pareja</div>
        <h1 class="page-title">Parejas</h1>
        <p class="page-subtitle">
            Formá tu pareja usando tu perfil de jugador y un compañero registrado.
        </p>
    </div>

    @if (CurrentPlayer != null)
    {
        <a class="btn btn-primary dashboard-hero-action" href="/tournaments/available">
            Ver torneos
        </a>
    }
</section>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

@if (!string.IsNullOrWhiteSpace(successMessage))
{
    <div class="alert alert-success">
        @successMessage
    </div>
}

<section class="metric-grid player-metric-grid">
    <div class="metric-card">
        <div class="metric-icon">PR</div>
        <div>
            <div class="metric-label">Parejas registradas</div>
            <div class="metric-value">@pairs.Count</div>
            <div class="metric-trend">Disponibles para competir</div>
        </div>
        <div class="metric-sparkline"></div>
    </div>

    <div class="metric-card">
        <div class="metric-icon">JG</div>
        <div>
            <div class="metric-label">Jugadores disponibles</div>
            <div class="metric-value">@partnerCandidates.Count</div>
            <div class="metric-trend">Con perfil completo y sin pareja</div>
        </div>
        <div class="metric-sparkline"></div>
    </div>

    <div class="metric-card">
        <div class="metric-icon">MI</div>
        <div>
            <div class="metric-label">Mi estado</div>
            <div class="metric-value metric-value-text">@CurrentPairStatus</div>
            <div class="metric-trend">Estado de inscripción posible</div>
        </div>
    </div>

    <div class="metric-card">
        <div class="metric-icon">OK</div>
        <div>
            <div class="metric-label">Verificadas</div>
            <div class="metric-value">@pairs.Count(pair => pair.IsFullyVerified)</div>
            <div class="metric-trend">Parejas completas</div>
        </div>
        <div class="metric-sparkline"></div>
    </div>
</section>

@if (CurrentPlayer == null)
{
    <div class="empty-state mb-4">
        <div class="empty-state-title">Iniciá sesión para crear tu pareja.</div>

        <div class="mb-3">
            Necesitás una cuenta de jugador para elegir compañero y anotarte a torneos.
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" href="/login?returnUrl=/pairs">
                Ingresar
            </a>

            <a class="btn btn-outline-primary" href="/register?returnUrl=/pairs">
                Registrarme
            </a>
        </div>
    </div>
}
else if (!CurrentPlayer.HasCompleteProfile)
{
    <div class="empty-state mb-4">
        <div class="empty-state-title">Completá tu perfil antes de crear pareja.</div>

        <div class="mb-3">
            Para formar pareja necesitás nombre real, email, mano hábil, lado de juego y categoría.
        </div>

        <a class="btn btn-primary" href="/profile">
            Ir a mi perfil
        </a>
    </div>
}
else if (myPair != null)
{
    <div class="card mb-4 pair-current-card">
        <div class="card-body">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Pareja activa</div>
                    <h2>Mi pareja actual</h2>
                    <p>Esta pareja queda disponible para inscribirte a torneos.</p>
                </div>

                @if (myPair.IsFullyVerified)
                {
                    <span class="badge bg-success">Verificada</span>
                }
                else
                {
                    <span class="badge bg-secondary">Pendiente</span>
                }
            </div>

            <div class="pair-detail-grid">
                <div>
                    <span>Pareja</span>
                    <strong>@myPair.DisplayName</strong>
                </div>

                <div>
                    <span>Jugador 1</span>
                    <strong>@myPair.PlayerOneName</strong>
                </div>

                <div>
                    <span>Jugador 2</span>
                    <strong>@myPair.PlayerTwoName</strong>
                </div>

                <div>
                    <span>Categoría</span>
                    <strong>Categoría @GetCategoryLabel(myPair.Category)</strong>
                </div>
            </div>

            <div class="panel-actions">
                <button class="btn btn-outline-danger"
                        @onclick="() => DeletePair(myPair.Id)">
                    Eliminar mi pareja
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="card mb-4 pair-create-card">
        <div class="card-body">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Nueva pareja</div>
                    <h2>Crear mi pareja</h2>
                    <p>Tu perfil queda como primer jugador. Elegí un compañero registrado con perfil completo y sin pareja activa.</p>
                </div>
            </div>

            <div class="pair-create-grid">
                <label class="form-field">
                    <span>Jugador 1</span>
                    <input class="form-control"
                           value="@CurrentPlayer.Name"
                           disabled />
                </label>

                <label class="form-field">
                    <span>Compañero</span>
                    <select class="form-select" @bind="selectedPartnerId">
                        <option value="">Seleccionar compañero</option>

                        @foreach (PlayerDto player in partnerCandidates)
                        {
                            <option value="@player.Id">
                                @player.Name · Categoría @GetCategoryLabel(player.Category)
                            </option>
                        }
                    </select>
                </label>
            </div>

            @if (!partnerCandidates.Any())
            {
                <div class="alert alert-warning">
                    No hay compañeros disponibles con perfil completo y sin pareja activa.
                </div>
            }

            <button class="btn btn-primary"
                    disabled="@(!partnerCandidates.Any())"
                    @onclick="CreatePair">
                Crear pareja
            </button>
        </div>
    </div>
}

<div class="section-toolbar">
    <div>
        <div class="panel-kicker">Comunidad</div>
        <h3>Parejas registradas</h3>
        <p class="text-muted mb-0">Estas parejas podrán utilizarse en torneos y partidos.</p>
    </div>

    <span class="status-pill">
        @pairs.Count total
    </span>
</div>

@if (!pairs.Any())
{
    <div class="empty-state">
        <div class="empty-state-title">Todavía no hay parejas registradas.</div>

        <div>
            Creá la primera pareja usando jugadores existentes.
        </div>
    </div>
}
else
{
    var currentPairPage = GetCurrentPairPage();
    var pagedPairs = GetPagedPairs();

    <div class="table-responsive pair-table-wrap">
        <table class="table table-striped align-middle pair-table">
            <thead>
                <tr>
                    <th>Pareja</th>
                    <th>Jugador 1</th>
                    <th>Jugador 2</th>
                    <th>Categoría</th>
                    <th>Estado</th>
                    <th></th>
                </tr>
            </thead>

            <tbody>
                @foreach (PairDto pair in pagedPairs)
                {
                    <tr>
                        <td>
                            <strong>@pair.DisplayName</strong>

                            @if (IsMyPair(pair))
                            {
                                <span class="badge bg-primary ms-2">Mi pareja</span>
                            }
                        </td>

                        <td>@pair.PlayerOneName</td>

                        <td>@pair.PlayerTwoName</td>

                        <td>
                            <span class="badge bg-primary">
                                Categoría @GetCategoryLabel(pair.Category)
                            </span>
                        </td>

                        <td>
                            @if (pair.IsFullyVerified)
                            {
                                <span class="badge bg-success">Verificada</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Pendiente</span>
                            }
                        </td>

                        <td class="text-end">
                            @if (CanDeletePair(pair))
                            {
                                <button class="btn btn-sm btn-outline-danger"
                                        @onclick="() => DeletePair(pair.Id)">
                                    Eliminar
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (pairs.Count > PairPageSize)
    {
        <div class="registration-pagination pair-pagination">
            <div>
                Mostrando @GetFirstVisiblePairNumber()-@GetLastVisiblePairNumber() de @pairs.Count parejas · Página @currentPairPage de @GetPairPageCount()
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary"
                        disabled="@(currentPairPage <= 1)"
                        @onclick="PreviousPairPage">
                    Anterior
                </button>

                <button class="btn btn-outline-primary"
                        disabled="@(currentPairPage >= GetPairPageCount())"
                        @onclick="NextPairPage">
                    Siguiente
                </button>
            </div>
        </div>
    }
}

@code {
    private const int PairPageSize = 12;
    private List<PlayerDto> players = new();
    private List<PlayerDto> partnerCandidates = new();
    private List<PairDto> pairs = new();

    private PairDto? myPair;
    private int pairPage = 1;
    private string selectedPartnerId = string.Empty;

    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private Player? CurrentPlayer => PlayerAccountService.CurrentPlayer;

    private string CurrentPairStatus
    {
        get
        {
            if (CurrentPlayer == null)
                return "Sin sesión";

            if (!CurrentPlayer.HasCompleteProfile)
                return "Perfil incompleto";

            return myPair == null ? "Sin pareja" : "Con pareja";
        }
    }

    protected override void OnInitialized()
    {
        LoadData();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await PlayerAccountService.RestoreSessionAsync();
        LoadData();
        StateHasChanged();
    }

    private void LoadData()
    {
        players = PlayerService.GetAllDtos().ToList();

        pairs = PairService.GetAllDtos()
            .OrderBy(pair => pair.PlayerOneName)
            .ThenBy(pair => pair.PlayerTwoName)
            .ToList();

        pairPage = Math.Clamp(pairPage, 1, GetPairPageCount());

        myPair = CurrentPlayer == null
            ? null
            : PairService.GetDtosByPlayerId(CurrentPlayer.Id).FirstOrDefault();

        partnerCandidates = players
            .Where(player =>
                CurrentPlayer != null &&
                player.Id != CurrentPlayer.Id &&
                player.HasCompleteProfile &&
                !PairService.PlayerHasPair(player.Id))
            .OrderBy(player => player.Name)
            .ToList();
    }

    private void CreatePair()
    {
        ClearMessages();

        try
        {
            if (CurrentPlayer == null)
                throw new InvalidOperationException("Tenés que iniciar sesión para crear una pareja.");

            if (!CurrentPlayer.HasCompleteProfile)
                throw new InvalidOperationException("Completá tu perfil antes de crear una pareja.");

            if (PairService.PlayerHasPair(CurrentPlayer.Id))
                throw new InvalidOperationException("Ya tenés una pareja activa.");

            if (string.IsNullOrWhiteSpace(selectedPartnerId))
                throw new ArgumentException("Seleccioná un compañero.");

            Player partner = PlayerService.GetById(Guid.Parse(selectedPartnerId))
                ?? throw new ArgumentException("No se encontró el compañero seleccionado.");

            if (!partner.HasCompleteProfile)
                throw new InvalidOperationException("El compañero debe tener el perfil completo.");

            if (PairService.PlayerHasPair(partner.Id))
                throw new InvalidOperationException("El compañero ya tiene una pareja activa.");

            PairService.Add(CurrentPlayer, partner);

            selectedPartnerId = string.Empty;
            pairPage = 1;

            successMessage = "Pareja creada correctamente.";

            LoadData();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private void DeletePair(Guid id)
    {
        ClearMessages();

        try
        {
            Pair pair = PairService.GetById(id)
                ?? throw new ArgumentException("Pair not found.");

            if (CurrentPlayer == null || !pair.ContainsPlayer(CurrentPlayer.Id))
                throw new InvalidOperationException("Solo podés eliminar una pareja en la que participás.");

            PairService.Delete(id);

            selectedPartnerId = string.Empty;
            pairPage = Math.Clamp(pairPage, 1, GetPairPageCount());
            successMessage = "Pareja eliminada correctamente.";

            LoadData();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private int GetPairPageCount()
    {
        return Math.Max(1, (int)Math.Ceiling(pairs.Count / (double)PairPageSize));
    }

    private int GetCurrentPairPage()
    {
        return Math.Clamp(pairPage, 1, GetPairPageCount());
    }

    private List<PairDto> GetPagedPairs()
    {
        int currentPage = GetCurrentPairPage();

        return pairs
            .Skip((currentPage - 1) * PairPageSize)
            .Take(PairPageSize)
            .ToList();
    }

    private int GetFirstVisiblePairNumber()
    {
        if (!pairs.Any())
            return 0;

        return ((GetCurrentPairPage() - 1) * PairPageSize) + 1;
    }

    private int GetLastVisiblePairNumber()
    {
        if (!pairs.Any())
            return 0;

        return Math.Min(GetCurrentPairPage() * PairPageSize, pairs.Count);
    }

    private void PreviousPairPage()
    {
        pairPage = Math.Max(1, pairPage - 1);
    }

    private void NextPairPage()
    {
        pairPage = Math.Min(GetPairPageCount(), pairPage + 1);
    }

    private bool IsMyPair(PairDto pair)
    {
        return CurrentPlayer != null &&
            (pair.PlayerOneId == CurrentPlayer.Id || pair.PlayerTwoId == CurrentPlayer.Id);
    }

    private bool CanDeletePair(PairDto pair)
    {
        return IsMyPair(pair);
    }

    private static string GetCategoryLabel(int? category)
    {
        if (!category.HasValue)
            return "-";

        return category.Value.ToString();
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
