@page "/tournaments/{TournamentId:guid}/groups/{GroupId:guid}"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject StandingService StandingService
@inject QualificationService QualificationService
@rendermode InteractiveServer

<PageTitle>Detalle del grupo</PageTitle>

@if (tournament == null || group == null)
{
    <div class="alert alert-danger">
        No se encontró el grupo.
    </div>

    <a class="btn btn-secondary" href="/tournaments">
        Volver a torneos
    </a>
}
else
{
    <div class="mb-3">
        <a class="btn btn-link px-0" href="@($"/tournaments/{tournament.Id}")">
            ← Volver al torneo
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">@group.Name</h1>
            <p class="text-muted mb-0">
                Torneo: <strong>@tournament.Name</strong>
            </p>
            <p class="text-muted mb-0">
                Categoría: <strong>@group.CategoryLabel</strong>
            </p>
        </div>

        <div class="text-end">
            <span class="badge bg-dark fs-6">
                Clasifican @QualifiedPairsCount
            </span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4 class="card-title mb-3">Agregar pareja</h4>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Jugador 1</label>
                    <input class="form-control"
                           placeholder="Ejemplo: Juan"
                           disabled="@group.Matches.Any()"
                           @bind="playerOneName" />
                </div>

                <div class="col-md-6 mb-3">
                    <label class="form-label">Jugador 2</label>
                    <input class="form-control"
                           placeholder="Ejemplo: Pedro"
                           disabled="@group.Matches.Any()"
                           @bind="playerTwoName" />
                </div>
            </div>

            <button class="btn btn-primary"
                    disabled="@group.Matches.Any()"
                    @onclick="AddPair">
                Agregar pareja
            </button>

            @if (group.Matches.Any())
            {
                <small class="text-muted ms-2">
                    No se pueden agregar parejas después de generar los partidos.
                </small>
            }
        </div>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h3 class="mb-0">Parejas</h3>

                <span class="badge bg-secondary">
                    @group.Pairs.Count cargadas
                </span>
            </div>

            @if (!group.Pairs.Any())
            {
                <div class="alert alert-info mb-0">
                    Todavía no hay parejas cargadas.
                </div>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var pair in group.Pairs)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span>@pair.DisplayName</span>
                            <span class="badge bg-light text-dark">Pareja</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="mb-4">
        <button class="btn btn-success"
                disabled="@(group.Pairs.Count < 2 || group.Matches.Any())"
                @onclick="GenerateMatches">
            Generar partidos del grupo
        </button>

        @if (group.Pairs.Count < 2)
        {
            <small class="text-muted ms-2">
                Agregá al menos 2 parejas para generar partidos.
            </small>
        }

        @if (group.Matches.Any())
        {
            <small class="text-muted ms-2">
                Los partidos ya fueron generados.
            </small>
        }
    </div>

    <h3 class="mb-3">Partidos</h3>

    @if (!group.Matches.Any())
    {
        <div class="alert alert-info">
            Todavía no hay partidos generados.
        </div>
    }
    else
    {
        <div class="table-responsive mb-5">
            <table class="table table-striped align-middle match-table">
                <thead class="table-light">
                    <tr>
                        <th>Pareja 1</th>
                        <th>Pareja 2</th>
                        <th>Set 1</th>
                        <th>Set 2</th>
                        <th>Super tie-break</th>
                        <th>Resultado</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var match in group.Matches)
                    {
                        var input = GetMatchInput(match.Id);
                        var isEditing = IsEditingMatch(match.Id);
                        var showInputs = !match.HasResult || isEditing;

                        <tr>
                            <td>
                                <strong>@match.PairOne.DisplayName</strong>
                            </td>

                            <td>
                                <strong>@match.PairTwo.DisplayName</strong>
                            </td>

                            @if (showInputs)
                            {
                                <td>
                                    <div class="d-flex gap-2 align-items-center">
                                        <input type="number"
                                               min="0"
                                               max="7"
                                               class="form-control score-input"
                                               @bind="input.SetOnePairOne" />
                                        <span>-</span>
                                        <input type="number"
                                               min="0"
                                               max="7"
                                               class="form-control score-input"
                                               @bind="input.SetOnePairTwo" />
                                    </div>
                                </td>

                                <td>
                                    <div class="d-flex gap-2 align-items-center">
                                        <input type="number"
                                               min="0"
                                               max="7"
                                               class="form-control score-input"
                                               @bind="input.SetTwoPairOne" />
                                        <span>-</span>
                                        <input type="number"
                                               min="0"
                                               max="7"
                                               class="form-control score-input"
                                               @bind="input.SetTwoPairTwo" />
                                    </div>
                                </td>

                                <td>
                                    @if (FirstTwoSetsAreSplit(input))
                                    {
                                        <div class="form-check mb-2">
                                            <input class="form-check-input"
                                                   type="checkbox"
                                                   @bind="input.UseSuperTieBreak" />
                                            <label class="form-check-label">
                                                Usar STB
                                            </label>
                                        </div>

                                        @if (input.UseSuperTieBreak)
                                        {
                                            <div class="d-flex gap-2 align-items-center">
                                                <input type="number"
                                                       min="0"
                                                       class="form-control score-input"
                                                       @bind="input.SuperTieBreakPairOne" />
                                                <span>-</span>
                                                <input type="number"
                                                       min="0"
                                                       class="form-control score-input"
                                                       @bind="input.SuperTieBreakPairTwo" />
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">
                                            No aplica
                                        </span>
                                    }
                                </td>
                            }
                            else
                            {
                                <td colspan="3">
                                    <span class="text-muted">
                                        Resultado cargado. Podés editarlo o limpiarlo.
                                    </span>
                                </td>
                            }

                            <td>
                                @if (match.HasResult && match.Result != null)
                                {
                                    <span class="badge bg-success">
                                        @match.Result.DisplayScore
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">
                                        Pendiente
                                    </span>
                                }
                            </td>

                            <td class="text-end">
                                @if (showInputs)
                                {
                                    <button class="btn btn-sm btn-outline-primary me-2"
                                            @onclick="() => RegisterResult(match.Id)">
                                        @(isEditing ? "Guardar cambios" : "Guardar")
                                    </button>

                                    @if (isEditing)
                                    {
                                        <button class="btn btn-sm btn-outline-secondary"
                                                @onclick="() => CancelEditResult(match.Id)">
                                            Cancelar
                                        </button>
                                    }
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-primary me-2"
                                            @onclick="() => StartEditResult(match.Id)">
                                        Editar
                                    </button>

                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => ClearResult(match.Id)">
                                        Limpiar
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <h3 class="mb-3">Tabla de posiciones</h3>

    @if (!standings.Any())
    {
        <div class="alert alert-info">
            La tabla aparecerá cuando agregues parejas.
        </div>
    }
    else
    {
        @if (!HasAnyResult && group.Matches.Any())
        {
            <div class="alert alert-warning">
                Todavía no hay resultados cargados. La clasificación se calculará cuando se guarde el primer partido.
            </div>
        }

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Pareja</th>
                        <th title="Partidos jugados">PJ</th>
                        <th title="Partidos ganados">PG</th>
                        <th title="Partidos perdidos">PP</th>
                        <th title="Sets a favor">SF</th>
                        <th title="Sets en contra">SC</th>
                        <th title="Diferencia de sets">DS</th>
                        <th title="Games a favor">GF</th>
                        <th title="Games en contra">GC</th>
                        <th title="Diferencia de games">DG</th>
                        <th>Puntos</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < standings.Count; i++)
                    {
                        var standing = standings[i];

                        <tr class="@GetStandingRowClass(i)">
                            <td>
                                <strong>@(i + 1)</strong>
                            </td>
                            <td>
                                <strong>@standing.Pair.DisplayName</strong>
                            </td>
                            <td>@standing.Played</td>
                            <td>@standing.Won</td>
                            <td>@standing.Lost</td>
                            <td>@standing.SetsFor</td>
                            <td>@standing.SetsAgainst</td>
                            <td>@standing.SetDifference</td>
                            <td>@standing.GamesFor</td>
                            <td>@standing.GamesAgainst</td>
                            <td>@standing.GameDifference</td>
                            <td>
                                <strong>@standing.Points</strong>
                            </td>
                            <td>
                                @if (qualificationByPairId.ContainsKey(standing.Pair.Id))
                                {
                                    var status = qualificationByPairId[standing.Pair.Id].Status;

                                    <span class="badge @GetQualificationBadgeClass(status)">
                                        @GetQualificationLabel(status)
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">
                                        Sin partidos
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-muted mt-2">
            <small>
                PJ: partidos jugados · PG: ganados · PP: perdidos · SF/SC: sets a favor/en contra · GF/GC: games a favor/en contra.
            </small>
        </div>
    }
}

@code {
    private const int QualifiedPairsCount = 2;

    [Parameter]
    public Guid TournamentId { get; set; }

    [Parameter]
    public Guid GroupId { get; set; }

    private Tournament? tournament;
    private Group? group;

    private bool HasAnyResult => group?.Matches.Any(match => match.HasResult) == true;

    private List<Standing> standings = new();
    private List<PairQualification> qualifications = new();
    private Dictionary<Guid, PairQualification> qualificationByPairId = new();

    private string playerOneName = string.Empty;
    private string playerTwoName = string.Empty;
    private string? errorMessage;
    private string? successMessage;

    private Dictionary<Guid, MatchInput> matchInputs = new();
    private HashSet<Guid> editingMatchIds = new();

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        tournament = TournamentService.GetTournamentById(TournamentId);
        group = tournament?.Groups.FirstOrDefault(g => g.Id == GroupId);

        RefreshStandings();

        if (group != null)
        {
            foreach (var match in group.Matches)
            {
                if (!matchInputs.ContainsKey(match.Id))
                {
                    matchInputs[match.Id] = new MatchInput();
                }
            }
        }
    }

    private void RefreshStandings()
    {
        if (group == null)
        {
            standings = new List<Standing>();
            qualifications = new List<PairQualification>();
            qualificationByPairId = new Dictionary<Guid, PairQualification>();
            return;
        }

        standings = StandingService.CalculateStandings(group);

        if (group.Pairs.Count > QualifiedPairsCount && HasAnyResult)
        {
            qualifications = QualificationService.CalculateQualifications(
                group,
                QualifiedPairsCount
            );

            qualificationByPairId = qualifications
                .ToDictionary(qualification => qualification.Pair.Id);
        }
        else
        {
            qualifications = new List<PairQualification>();
            qualificationByPairId = new Dictionary<Guid, PairQualification>();
        }
    }

    private void AddPair()
    {
        if (tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.AddPairToGroup(
                tournament.Id,
                group.Id,
                playerOneName,
                playerTwoName
            );

            playerOneName = string.Empty;
            playerTwoName = string.Empty;

            LoadData();

            successMessage = "Pareja agregada correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void GenerateMatches()
    {
        if (tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.GenerateGroupMatches(tournament.Id, group.Id);
            LoadData();

            successMessage = "Partidos generados correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private MatchInput GetMatchInput(Guid matchId)
    {
        if (!matchInputs.ContainsKey(matchId))
        {
            matchInputs[matchId] = new MatchInput();
        }

        return matchInputs[matchId];
    }

    private bool IsEditingMatch(Guid matchId)
    {
        return editingMatchIds.Contains(matchId);
    }

    private void StartEditResult(Guid matchId)
    {
        if (group == null)
            return;

        var match = group.Matches.FirstOrDefault(match => match.Id == matchId);

        if (match == null || match.Result == null)
            return;

        FillInputFromResult(match);
        editingMatchIds.Add(matchId);

        errorMessage = null;
        successMessage = null;
    }

    private void CancelEditResult(Guid matchId)
    {
        editingMatchIds.Remove(matchId);

        if (group == null)
            return;

        var match = group.Matches.FirstOrDefault(match => match.Id == matchId);

        if (match?.Result != null)
        {
            FillInputFromResult(match);
        }

        errorMessage = null;
        successMessage = null;
    }

    private void ClearResult(Guid matchId)
    {
        if (tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.ClearMatchResult(
                tournament.Id,
                group.Id,
                matchId
            );

            matchInputs[matchId] = new MatchInput();
            editingMatchIds.Remove(matchId);

            LoadData();

            successMessage = "Resultado limpiado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void RegisterResult(Guid matchId)
    {
        if (tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            var input = GetMatchInput(matchId);

            var sets = new List<MatchSet>
            {
                new MatchSet(input.SetOnePairOne, input.SetOnePairTwo),
                new MatchSet(input.SetTwoPairOne, input.SetTwoPairTwo)
            };

            if (ShouldUseSuperTieBreak(input))
            {
                sets.Add(new MatchSet(
                    input.SuperTieBreakPairOne,
                    input.SuperTieBreakPairTwo,
                    true
                ));
            }

            TournamentService.RegisterMatchResult(
                tournament.Id,
                group.Id,
                matchId,
                sets
            );

            editingMatchIds.Remove(matchId);

            LoadData();

            successMessage = "Resultado guardado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void FillInputFromResult(Match match)
    {
        if (match.Result == null)
            return;

        var input = GetMatchInput(match.Id);
        var sets = match.Result.Sets;

        input.SetOnePairOne = sets[0].PairOneScore;
        input.SetOnePairTwo = sets[0].PairTwoScore;

        input.SetTwoPairOne = sets[1].PairOneScore;
        input.SetTwoPairTwo = sets[1].PairTwoScore;

        if (sets.Count == 3)
        {
            input.UseSuperTieBreak = true;
            input.SuperTieBreakPairOne = sets[2].PairOneScore;
            input.SuperTieBreakPairTwo = sets[2].PairTwoScore;
        }
        else
        {
            input.UseSuperTieBreak = false;
            input.SuperTieBreakPairOne = 0;
            input.SuperTieBreakPairTwo = 0;
        }
    }

    private bool ShouldUseSuperTieBreak(MatchInput input)
    {
        if (!input.UseSuperTieBreak)
            return false;

        return FirstTwoSetsAreSplit(input);
    }

    private bool FirstTwoSetsAreSplit(MatchInput input)
    {
        var pairOneWonSetOne = input.SetOnePairOne > input.SetOnePairTwo;
        var pairTwoWonSetOne = input.SetOnePairTwo > input.SetOnePairOne;

        var pairOneWonSetTwo = input.SetTwoPairOne > input.SetTwoPairTwo;
        var pairTwoWonSetTwo = input.SetTwoPairTwo > input.SetTwoPairOne;

        return (pairOneWonSetOne && pairTwoWonSetTwo) ||
               (pairTwoWonSetOne && pairOneWonSetTwo);
    }

    private string GetQualificationLabel(QualificationStatus status)
    {
        return status switch
        {
            QualificationStatus.MathematicallyQualified => "Clasificado",
            QualificationStatus.InQualificationZone => "En zona",
            QualificationStatus.Alive => "Con chances",
            QualificationStatus.MathematicallyEliminated => "Eliminado",
            _ => "Desconocido"
        };
    }

    private string GetQualificationBadgeClass(QualificationStatus status)
    {
        return status switch
        {
            QualificationStatus.MathematicallyQualified => "bg-success",
            QualificationStatus.InQualificationZone => "bg-primary",
            QualificationStatus.Alive => "bg-warning text-dark",
            QualificationStatus.MathematicallyEliminated => "bg-danger",
            _ => "bg-dark"
        };
    }

    private string GetStandingRowClass(int index)
    {
        if (!HasAnyResult)
            return string.Empty;

        return index < QualifiedPairsCount ? "table-success" : string.Empty;
    }

    private class MatchInput
    {
        public int SetOnePairOne { get; set; }
        public int SetOnePairTwo { get; set; }

        public int SetTwoPairOne { get; set; }
        public int SetTwoPairTwo { get; set; }

        public bool UseSuperTieBreak { get; set; }

        public int SuperTieBreakPairOne { get; set; }
        public int SuperTieBreakPairTwo { get; set; }
    }
}