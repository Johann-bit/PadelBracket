@page "/tournaments/{TournamentId:guid}/groups/{GroupId:guid}"
@using PadelBracket.Domain.Entities
@using PadelBracket.Domain.Enums
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject StandingService StandingService
@inject QualificationService QualificationService
@inject OrganizerAccountService OrganizerAccountService
@rendermode InteractiveServer

<PageTitle>Detalle del grupo</PageTitle>

@if (tournament == null || group == null)
{
    <div class="alert alert-danger">
        No se encontró el grupo.
    </div>

    <a class="btn btn-secondary" href="/tournaments">
        Volver a torneos
    </a>
}
else if (CurrentOrganizer == null)
{
    <div class="page-header">
        <div class="page-eyebrow">Panel de organizador</div>
        <h1 class="page-title">Acceso de organizador</h1>
        <p class="page-subtitle">
            Iniciá sesión como organizador para administrar este grupo.
        </p>
    </div>

    <div class="empty-state">
        <div class="empty-state-title">No hay una sesión de organizador activa.</div>
        <div class="mb-3">
            Entrá con tu cuenta de organizador para ver y editar grupos.
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-primary" href="/organizer/login">
                Ingresar como organizador
            </a>

            <a class="btn btn-outline-primary" href="/tournaments">
                Volver a torneos
            </a>
        </div>
    </div>
}
else if (!CanManageTournament)
{
    <div class="page-header">
        <div class="page-eyebrow">Panel de organizador</div>
        <h1 class="page-title">Acceso denegado</h1>
        <p class="page-subtitle">
            Este grupo pertenece a un torneo de otra cuenta de organizador.
        </p>
    </div>

    <div class="empty-state">
        <div class="empty-state-title">No podés administrar este grupo.</div>
        <div class="mb-3">
            Solo el organizador dueño del torneo puede editar parejas, partidos y resultados.
        </div>

        <a class="btn btn-primary" href="/tournaments">
            Volver a mis torneos
        </a>
    </div>
}
else
{
    <div class="mb-3">
        <a class="btn btn-link px-0" href="@($"/tournaments/{tournament.Id}")">
            ← Volver al torneo
        </a>
    </div>

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="mb-1">@group.Name</h1>
            <p class="text-muted mb-0">
                Torneo: <strong>@tournament.Name</strong>
            </p>
            <p class="text-muted mb-0">
                Categoría: <strong>@group.CategoryLabel</strong>
            </p>
        </div>

        <div class="text-end">
            <span class="badge bg-dark fs-6">
                Clasifican @QualifiedPairsCount
            </span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <h4 class="card-title mb-3">Agregar pareja confirmada</h4>

            <p class="text-muted mb-4">
                Seleccioná una inscripción confirmada de este torneo y de esta categoría.
            </p>

            <div class="mb-3">
                <label class="form-label">Inscripción</label>

                <select class="form-select"
                        disabled="@group.Matches.Any()"
                        @bind="selectedRegistrationId">
                    <option value="">Seleccionar inscripción</option>

                    @foreach (var registration in AvailableRegistrations)
                    {
                        <option value="@registration.Id">
                            @registration.Pair.DisplayName
                        </option>
                    }
                </select>
            </div>

            <button class="btn btn-primary"
                    disabled="@(group.Matches.Any() || !AvailableRegistrations.Any())"
                    @onclick="AddPair">
                Agregar pareja
            </button>

            @if (!tournament.Registrations.Any())
            {
                <small class="text-muted ms-2">
                    Todavía no hay inscripciones en este torneo.
                </small>
            }
            else if (!AvailableRegistrations.Any() && !group.Matches.Any())
            {
                <small class="text-muted ms-2">
                    No hay inscripciones confirmadas disponibles para esta categoría.
                </small>
            }

            @if (group.Matches.Any())
            {
                <small class="text-muted ms-2">
                    No se pueden agregar ni eliminar parejas después de generar los partidos.
                </small>
            }
        </div>
    </div>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <div>
                    <h3 class="mb-1">Parejas</h3>
                    <p class="text-muted mb-0">
                        Gestioná las parejas antes de generar los partidos del grupo.
                    </p>
                </div>

                <span class="badge bg-secondary">
                    @group.Pairs.Count cargadas
                </span>
            </div>

            @if (!group.Pairs.Any())
            {
                <div class="alert alert-info mb-0">
                    Todavía no hay parejas cargadas.
                </div>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var pair in group.Pairs)
                    {
                        <li class="list-group-item">
                            <div class="d-flex justify-content-between align-items-center gap-3">
                                <div>
                                    <strong>@pair.DisplayName</strong>
                                </div>

                                @if (!group.Matches.Any())
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => RemovePair(pair.Id)">
                                        Eliminar
                                    </button>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">Pareja</span>
                                }
                            </div>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>

    <div class="mb-4">
        <button class="btn btn-success"
                disabled="@(group.Pairs.Count < 3 || group.Matches.Any())"
                @onclick="GenerateMatches">
            Generar partidos del grupo
        </button>

        @if (group.Pairs.Count < 3)
        {
            <small class="text-muted ms-2">
                Agregá al menos 3 parejas para generar partidos.
            </small>
        }

        @if (group.Matches.Any())
        {
            <small class="text-muted ms-2">
                Los partidos ya fueron generados.
            </small>
        }
    </div>

    <h3 class="mb-3">Partidos</h3>

    @if (!group.Matches.Any())
    {
        <div class="alert alert-info">
            Todavía no hay partidos generados.
        </div>
    }
    else
    {
        <div class="match-list mb-5">
            @foreach (var match in group.Matches)
            {
                var input = GetMatchInput(match.Id);
                var isEditing = IsEditingMatch(match.Id);
                var showInputs = !match.HasResult || isEditing;

                <div class="match-card">
                    <div class="match-card-header">
                        <div class="match-pair-stack">
                            <strong>@match.PairOne.DisplayName</strong>
                            <span>vs</span>
                            <strong>@match.PairTwo.DisplayName</strong>
                        </div>

                        @if (match.HasResult && match.Result != null)
                        {
                            <span class="badge bg-success">
                                @match.Result.DisplayScore
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">
                                Pendiente
                            </span>
                        }
                    </div>

                    @if (showInputs)
                    {
                        <div class="match-score-grid">
                            <div class="match-score-field">
                                <label>Set 1</label>
                                <div class="score-pair-inputs">
                                    <input type="number"
                                           min="0"
                                           max="7"
                                           class="form-control score-input"
                                           @bind="input.SetOnePairOne" />
                                    <span>-</span>
                                    <input type="number"
                                           min="0"
                                           max="7"
                                           class="form-control score-input"
                                           @bind="input.SetOnePairTwo" />
                                </div>
                            </div>

                            <div class="match-score-field">
                                <label>Set 2</label>
                                <div class="score-pair-inputs">
                                    <input type="number"
                                           min="0"
                                           max="7"
                                           class="form-control score-input"
                                           @bind="input.SetTwoPairOne" />
                                    <span>-</span>
                                    <input type="number"
                                           min="0"
                                           max="7"
                                           class="form-control score-input"
                                           @bind="input.SetTwoPairTwo" />
                                </div>
                            </div>

                            <div class="match-score-field">
                                <label>Super tie-break</label>

                                @if (FirstTwoSetsAreSplit(input))
                                {
                                    <div class="form-check mb-2">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               @bind="input.UseSuperTieBreak" />
                                        <label class="form-check-label">
                                            Usar STB
                                        </label>
                                    </div>

                                    @if (input.UseSuperTieBreak)
                                    {
                                        <div class="score-pair-inputs">
                                            <input type="number"
                                                   min="0"
                                                   class="form-control score-input"
                                                   @bind="input.SuperTieBreakPairOne" />
                                            <span>-</span>
                                            <input type="number"
                                                   min="0"
                                                   class="form-control score-input"
                                                   @bind="input.SuperTieBreakPairTwo" />
                                        </div>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">
                                        No aplica
                                    </span>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="match-result-note">
                            Resultado cargado. Podés editarlo o limpiarlo.
                        </div>
                    }

                    <div class="match-card-actions">
                        @if (showInputs)
                        {
                            <button class="btn btn-sm btn-outline-primary"
                                    @onclick="() => RegisterResult(match.Id)">
                                @(isEditing ? "Guardar cambios" : "Guardar")
                            </button>

                            @if (isEditing)
                            {
                                <button class="btn btn-sm btn-outline-secondary"
                                        @onclick="() => CancelEditResult(match.Id)">
                                    Cancelar
                                </button>
                            }
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-primary"
                                    @onclick="() => StartEditResult(match.Id)">
                                Editar
                            </button>

                            <button class="btn btn-sm btn-outline-danger"
                                    @onclick="() => ClearResult(match.Id)">
                                Limpiar
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
    }

    <h3 class="mb-3">Tabla de posiciones</h3>

    @if (!standings.Any())
    {
        <div class="alert alert-info">
            La tabla aparecerá cuando agregues parejas.
        </div>
    }
    else
    {
        @if (!HasAnyResult && group.Matches.Any())
        {
            <div class="alert alert-warning">
                Todavía no hay resultados cargados. La clasificación se calculará cuando se guarde el primer partido.
            </div>
        }

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>#</th>
                        <th>Pareja</th>
                        <th title="Partidos jugados">PJ</th>
                        <th title="Partidos ganados">PG</th>
                        <th title="Partidos perdidos">PP</th>
                        <th title="Sets a favor">SF</th>
                        <th title="Sets en contra">SC</th>
                        <th title="Diferencia de sets">DS</th>
                        <th title="Games a favor">GF</th>
                        <th title="Games en contra">GC</th>
                        <th title="Diferencia de games">DG</th>
                        <th>Puntos</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < standings.Count; i++)
                    {
                        var standing = standings[i];

                        <tr class="@GetStandingRowClass(i)">
                            <td>
                                <strong>@(i + 1)</strong>
                            </td>
                            <td>
                                <strong>@standing.Pair.DisplayName</strong>
                            </td>
                            <td>@standing.Played</td>
                            <td>@standing.Won</td>
                            <td>@standing.Lost</td>
                            <td>@standing.SetsFor</td>
                            <td>@standing.SetsAgainst</td>
                            <td>@standing.SetDifference</td>
                            <td>@standing.GamesFor</td>
                            <td>@standing.GamesAgainst</td>
                            <td>@standing.GameDifference</td>
                            <td>
                                <strong>@standing.Points</strong>
                            </td>
                            <td>
                                @if (qualificationByPairId.ContainsKey(standing.Pair.Id))
                                {
                                    var status = qualificationByPairId[standing.Pair.Id].Status;

                                    <span class="badge @GetQualificationBadgeClass(status)">
                                        @GetQualificationLabel(status)
                                    </span>
                                }
                                else if (standing.Played > 0)
                                {
                                    <span class="badge bg-secondary">
                                        Fuera de zona
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-light text-dark">
                                        Sin partidos
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="text-muted mt-2">
            <small>
                PJ: partidos jugados · PG: ganados · PP: perdidos · SF/SC: sets a favor/en contra · GF/GC: games a favor/en contra.
            </small>
        </div>
    }
}

@code {
    private const int QualifiedPairsCount = 2;

    [Parameter]
    public Guid TournamentId { get; set; }

    [Parameter]
    public Guid GroupId { get; set; }

    private Tournament? tournament;
    private Group? group;

    private bool HasAnyResult => group?.Matches.Any(match => match.HasResult) == true;

    private List<Standing> standings = new();
    private List<PairQualification> qualifications = new();
    private Dictionary<Guid, PairQualification> qualificationByPairId = new();

    private string selectedRegistrationId = string.Empty;
    private string? errorMessage;
    private string? successMessage;

    private Dictionary<Guid, MatchInput> matchInputs = new();
    private HashSet<Guid> editingMatchIds = new();

    private Organizer? CurrentOrganizer => OrganizerAccountService.CurrentOrganizer;

    private bool CanManageTournament =>
        tournament != null &&
        CurrentOrganizer != null &&
        tournament.OrganizerId == CurrentOrganizer.Id;

    private List<TournamentRegistration> AvailableRegistrations
    {
        get
        {
            if (tournament == null || group == null)
                return new List<TournamentRegistration>();

            var assignedPairIds = tournament.Groups
                .SelectMany(group => group.Pairs)
                .Select(pair => pair.Id)
                .ToHashSet();

            return tournament.Registrations
                .Where(registration => registration.Status == RegistrationStatus.Confirmed)
                .Where(registration => registration.Category == group.Category)
                .Where(registration => !assignedPairIds.Contains(registration.Pair.Id))
                .OrderBy(registration => registration.Pair.DisplayName)
                .ToList();
        }
    }

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        tournament = TournamentService.GetTournamentById(TournamentId);
        group = tournament?.Groups.FirstOrDefault(g => g.Id == GroupId);

        RefreshStandings();

        if (group != null)
        {
            foreach (var match in group.Matches)
            {
                if (!matchInputs.ContainsKey(match.Id))
                {
                    matchInputs[match.Id] = new MatchInput();
                }
            }
        }
    }

    private bool EnsureCanManageTournament()
    {
        if (tournament == null || group == null)
            return false;

        if (CurrentOrganizer == null)
        {
            errorMessage = "Tenés que iniciar sesión como organizador.";
            return false;
        }

        if (tournament.OrganizerId != CurrentOrganizer.Id)
        {
            errorMessage = "Solo podés administrar torneos asociados a tu cuenta.";
            return false;
        }

        return true;
    }

    private void RefreshStandings()
    {
        if (group == null)
        {
            standings = new List<Standing>();
            qualifications = new List<PairQualification>();
            qualificationByPairId = new Dictionary<Guid, PairQualification>();
            return;
        }

        standings = StandingService.CalculateStandings(group);

        if (group.Pairs.Count <= QualifiedPairsCount && HasAnyResult)
        {
            qualifications = standings
                .Select((standing, index) => new PairQualification(
                    standing.Pair,
                    QualificationStatus.MathematicallyQualified,
                    index + 1))
                .ToList();

            qualificationByPairId = qualifications
                .ToDictionary(qualification => qualification.Pair.Id);
        }
        else if (group.Pairs.Count > QualifiedPairsCount && HasAnyResult)
        {
            qualifications = QualificationService.CalculateQualifications(
                group,
                QualifiedPairsCount
            );

            qualificationByPairId = qualifications
                .ToDictionary(qualification => qualification.Pair.Id);
        }
        else
        {
            qualifications = new List<PairQualification>();
            qualificationByPairId = new Dictionary<Guid, PairQualification>();
        }
    }

    private void AddPair()
    {
        if (!EnsureCanManageTournament() || tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            if (string.IsNullOrWhiteSpace(selectedRegistrationId))
                throw new ArgumentException("You must select a registration.");

            TournamentService.AddConfirmedRegistrationPairToGroup(
                tournament.Id,
                group.Id,
                Guid.Parse(selectedRegistrationId)
            );

            selectedRegistrationId = string.Empty;

            LoadData();

            successMessage = "Pareja agregada correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void RemovePair(Guid pairId)
    {
        if (!EnsureCanManageTournament() || tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.RemovePairFromGroup(
                tournament.Id,
                group.Id,
                pairId
            );

            LoadData();

            successMessage = "Pareja eliminada correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void GenerateMatches()
    {
        if (!EnsureCanManageTournament() || tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.GenerateGroupMatches(tournament.Id, group.Id);
            LoadData();

            successMessage = "Partidos generados correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private MatchInput GetMatchInput(Guid matchId)
    {
        if (!matchInputs.ContainsKey(matchId))
        {
            matchInputs[matchId] = new MatchInput();
        }

        return matchInputs[matchId];
    }

    private bool IsEditingMatch(Guid matchId)
    {
        return editingMatchIds.Contains(matchId);
    }

    private void StartEditResult(Guid matchId)
    {
        if (!EnsureCanManageTournament() || group == null)
            return;

        var match = group.Matches.FirstOrDefault(match => match.Id == matchId);

        if (match == null || match.Result == null)
            return;

        FillInputFromResult(match);
        editingMatchIds.Add(matchId);

        errorMessage = null;
        successMessage = null;
    }

    private void CancelEditResult(Guid matchId)
    {
        editingMatchIds.Remove(matchId);

        if (group == null)
            return;

        var match = group.Matches.FirstOrDefault(match => match.Id == matchId);

        if (match?.Result != null)
        {
            FillInputFromResult(match);
        }

        errorMessage = null;
        successMessage = null;
    }

    private void ClearResult(Guid matchId)
    {
        if (!EnsureCanManageTournament() || tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            TournamentService.ClearMatchResult(
                tournament.Id,
                group.Id,
                matchId
            );

            matchInputs[matchId] = new MatchInput();
            editingMatchIds.Remove(matchId);

            LoadData();

            successMessage = "Resultado limpiado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void RegisterResult(Guid matchId)
    {
        if (!EnsureCanManageTournament() || tournament == null || group == null)
            return;

        errorMessage = null;
        successMessage = null;

        try
        {
            var input = GetMatchInput(matchId);

            var sets = new List<MatchSet>
            {
                new MatchSet(input.SetOnePairOne, input.SetOnePairTwo),
                new MatchSet(input.SetTwoPairOne, input.SetTwoPairTwo)
            };

            if (ShouldUseSuperTieBreak(input))
            {
                sets.Add(new MatchSet(
                    input.SuperTieBreakPairOne,
                    input.SuperTieBreakPairTwo,
                    true
                ));
            }

            TournamentService.RegisterMatchResult(
                tournament.Id,
                group.Id,
                matchId,
                sets
            );

            editingMatchIds.Remove(matchId);

            LoadData();

            successMessage = "Resultado guardado correctamente.";
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void FillInputFromResult(Match match)
    {
        if (match.Result == null)
            return;

        var input = GetMatchInput(match.Id);
        var sets = match.Result.Sets;

        input.SetOnePairOne = sets[0].PairOneScore;
        input.SetOnePairTwo = sets[0].PairTwoScore;

        input.SetTwoPairOne = sets[1].PairOneScore;
        input.SetTwoPairTwo = sets[1].PairTwoScore;

        if (sets.Count == 3)
        {
            input.UseSuperTieBreak = true;
            input.SuperTieBreakPairOne = sets[2].PairOneScore;
            input.SuperTieBreakPairTwo = sets[2].PairTwoScore;
        }
        else
        {
            input.UseSuperTieBreak = false;
            input.SuperTieBreakPairOne = 0;
            input.SuperTieBreakPairTwo = 0;
        }
    }

    private bool ShouldUseSuperTieBreak(MatchInput input)
    {
        if (!input.UseSuperTieBreak)
            return false;

        return FirstTwoSetsAreSplit(input);
    }

    private bool FirstTwoSetsAreSplit(MatchInput input)
    {
        var pairOneWonSetOne = input.SetOnePairOne > input.SetOnePairTwo;
        var pairTwoWonSetOne = input.SetOnePairTwo > input.SetOnePairOne;

        var pairOneWonSetTwo = input.SetTwoPairOne > input.SetTwoPairTwo;
        var pairTwoWonSetTwo = input.SetTwoPairTwo > input.SetTwoPairOne;

        return (pairOneWonSetOne && pairTwoWonSetTwo) ||
               (pairTwoWonSetOne && pairOneWonSetTwo);
    }

    private string GetQualificationLabel(QualificationStatus status)
    {
        return status switch
        {
            QualificationStatus.MathematicallyQualified => "Clasificado",
            QualificationStatus.InQualificationZone => "En zona",
            QualificationStatus.Alive => "Con chances",
            QualificationStatus.MathematicallyEliminated => "Eliminado",
            _ => "Desconocido"
        };
    }

    private string GetQualificationBadgeClass(QualificationStatus status)
    {
        return status switch
        {
            QualificationStatus.MathematicallyQualified => "bg-success",
            QualificationStatus.InQualificationZone => "bg-primary",
            QualificationStatus.Alive => "bg-warning text-dark",
            QualificationStatus.MathematicallyEliminated => "bg-danger",
            _ => "bg-dark"
        };
    }

    private string GetStandingRowClass(int index)
    {
        if (!HasAnyResult)
            return string.Empty;

        return index < QualifiedPairsCount ? "table-success" : string.Empty;
    }

    private class MatchInput
    {
        public int SetOnePairOne { get; set; }
        public int SetOnePairTwo { get; set; }

        public int SetTwoPairOne { get; set; }
        public int SetTwoPairTwo { get; set; }

        public bool UseSuperTieBreak { get; set; }

        public int SuperTieBreakPairOne { get; set; }
        public int SuperTieBreakPairTwo { get; set; }
    }
}
