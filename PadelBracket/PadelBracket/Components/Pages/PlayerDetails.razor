@page "/players/{PlayerId:guid}"
@using PadelBracket.Domain.DTOs
@using PadelBracket.Domain.Enums
@using PadelBracket.Services
@inject PlayerService PlayerService

<PageTitle>Jugador</PageTitle>

@if (player == null)
{
    <div class="page-header">
        <div class="page-eyebrow">Jugador</div>
        <h1 class="page-title">Jugador no encontrado</h1>
        <p class="page-subtitle">
            No existe un jugador registrado con esa referencia.
        </p>
    </div>

    <div class="empty-state">
        <div class="empty-state-title">No encontramos este jugador.</div>
        <div class="mb-3">
            Volvé al listado para revisar los jugadores registrados.
        </div>

        <a class="btn btn-primary" href="/players">
            Ver jugadores
        </a>
    </div>
}
else
{
    <div class="page-header">
        <div class="page-eyebrow">Ficha de jugador</div>
        <h1 class="page-title">@player.Name</h1>
        <p class="page-subtitle">
            Datos deportivos, categoría, ranking y estado del perfil.
        </p>
    </div>

    <div class="stat-grid">
        <div class="stat-card">
            <div class="stat-label">Categoría</div>
            <div class="stat-value">@GetCategoryLabel(player.Category)</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Puntos</div>
            <div class="stat-value">@player.RankingPoints</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Estado</div>
            <div class="stat-value">@GetProfileStatus(player)</div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <h4 class="card-title mb-2">Datos deportivos</h4>

            <p class="text-muted mb-4">
                Información principal para formar pareja y competir en torneos.
            </p>

            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <tbody>
                        <tr>
                            <th>Nombre real</th>
                            <td>@player.Name</td>
                        </tr>

                        <tr>
                            <th>Mano hábil</th>
                            <td>@GetDominantHandLabel(player.DominantHand)</td>
                        </tr>

                        <tr>
                            <th>Lado de juego</th>
                            <td>@GetPreferredSideLabel(player.PreferredSide)</td>
                        </tr>

                        <tr>
                            <th>Categoría</th>
                            <td>@GetCategoryLabel(player.Category)</td>
                        </tr>

                        <tr>
                            <th>Referencia</th>
                            <td>
                                <span class="badge bg-secondary">
                                    @player.ShortId
                                </span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-body">
            <h4 class="card-title mb-2">Estado del jugador</h4>

            <div class="d-flex gap-2 flex-wrap">
                <span class="badge @GetVerificationBadgeClass(player.VerificationStatus)">
                    @GetVerificationLabel(player.VerificationStatus)
                </span>

                @if (player.HasCompleteProfile)
                {
                    <span class="badge bg-success">Perfil completo</span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">Perfil incompleto</span>
                }
            </div>

            <div class="mt-4">
                <a class="btn btn-outline-primary" href="/players">
                    Volver a jugadores
                </a>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid PlayerId { get; set; }

    private PlayerDto? player;

    protected override void OnParametersSet()
    {
        player = PlayerService.GetDtoById(PlayerId);
    }

    private static string GetCategoryLabel(int? category)
    {
        if (!category.HasValue)
            return "-";

        return category.Value.ToString();
    }

    private static string GetDominantHandLabel(DominantHand? dominantHand)
    {
        return dominantHand switch
        {
            DominantHand.Right => "Derecha",
            DominantHand.Left => "Zurda",
            _ => "-"
        };
    }

    private static string GetPreferredSideLabel(PreferredSide? preferredSide)
    {
        return preferredSide switch
        {
            PreferredSide.Drive => "Drive",
            PreferredSide.Backhand => "Revés",
            PreferredSide.Both => "Ambos",
            _ => "-"
        };
    }

    private static string GetProfileStatus(PlayerDto player)
    {
        return player.HasCompleteProfile ? "Completo" : "Incompleto";
    }

    private static string GetVerificationLabel(PlayerVerificationStatus status)
    {
        return status switch
        {
            PlayerVerificationStatus.Pending => "Verificación pendiente",
            PlayerVerificationStatus.Verified => "Verificado",
            PlayerVerificationStatus.Rejected => "Verificación rechazada",
            _ => status.ToString()
        };
    }

    private static string GetVerificationBadgeClass(PlayerVerificationStatus status)
    {
        return status switch
        {
            PlayerVerificationStatus.Verified => "bg-success",
            PlayerVerificationStatus.Rejected => "bg-danger",
            _ => "bg-secondary"
        };
    }
}