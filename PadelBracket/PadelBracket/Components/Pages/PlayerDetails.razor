@page "/players/{PlayerId:guid}"
@using PadelBracket.Domain.DTOs
@using PadelBracket.Domain.Enums
@using PadelBracket.Services
@inject PlayerService PlayerService

<PageTitle>Jugador</PageTitle>

@if (player == null)
{
    <div class="dashboard-hero player-page-hero">
        <div>
            <div class="page-eyebrow">Jugador</div>
            <h1 class="page-title">Jugador no encontrado</h1>
            <p class="page-subtitle">
                No existe un jugador registrado con esa referencia.
            </p>
        </div>

        <a class="btn btn-primary" href="/players">
            Ver jugadores
        </a>
    </div>

    <div class="empty-state">
        <div class="empty-state-title">No encontramos este jugador.</div>
        <div>
            Volvé al listado para revisar los jugadores registrados.
        </div>
    </div>
}
else
{
    <div class="player-detail-hero">
        <div class="player-detail-avatar">
            @GetInitials(player.Name)
        </div>

        <div class="player-detail-identity">
            <div class="page-eyebrow">Ficha de jugador</div>
            <h1 class="page-title">@player.Name</h1>
            <p class="page-subtitle">
                Datos deportivos, categoría, ranking y estado del perfil.
            </p>

            <div class="player-detail-tags">
                <span class="players-reference">@player.ShortId</span>
                <span class="@GetProfileBadgeClass(player)">@GetProfileStatus(player)</span>
                <span class="@GetVerificationPillClass(player.VerificationStatus)">
                    @GetVerificationLabel(player.VerificationStatus)
                </span>
            </div>
        </div>

        <a class="btn btn-outline-primary" href="/players">
            Volver a jugadores
        </a>
    </div>

    <div class="metric-grid player-detail-metric-grid">
        <div class="metric-card">
            <div class="metric-icon">CT</div>
            <div>
                <div class="metric-label">Categoría</div>
                <div class="metric-value metric-value-text">@GetCategoryLabel(player.Category)</div>
                <div class="metric-trend">Nivel competitivo</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">PTS</div>
            <div>
                <div class="metric-label">Puntos</div>
                <div class="metric-value">@player.RankingPoints</div>
                <div class="metric-trend positive">Ranking acumulado</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">MN</div>
            <div>
                <div class="metric-label">Mano hábil</div>
                <div class="metric-value metric-value-text">@GetDominantHandLabel(player.DominantHand)</div>
                <div class="metric-trend">Perfil deportivo</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">LD</div>
            <div>
                <div class="metric-label">Lado de juego</div>
                <div class="metric-value metric-value-text">@GetPreferredSideLabel(player.PreferredSide)</div>
                <div class="metric-trend">Preferencia de cancha</div>
            </div>
        </div>
    </div>

    <div class="player-detail-grid">
        <div class="card player-detail-card">
            <div class="card-body">
                <div class="panel-kicker">Datos personales</div>
                <h4 class="card-title mb-2">Identidad</h4>
                <p class="text-muted mb-4">
                    Información principal usada para registro, parejas e inscripciones.
                </p>

                <div class="player-detail-list">
                    <div>
                        <span>Nombre real</span>
                        <strong>@player.Name</strong>
                    </div>

                    <div>
                        <span>Email</span>
                        <strong>@(string.IsNullOrWhiteSpace(player.Email) ? "Sin email" : player.Email)</strong>
                    </div>

                    <div>
                        <span>Referencia</span>
                        <strong>@player.ShortId</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="card player-detail-card">
            <div class="card-body">
                <div class="panel-kicker">Competencia</div>
                <h4 class="card-title mb-2">Datos deportivos</h4>
                <p class="text-muted mb-4">
                    Base para validar parejas, categorías y participación en torneos.
                </p>

                <div class="player-detail-list">
                    <div>
                        <span>Mano hábil</span>
                        <strong>@GetDominantHandLabel(player.DominantHand)</strong>
                    </div>

                    <div>
                        <span>Lado de juego</span>
                        <strong>@GetPreferredSideLabel(player.PreferredSide)</strong>
                    </div>

                    <div>
                        <span>Categoría</span>
                        <strong>@GetCategoryLabel(player.Category)</strong>
                    </div>
                </div>
            </div>
        </div>

        <div class="card player-detail-card player-detail-status-card">
            <div class="card-body">
                <div class="panel-kicker">Estado</div>
                <h4 class="card-title mb-2">Situación del perfil</h4>
                <p class="text-muted mb-4">
                    Un jugador con perfil completo ya tiene los datos mínimos para formar pareja.
                </p>

                <div class="player-detail-status-grid">
                    <div>
                        <span>Perfil</span>
                        <strong>@GetProfileStatus(player)</strong>
                    </div>

                    <div>
                        <span>Verificación</span>
                        <strong>@GetVerificationLabel(player.VerificationStatus)</strong>
                    </div>

                    <div>
                        <span>Ranking</span>
                        <strong>@player.RankingPoints puntos</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public Guid PlayerId { get; set; }

    private PlayerDto? player;

    protected override void OnParametersSet()
    {
        player = PlayerService.GetDtoById(PlayerId);
    }

    private static string GetInitials(string name)
    {
        string[] parts = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 0)
            return "JG";

        if (parts.Length == 1)
            return parts[0][0].ToString().ToUpperInvariant();

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    private static string GetCategoryLabel(int? category)
    {
        if (!category.HasValue)
            return "Sin categoría";

        return category.Value switch
        {
            1 => "1ra categoría",
            2 => "2da categoría",
            3 => "3ra categoría",
            4 => "4ta categoría",
            5 => "5ta categoría",
            6 => "6ta categoría",
            7 => "7ma categoría",
            8 => "8va categoría",
            _ => "Sin categoría"
        };
    }

    private static string GetDominantHandLabel(DominantHand? dominantHand)
    {
        return dominantHand switch
        {
            DominantHand.Right => "Derecha",
            DominantHand.Left => "Zurda",
            _ => "Sin mano"
        };
    }

    private static string GetPreferredSideLabel(PreferredSide? preferredSide)
    {
        return preferredSide switch
        {
            PreferredSide.Drive => "Drive",
            PreferredSide.Backhand => "Revés",
            PreferredSide.Both => "Ambos lados",
            _ => "Sin lado"
        };
    }

    private static string GetProfileStatus(PlayerDto player)
    {
        return player.HasCompleteProfile ? "Perfil completo" : "Perfil incompleto";
    }

    private static string GetProfileBadgeClass(PlayerDto player)
    {
        return player.HasCompleteProfile ? "players-profile-badge is-complete" : "players-profile-badge is-incomplete";
    }

    private static string GetVerificationLabel(PlayerVerificationStatus status)
    {
        return status switch
        {
            PlayerVerificationStatus.Pending => "Pendiente",
            PlayerVerificationStatus.Verified => "Verificado",
            PlayerVerificationStatus.Rejected => "Rechazado",
            _ => status.ToString()
        };
    }

    private static string GetVerificationPillClass(PlayerVerificationStatus status)
    {
        return status switch
        {
            PlayerVerificationStatus.Verified => "player-detail-pill is-verified",
            PlayerVerificationStatus.Rejected => "player-detail-pill is-rejected",
            _ => "player-detail-pill"
        };
    }
}
