@page "/organizer/profile"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject OrganizerAccountService OrganizerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Perfil organizador</PageTitle>

@if (CurrentOrganizer == null)
{
    <div class="dashboard-hero player-page-hero">
        <div>
            <div class="page-eyebrow">Cuenta de organizador</div>
            <h1 class="page-title">Mi perfil</h1>
            <p class="page-subtitle">
                Iniciá sesión como organizador para ver y editar tus datos.
            </p>
        </div>

        <a class="btn btn-primary" href="/organizer/login">
            Ingresar como organizador
        </a>
    </div>

    <div class="empty-state">
        <div class="empty-state-title">No hay una sesión de organizador activa.</div>
        <div>
            Entrá con tu cuenta de organizador para administrar torneos.
        </div>
    </div>
}
else
{
    <div class="organizer-profile-hero">
        <div class="organizer-profile-avatar">
            @GetInitials(CurrentOrganizer.RealName)
        </div>

        <div class="organizer-profile-identity">
            <div class="page-eyebrow">Cuenta de organizador</div>
            <h1 class="page-title">@CurrentOrganizer.RealName</h1>
            <p class="page-subtitle">
                Responsable de @CurrentOrganizer.ClubName en @CurrentOrganizer.City.
            </p>

            <div class="organizer-profile-tags">
                <span>@CurrentOrganizer.ClubName</span>
                <span>@CurrentOrganizer.City</span>
                <span>@(CurrentOrganizer.HasCompleteProfile ? "Perfil completo" : "Perfil incompleto")</span>
            </div>
        </div>

        <a class="btn btn-outline-primary" href="/tournaments">
            Mis torneos
        </a>
    </div>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(successMessage))
    {
        <div class="alert alert-success">
            @successMessage
        </div>
    }

    <div class="metric-grid organizer-profile-metric-grid">
        <div class="metric-card">
            <div class="metric-icon">OR</div>
            <div>
                <div class="metric-label">Organizador</div>
                <div class="metric-value metric-value-text">@CurrentOrganizer.RealName</div>
                <div class="metric-trend">Responsable principal</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">CL</div>
            <div>
                <div class="metric-label">Club</div>
                <div class="metric-value metric-value-text">@CurrentOrganizer.ClubName</div>
                <div class="metric-trend">Sede del torneo</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">UY</div>
            <div>
                <div class="metric-label">Ciudad</div>
                <div class="metric-value metric-value-text">@CurrentOrganizer.City</div>
                <div class="metric-trend">Ubicación base</div>
            </div>
        </div>

        <div class="metric-card">
            <div class="metric-icon">OK</div>
            <div>
                <div class="metric-label">Estado</div>
                <div class="metric-value metric-value-text">@(CurrentOrganizer.HasCompleteProfile ? "Completo" : "Incompleto")</div>
                <div class="metric-trend positive">Datos del panel</div>
            </div>
        </div>
    </div>

    <div class="organizer-profile-grid">
        <div class="card organizer-profile-form-card">
            <div class="card-body">
                <div class="panel-kicker">Editar perfil</div>
                <h4 class="card-title mb-2">Datos del organizador</h4>
                <p class="text-muted mb-4">
                    Estos datos se usan como referencia para torneos, clubes e inscripciones.
                </p>

                <div class="organizer-profile-form-grid">
                    <div class="form-field">
                        <span>Nombre real</span>
                        <input class="form-control"
                               autocomplete="name"
                               @bind="realName"
                               @bind:event="oninput" />
                    </div>

                    <div class="form-field">
                        <span>Email</span>
                        <input class="form-control"
                               type="email"
                               autocomplete="email"
                               @bind="email"
                               @bind:event="oninput" />
                    </div>

                    <div class="form-field">
                        <span>Club</span>
                        <input class="form-control"
                               @bind="clubName"
                               @bind:event="oninput" />
                    </div>

                    <div class="form-field">
                        <span>Ciudad</span>
                        <input class="form-control"
                               @bind="city"
                               @bind:event="oninput" />
                    </div>

                    <div class="form-field span-2">
                        <span>Teléfono</span>
                        <input class="form-control"
                               autocomplete="tel"
                               @bind="phone"
                               @bind:event="oninput" />
                    </div>
                </div>

                <div class="panel-actions">
                    <button class="btn btn-primary" @onclick="SaveProfile">
                        Guardar perfil
                    </button>
                </div>
            </div>
        </div>

        <div class="card organizer-profile-summary-card">
            <div class="card-body">
                <div class="panel-kicker">Resumen</div>
                <h4 class="card-title mb-2">Datos visibles</h4>
                <p class="text-muted mb-4">
                    Esta información ayuda a identificar al responsable del torneo.
                </p>

                <div class="player-detail-list">
                    <div>
                        <span>Email</span>
                        <strong>@CurrentOrganizer.Email</strong>
                    </div>

                    <div>
                        <span>Teléfono</span>
                        <strong>@CurrentOrganizer.Phone</strong>
                    </div>

                    <div>
                        <span>Alta</span>
                        <strong>@CurrentOrganizer.CreatedAt.ToString("dd/MM/yyyy HH:mm")</strong>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private string realName = string.Empty;
    private string email = string.Empty;
    private string clubName = string.Empty;
    private string city = string.Empty;
    private string phone = string.Empty;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private Organizer? CurrentOrganizer => OrganizerAccountService.CurrentOrganizer;

    protected override void OnInitialized()
    {
        LoadProfile();
    }

    private void LoadProfile()
    {
        if (CurrentOrganizer == null)
            return;

        realName = CurrentOrganizer.RealName;
        email = CurrentOrganizer.Email;
        clubName = CurrentOrganizer.ClubName;
        city = CurrentOrganizer.City;
        phone = CurrentOrganizer.Phone;
    }

    private void SaveProfile()
    {
        ClearMessages();

        if (CurrentOrganizer == null)
        {
            NavigationManager.NavigateTo("/organizer/login");
            return;
        }

        try
        {
            OrganizerAccountService.UpdateCurrentOrganizerProfile(
                realName,
                email,
                clubName,
                city,
                phone);

            successMessage = "Perfil de organizador actualizado correctamente.";
            LoadProfile();
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private static string GetInitials(string name)
    {
        string[] parts = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 0)
            return "OR";

        if (parts.Length == 1)
            return parts[0][0].ToString().ToUpperInvariant();

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
