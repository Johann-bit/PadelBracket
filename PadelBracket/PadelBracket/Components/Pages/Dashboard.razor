@page "/dashboard"
@using PadelBracket.Domain.Entities
@using PadelBracket.Services
@inject TournamentService TournamentService
@inject KnockoutService KnockoutService
@inject OrganizerAccountService OrganizerAccountService
@rendermode InteractiveServer

<PageTitle>Dashboard</PageTitle>

<section class="dashboard-hero">
    <div>
        <div class="page-eyebrow">Panel de organizador</div>
        <h1 class="page-title">Tournament Dashboard</h1>
        <p class="page-subtitle">
            Bienvenido@if (!string.IsNullOrWhiteSpace(OrganizerName)) { <span>, @OrganizerName</span> }. Controlá torneos, grupos, partidos y llaves desde un solo lugar.
        </p>
    </div>

    <a class="btn btn-primary dashboard-hero-action" href="/tournaments">
        <span>+</span>
        Crear torneo
    </a>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <span class="metric-icon">JG</span>
        <div>
            <div class="metric-label">Parejas activas</div>
            <div class="metric-value">@TotalPairs</div>
            <div class="metric-trend positive">+ @ActiveCategories categorías</div>
        </div>
        <div class="metric-sparkline" aria-hidden="true"></div>
    </article>

    <article class="metric-card">
        <span class="metric-icon">TR</span>
        <div>
            <div class="metric-label">Torneos</div>
            <div class="metric-value">@TotalTournaments</div>
            <div class="metric-trend positive">@GeneratedBrackets llaves generadas</div>
        </div>
        <div class="metric-sparkline" aria-hidden="true"></div>
    </article>

    <article class="metric-card">
        <span class="metric-icon">PT</span>
        <div>
            <div class="metric-label">Partidos jugados</div>
            <div class="metric-value">@CompletedMatches</div>
            <div class="metric-trend positive">@GlobalProgress% progreso global</div>
        </div>
        <div class="metric-sparkline" aria-hidden="true"></div>
    </article>

    <article class="metric-card">
        <span class="metric-icon">PD</span>
        <div>
            <div class="metric-label">Pendientes</div>
            <div class="metric-value">@PendingMatches</div>
            <div class="metric-trend muted">@TotalMatches partidos totales</div>
        </div>
        <div class="metric-sparkline" aria-hidden="true"></div>
    </article>
</section>

@if (!tournaments.Any())
{
    <div class="empty-state">
        <div class="empty-state-title">Todavía no hay datos para mostrar.</div>
        <div>
            Creá tu primer torneo para empezar a ver estadísticas en el dashboard.
        </div>
    </div>
}
else
{
    <section class="dashboard-grid">
        <article class="dashboard-panel dashboard-panel-lg">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Progreso general</div>
                    <h2>Estado competitivo</h2>
                </div>
                <span class="status-pill">@CompletedMatches / @TotalMatches jugados</span>
            </div>

            <div class="dashboard-progress-large">
                <div class="dashboard-progress-large-bar" style="width: @GlobalProgress%;"></div>
                <span>@GlobalProgress%</span>
            </div>

            <div class="dashboard-split-stats">
                <div>
                    <strong>@TotalGroups</strong>
                    <span>Grupos</span>
                </div>
                <div>
                    <strong>@ActiveCategories</strong>
                    <span>Categorías</span>
                </div>
                <div>
                    <strong>@GeneratedBrackets</strong>
                    <span>Llaves</span>
                </div>
            </div>
        </article>

        <article class="dashboard-panel">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Torneo activo</div>
                    <h2>@FeaturedTournament.Name</h2>
                </div>
                <span class="status-pill">@FeaturedTournament.StatusLabel</span>
            </div>

            <div class="featured-tournament-meta">
                <span>@FeaturedTournament.ClubName</span>
                <span>@FeaturedTournament.City</span>
                <span>@FeaturedTournament.StartDate.ToString("dd/MM/yyyy")</span>
            </div>

            <div class="mini-bracket-card">
                <div>
                    <strong>@GetCompletedMatches(FeaturedTournament)</strong>
                    <span>jugados</span>
                </div>
                <div>
                    <strong>@GetTotalMatches(FeaturedTournament)</strong>
                    <span>partidos</span>
                </div>
                <div>
                    <strong>@GetBracketCount(FeaturedTournament)</strong>
                    <span>llaves</span>
                </div>
            </div>

            <a class="panel-link" href="@($"/tournaments/{FeaturedTournament.Id}")">
                Abrir torneo
            </a>
        </article>

        <article class="dashboard-panel">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Llaves</div>
                    <h2>Eliminatorias</h2>
                </div>
                <a class="panel-link" href="/tournaments">Ver todas</a>
            </div>

            <div class="compact-list">
                @foreach (var bracket in RecentBrackets)
                {
                    <a class="compact-row" href="@($"/tournaments/{bracket.TournamentId}/categories/{bracket.Category}/knockout")">
                        <span class="compact-icon">LL</span>
                        <span>
                            <strong>@GetTournamentName(bracket.TournamentId)</strong>
                            <small>@GetCategoryLabel(bracket.Category) · @bracket.Matches.Count partidos</small>
                        </span>
                    </a>
                }
            </div>
        </article>

        <article class="dashboard-panel dashboard-panel-lg">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Torneos recientes</div>
                    <h2>Actividad de organizador</h2>
                </div>
                <a class="panel-link" href="/tournaments">Gestionar</a>
            </div>

            <div class="table-responsive dashboard-table-wrap">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Torneo</th>
                            <th>Club</th>
                            <th>Grupos</th>
                            <th>Partidos</th>
                            <th>Progreso</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var tournament in RecentTournaments)
                        {
                            var totalMatches = GetTotalMatches(tournament);
                            var completedMatches = GetCompletedMatches(tournament);
                            var progress = GetTournamentProgress(tournament);

                            <tr>
                                <td>
                                    <strong>@tournament.Name</strong>
                                    <div class="text-muted">@tournament.StartDate.ToString("dd/MM/yyyy")</div>
                                </td>
                                <td>@tournament.ClubName</td>
                                <td>@tournament.Groups.Count</td>
                                <td>@completedMatches / @totalMatches</td>
                                <td>
                                    <span class="badge @GetProgressBadgeClass(progress)">
                                        @progress%
                                    </span>
                                </td>
                                <td class="text-end">
                                    <a class="btn btn-sm btn-outline-primary"
                                       href="@($"/tournaments/{tournament.Id}")">
                                        Abrir
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>

        <article class="dashboard-panel">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Resultados</div>
                    <h2>Últimos cargados</h2>
                </div>
                <a class="panel-link" href="/matches/history">Historial</a>
            </div>

            @if (LatestResults.Any())
            {
                <div class="result-list">
                    @foreach (var result in LatestResults)
                    {
                        <div class="result-row">
                            <span class="result-check">OK</span>
                            <span>
                                <strong>@result.Winner</strong>
                                <small>venció a @result.Loser</small>
                            </span>
                            <strong>@result.Score</strong>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="empty-state compact-empty">
                    <div class="empty-state-title">Sin resultados cargados.</div>
                    <div>Cuando cargues partidos, van a aparecer acá.</div>
                </div>
            }
        </article>

        <article class="dashboard-panel">
            <div class="panel-header">
                <div>
                    <div class="panel-kicker">Ranking</div>
                    <h2>Top parejas</h2>
                </div>
                <a class="panel-link" href="/ranking">Ver ranking</a>
            </div>

            <div class="compact-list">
                @foreach (var pair in TopPairs)
                {
                    <div class="compact-row">
                        <span class="compact-icon">PR</span>
                        <span>
                            <strong>@pair.DisplayName</strong>
                            <small>@(pair.Category.HasValue ? GetCategoryLabel(pair.Category.Value) : "Sin categoría")</small>
                        </span>
                    </div>
                }
            </div>
        </article>
    </section>
}

@code {
    private List<Tournament> tournaments = new();
    private List<KnockoutBracket> brackets = new();

    private string OrganizerName =>
        OrganizerAccountService.CurrentOrganizer?.RealName ?? string.Empty;

    private int TotalTournaments => tournaments.Count;

    private int TotalGroups => tournaments
        .SelectMany(tournament => tournament.Groups)
        .Count();

    private int TotalPairs => tournaments
        .SelectMany(tournament => tournament.Groups)
        .Sum(group => group.Pairs.Count);

    private int TotalMatches => tournaments
        .SelectMany(tournament => tournament.Groups)
        .SelectMany(group => group.Matches)
        .Count();

    private int CompletedMatches => tournaments
        .SelectMany(tournament => tournament.Groups)
        .SelectMany(group => group.Matches)
        .Count(match => match.HasResult);

    private int PendingMatches => TotalMatches - CompletedMatches;

    private int GeneratedBrackets => brackets.Count;

    private int ActiveCategories => tournaments
        .SelectMany(tournament => tournament.Groups)
        .Select(group => group.Category)
        .Distinct()
        .Count();

    private int GlobalProgress
    {
        get
        {
            if (TotalMatches == 0)
                return 0;

            return (int)Math.Round((double)CompletedMatches / TotalMatches * 100);
        }
    }

    private Tournament FeaturedTournament => tournaments
        .OrderByDescending(GetTournamentProgress)
        .ThenByDescending(tournament => tournament.CreatedAt)
        .First();

    private List<Tournament> RecentTournaments => tournaments
        .OrderByDescending(tournament => tournament.CreatedAt)
        .Take(5)
        .ToList();

    private List<KnockoutBracket> RecentBrackets => brackets
        .OrderByDescending(bracket => bracket.CreatedAt)
        .Take(4)
        .ToList();

    private List<Pair> TopPairs => tournaments
        .SelectMany(tournament => tournament.Groups)
        .SelectMany(group => group.Pairs)
        .GroupBy(pair => pair.DisplayName)
        .Select(group => group.First())
        .Take(5)
        .ToList();

    private List<DashboardResult> LatestResults => tournaments
        .SelectMany(tournament => tournament.Groups)
        .SelectMany(group => group.Matches)
        .Where(match => match.HasResult && match.Winner != null && match.Loser != null && match.Result != null)
        .TakeLast(5)
        .Reverse()
        .Select(match => new DashboardResult(
            match.Winner!.DisplayName,
            match.Loser!.DisplayName,
            match.Result!.DisplayScore))
        .ToList();

    protected override void OnInitialized()
    {
        tournaments = TournamentService.GetAllTournaments();
        brackets = KnockoutService.GetAllBrackets();
    }

    private int GetTotalMatches(Tournament tournament)
    {
        return tournament.Groups.Sum(group => group.Matches.Count);
    }

    private int GetCompletedMatches(Tournament tournament)
    {
        return tournament.Groups
            .SelectMany(group => group.Matches)
            .Count(match => match.HasResult);
    }

    private int GetTournamentProgress(Tournament tournament)
    {
        var totalMatches = GetTotalMatches(tournament);

        if (totalMatches == 0)
            return 0;

        return (int)Math.Round((double)GetCompletedMatches(tournament) / totalMatches * 100);
    }

    private int GetBracketCount(Tournament tournament)
    {
        return brackets.Count(bracket => bracket.TournamentId == tournament.Id);
    }

    private string GetTournamentName(Guid tournamentId)
    {
        var tournament = tournaments.FirstOrDefault(tournament => tournament.Id == tournamentId);

        return tournament?.Name ?? "Torneo no encontrado";
    }

    private string GetProgressBadgeClass(int progress)
    {
        if (progress == 100)
            return "bg-success";

        if (progress >= 50)
            return "bg-primary";

        if (progress > 0)
            return "bg-warning text-dark";

        return "bg-secondary";
    }

    private string GetCategoryLabel(int category)
    {
        return category switch
        {
            1 => "1ra categoría",
            2 => "2da categoría",
            3 => "3ra categoría",
            4 => "4ta categoría",
            5 => "5ta categoría",
            6 => "6ta categoría",
            7 => "7ma categoría",
            8 => "8va categoría",
            _ => $"{category} categoría"
        };
    }

    private sealed record DashboardResult(string Winner, string Loser, string Score);
}
