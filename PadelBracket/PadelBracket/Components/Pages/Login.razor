@page "/login"
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Ingresar</PageTitle>

<div class="page-header">
    <div class="page-eyebrow">Cuenta de jugador</div>
    <h1 class="page-title">Ingresar</h1>
    <p class="page-subtitle">
        Entrá con tu email para acceder a tu perfil de jugador y anotarte a torneos.
    </p>
</div>

@if (!string.IsNullOrWhiteSpace(errorMessage))
{
    <div class="alert alert-danger">
        @errorMessage
    </div>
}

<div class="card mb-4">
    <div class="card-body">
        <h4 class="card-title mb-2">Iniciar sesión</h4>

        <p class="text-muted mb-4">
            Usá el email con el que registraste tu perfil.
        </p>

        <div class="mb-3">
            <label class="form-label">Email</label>
            <input class="form-control"
                   type="email"
                   placeholder="Ejemplo: juan@mail.com"
                   @bind="email"
                   @bind:event="oninput" />
        </div>

        <div class="mb-2">
            <label class="form-label">Contraseña</label>
            <input class="form-control"
                   type="password"
                   placeholder="Tu contraseña"
                   @bind="password"
                   @bind:event="oninput" />
        </div>

        <div class="mb-4">
            <a href="/forgot-password">
                Olvidé mi contraseña
            </a>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <button class="btn btn-primary" @onclick="LoginPlayer">
                Ingresar
            </button>

            <a class="btn btn-outline-primary" href="/register">
                Crear cuenta
            </a>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task LoginPlayer()
    {
        errorMessage = string.Empty;

        try
        {
            await PlayerAccountService.LoginAsync(email, password);

            NavigationManager.NavigateTo(GetSafeReturnUrl());
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
            return "/";

        if (!ReturnUrl.StartsWith("/") || ReturnUrl.StartsWith("//"))
            return "/";

        return ReturnUrl;
    }
}