@page "/login"
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService
@inject NavigationManager NavigationManager
@rendermode InteractiveServer

<PageTitle>Ingresar</PageTitle>

<div class="auth-shell">
    <section class="auth-panel">
        <div class="auth-card">
            <div class="auth-card-header">
                <span class="auth-badge">Jugador</span>
                <h1>Ingresar</h1>
                <p>
                    Entrá a tu cuenta para ver tu perfil, tu pareja, tus inscripciones y los torneos disponibles.
                </p>
            </div>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="alert alert-danger">
                    @errorMessage
                </div>
            }

            <div class="auth-form">
                <div class="form-field">
                    <span>Email</span>
                    <input class="form-control"
                           type="email"
                           placeholder="Ejemplo: juan@mail.com"
                           autocomplete="email"
                           @bind="email"
                           @bind:event="oninput" />
                </div>

                <div class="form-field">
                    <span>Contraseña</span>
                    <input class="form-control"
                           type="password"
                           placeholder="Tu contraseña"
                           autocomplete="current-password"
                           @bind="password"
                           @bind:event="oninput" />
                </div>

                <div class="auth-inline-actions">
                    <a href="/forgot-password">
                        Olvidé mi contraseña
                    </a>
                </div>

                <button class="btn btn-primary auth-submit"
                        @onclick="LoginPlayer">
                    Ingresar
                </button>
            </div>

            <div class="auth-footer">
                <span>¿Todavía no tenés cuenta?</span>
                <a href="/register">Crear cuenta de jugador</a>
            </div>
        </div>
    </section>

    <aside class="auth-side-panel">
        <div class="auth-side-card">
            <div class="auth-side-icon">PB</div>
            <h2>Tu circuito de pádel en un solo lugar.</h2>
            <p>
                Registrá tu perfil real, formá pareja y anotate a torneos por categoría.
            </p>

            <div class="auth-feature-list">
                <div>
                    <span>01</span>
                    <strong>Perfil competitivo</strong>
                    <small>Categoría, mano hábil y lado de juego siempre listos.</small>
                </div>

                <div>
                    <span>02</span>
                    <strong>Inscripciones claras</strong>
                    <small>Seguimiento de torneos, pagos y estados de tu pareja.</small>
                </div>

                <div>
                    <span>03</span>
                    <strong>Ranking vivo</strong>
                    <small>Los resultados cargados alimentan la tabla competitiva.</small>
                </div>
            </div>
        </div>
    </aside>
</div>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string email = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;

    private async Task LoginPlayer()
    {
        errorMessage = string.Empty;

        try
        {
            await PlayerAccountService.LoginAsync(email, password);

            NavigationManager.NavigateTo(GetSafeReturnUrl());
        }
        catch (Exception exception)
        {
            errorMessage = exception.Message;
        }
    }

    private string GetSafeReturnUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
            return "/";

        if (!ReturnUrl.StartsWith("/") || ReturnUrl.StartsWith("//"))
            return "/";

        return ReturnUrl;
    }
}
