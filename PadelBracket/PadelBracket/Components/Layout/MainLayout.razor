@inherits LayoutComponentBase
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService
@inject OrganizerAccountService OrganizerAccountService
@inject NavigationManager NavigationManager

<div class="app-shell">
    <aside class="app-sidebar">
        <NavMenu />
    </aside>

    <main class="app-main">
        <header class="app-topbar">
            <div>
                <span class="app-topbar-kicker">Panel de torneos</span>
            </div>

            <div class="topbar-account">
                @if (OrganizerAccountService.IsLoggedIn && OrganizerAccountService.CurrentOrganizer != null)
                {
                    <a class="topbar-player-name" href="/organizer/profile">
                        @OrganizerAccountService.CurrentOrganizer.RealName
                    </a>

                    <button class="btn btn-sm btn-outline-primary" @onclick="LogoutOrganizer">
                        Cerrar sesión
                    </button>
                }
                else if (PlayerAccountService.IsLoggedIn && PlayerAccountService.CurrentPlayer != null)
                {
                    <a class="topbar-player-name" href="/profile">
                        @PlayerAccountService.CurrentPlayer.Name
                    </a>

                    <button class="btn btn-sm btn-outline-primary" @onclick="LogoutPlayer">
                        Cerrar sesión
                    </button>
                }
                else
                {
                    <a class="btn btn-sm btn-outline-primary" href="/login">
                        Ingresar
                    </a>

                    <a class="btn btn-sm btn-primary" href="/register">
                        Registrarme
                    </a>

                    <a class="btn btn-sm btn-outline-primary" href="/organizer/login">
                        Organizador
                    </a>
                }
            </div>
        </header>

        <section class="app-content">
            @Body
        </section>
    </main>
</div>

<div id="blazor-error-ui">
    Ocurrió un error inesperado.
    <a href="" class="reload">Recargar</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private void LogoutPlayer()
    {
        PlayerAccountService.Logout();
        NavigationManager.NavigateTo("/");
    }

    private void LogoutOrganizer()
    {
        OrganizerAccountService.Logout();
        NavigationManager.NavigateTo("/");
    }
}