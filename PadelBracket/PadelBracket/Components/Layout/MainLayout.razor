@implements IDisposable
@inherits LayoutComponentBase
@using PadelBracket.Services
@inject PlayerAccountService PlayerAccountService
@inject OrganizerAccountService OrganizerAccountService
@inject NavigationManager NavigationManager

<div class="app-shell">
    <aside class="app-sidebar">
        <NavMenu />
    </aside>

    <main class="app-main">
        <header class="app-topbar">
            <div class="topbar-search">
                <span aria-hidden="true">SR</span>
                <input placeholder="Buscar jugadores, parejas, torneos..." />
            </div>

            <div class="topbar-account">
                @if (OrganizerAccountService.IsLoggedIn && OrganizerAccountService.CurrentOrganizer != null)
                {
                    <a class="topbar-profile" href="/organizer/profile">
                        <span class="topbar-avatar">@GetInitials(OrganizerAccountService.CurrentOrganizer.RealName)</span>
                        <span>
                            <strong>@OrganizerAccountService.CurrentOrganizer.RealName</strong>
                            <small>Organizador</small>
                        </span>
                    </a>

                    <button class="btn btn-sm btn-outline-primary" @onclick="LogoutOrganizer">
                        Cerrar sesión
                    </button>
                }
                else if (PlayerAccountService.IsLoggedIn && PlayerAccountService.CurrentPlayer != null)
                {
                    <a class="topbar-profile" href="/profile">
                        <span class="topbar-avatar">@GetInitials(PlayerAccountService.CurrentPlayer.Name)</span>
                        <span>
                            <strong>@PlayerAccountService.CurrentPlayer.Name</strong>
                            <small>Jugador</small>
                        </span>
                    </a>

                    <button class="btn btn-sm btn-outline-primary" @onclick="LogoutPlayer">
                        Cerrar sesión
                    </button>
                }
                else
                {
                    <a class="btn btn-sm btn-outline-primary" href="/login">
                        Ingresar
                    </a>

                    <a class="btn btn-sm btn-primary" href="/register">
                        Registrarme
                    </a>

                    <a class="btn btn-sm btn-outline-primary" href="/organizer/login">
                        Organizador
                    </a>
                }
            </div>
        </header>

        <section class="app-content">
            @Body
        </section>
    </main>
</div>

<div id="blazor-error-ui">
    Ocurrió un error inesperado.
    <a href="" class="reload">Recargar</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    protected override void OnInitialized()
    {
        PlayerAccountService.SessionChanged += RefreshTopbar;
        OrganizerAccountService.SessionChanged += RefreshTopbar;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        await PlayerAccountService.RestoreSessionAsync();
        StateHasChanged();
    }

    private async Task LogoutPlayer()
    {
        await PlayerAccountService.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }

    private void LogoutOrganizer()
    {
        OrganizerAccountService.Logout();
        NavigationManager.NavigateTo("/");
    }

    private void RefreshTopbar()
    {
        InvokeAsync(StateHasChanged);
    }

    private static string GetInitials(string name)
    {
        var parts = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Take(2)
            .ToList();

        if (!parts.Any())
            return "PB";

        return string.Concat(parts.Select(part => char.ToUpperInvariant(part[0])));
    }

    public void Dispose()
    {
        PlayerAccountService.SessionChanged -= RefreshTopbar;
        OrganizerAccountService.SessionChanged -= RefreshTopbar;
    }
}
